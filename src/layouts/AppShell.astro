---
import Layout from './Layout.astro'
const { title, pageTitle, pageSubtitle, pageCap } = Astro.props
---
<Layout title={title}>
<style is:global>
  .shell-wrap { max-width: 900px; padding: 40px 24px 120px; }
  .shell-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; }
  .shell-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(24px,5vw,36px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 4px; }
  .shell-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: #8A7A66; padding-bottom: 24px; border-bottom: 1px solid #C4B49E; margin-bottom: 32px; }
</style>
<div class="shell-wrap">
  {pageCap && <div class="shell-cap">{pageCap}</div>}
  {pageTitle && <div class="shell-title">{pageTitle}</div>}
  {pageSubtitle && <div class="shell-sub">{pageSubtitle}</div>}
  <slot />
</div>
</Layout>
