---
const { title } = Astro.props
import Layout from './Layout.astro'
---
<Layout title={title}>
<style is:global>
  /* PUBLIC NAV */
  .pub-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 40px; height: 64px;
    background: linear-gradient(to bottom, rgba(13,11,9,.8), rgba(13,11,9,.3));
    border-bottom: 1px solid #C4B49E;
  }
  .pub-logo {
    font-family: 'Prata', Georgia, serif;
    font-size: 12px; letter-spacing: 4px; text-transform: uppercase;
    color: #1C1810; text-decoration: none;
  }
  .pub-logo span { color: #7A5C20; }
  .pub-nav-links { display: flex; align-items: center; gap: 24px; }

  .pub-nav-link {
    font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(239,231,217,.7);
    text-decoration: none; transition: color .2s;
  }
  .pub-nav-link:hover { color: #EFE7D9; }
  .pub-nav-cta {
    font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: #fff; background: #B8860B;
    padding: 10px 20px; text-decoration: none; transition: background .2s; white-space: nowrap;
  }
  .pub-nav-cta:hover { background: #9A7009; }
  .pub-nav-signin {
    font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(239,231,217,.7); text-decoration: none;
    border: 1px solid rgba(239,231,217,.3); padding: 9px 16px; transition: all .2s;
  }
  .pub-nav-signin:hover { border-color: #EFE7D9; color: #EFE7D9; }

  /* CATEGORIES DROPDOWN */
  .pub-nav-dropdown { position: relative; }
  .pub-nav-dropdown-trigger {
    font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(239,231,217,.7);
    background: none; border: none; cursor: pointer; padding: 0;
    transition: color .2s; display: flex; align-items: center; gap: 6px;
  }
  .pub-nav-dropdown-trigger:hover { color: #EFE7D9; }
  .pub-nav-dropdown-menu {
    display: none; position: absolute; top: calc(100% + 16px); left: 50%;
    transform: translateX(-50%); background: rgba(20,16,10,.98);
    backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,.08);
    min-width: 200px; z-index: 200; padding: 8px 0;
  }
  .pub-nav-dropdown:hover .pub-nav-dropdown-menu { display: block; }
  .pub-nav-dropdown-item {
    display: block; font-family: 'Prata', Georgia, serif; font-size: 10px;
    letter-spacing: 2px; text-transform: uppercase;
    color: rgba(239,231,217,.6); text-decoration: none;
    padding: 10px 20px; transition: color .2s, background .2s;
  }
  .pub-nav-dropdown-item:hover { color: #EFE7D9; background: rgba(255,255,255,.05); }
  .pub-nav-dropdown-divider { height: 1px; background: rgba(255,255,255,.08); margin: 6px 0; }

  /* HAMBURGER */
  .pub-ham { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
  .pub-ham span { display: block; width: 18px; height: 1px; background: #EFE7D9; transition: all .25s; }
  .pub-ham.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .pub-ham.open span:nth-child(2) { opacity: 0; }
  .pub-ham.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* MOBILE DRAWER */
  .pub-drawer {
    display: none; position: fixed; top: 64px; left: 0; right: 0; z-index: 99;
    background: rgba(20,16,10,.98); backdrop-filter: blur(16px);
    flex-direction: column; padding: 24px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .pub-drawer.open { display: flex; }
  .pub-drawer-link {
    font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(239,231,217,.7); text-decoration: none;
    padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,.06); display: block;
  }
  .pub-drawer-link:hover { color: #EFE7D9; }
  .pub-drawer-cta {
    font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px;
    text-transform: uppercase; color: #fff; background: #B8860B;
    padding: 12px; text-decoration: none; text-align: center; margin-top: 16px; display: block;
  }

  @media (max-width: 767px) {
    .pub-nav { padding: 0 16px; }
    .pub-ham { display: flex; }
    .pub-nav-links .pub-nav-link { display: none; }
    .pub-nav-links .pub-nav-cta { display: none; }
    .pub-nav-links .pub-nav-account { display: none; }
  }

  /* PAGE BODY — offset for fixed nav */
  .pub-body { padding-top: 0; }

  /* PUBLIC FOOTER */
  .pub-footer {
    background: #E6DCCB; border-top: 1px solid #C4B49E;
    padding: 40px; margin-top: 80px;
  }
  .pub-footer-inner {
    max-width: 900px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 40px;
  }
  @media (max-width: 600px) { .pub-footer-inner { grid-template-columns: 1fr; gap: 24px; } }
  .pub-footer-logo {
    font-family: 'Prata', Georgia, serif;
    font-size: 11px; letter-spacing: 4px; text-transform: uppercase;
    color: #1C1810; margin-bottom: 10px;
  }
  .pub-footer-logo span { color: #7A5C20; }
  .pub-footer-tagline {
    font-family: 'Prata', Georgia, serif;
    font-size: 13px; color: #8A7A66; line-height: 1.8;
  }
  .pub-footer-heading {
    font-family: 'Prata', Georgia, serif;
    font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
    color: #5C5040; margin-bottom: 14px;
  }
  .pub-footer-link {
    display: block; font-family: 'Prata', Georgia, serif;
    font-size: 13px; color: #8A7A66; text-decoration: none;
    margin-bottom: 8px; transition: color .2s;
  }
  .pub-footer-link:hover { color: #7A5C20; }
  .pub-footer-bottom {
    max-width: 900px; margin: 32px auto 0;
    padding-top: 20px; border-top: 1px solid #C4B49E;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 12px;
  }
  .pub-footer-copy {
    font-family: 'Prata', Georgia, serif;
    font-size: 11px; color: #8A7A66;
  }

  /* Logged-in state — hide CTA, show account link */
  .pub-nav-cta.hidden { display: none; }
  .pub-nav-account {
    font-family: 'Prata', Georgia, serif;
    font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(239,231,217,.7); text-decoration: none; display: none;
  }
  .pub-nav-account.visible { display: block; }
</style>

<!-- NAV -->
<nav class="pub-nav">
  <a href="/" class="pub-logo">GAUK <span>Antiques</span></a>
  <button class="pub-ham" id="pub-ham" aria-label="Menu"><span></span><span></span><span></span></button>
  <div class="pub-nav-links">
    <div class="pub-nav-dropdown">
      <button class="pub-nav-dropdown-trigger">Categories ▾</button>
      <div class="pub-nav-dropdown-menu">
        <a href="/categories/pottery" class="pub-nav-dropdown-item">Pottery & Ceramics</a>
        <a href="/categories/silver" class="pub-nav-dropdown-item">Silver</a>
        <a href="/categories/furniture" class="pub-nav-dropdown-item">Furniture</a>
        <a href="/categories/art" class="pub-nav-dropdown-item">Art</a>
        <a href="/categories/glass" class="pub-nav-dropdown-item">Glass</a>
        <a href="/categories/jewellery" class="pub-nav-dropdown-item">Jewellery</a>
        <div class="pub-nav-dropdown-divider"></div>
        <a href="/explore" class="pub-nav-dropdown-item">All Categories →</a>
      </div>
    </div>
    <a href="/pricing" class="pub-nav-link">Pricing</a>
    <a href="/auth/signin" class="pub-nav-signin" id="pub-signin">Sign In</a>
    <a href="/identify" class="pub-nav-link pub-nav-account" id="pub-account">My Collection</a>
    <a href="/auth/signup" class="pub-nav-cta" id="pub-cta">Start Your Catalogue</a>
  </div>
</nav>

<!-- BODY -->
<div class="pub-body">
  <slot />
</div>

<!-- FOOTER -->
<footer class="pub-footer">
  <div class="pub-footer-inner">
    <div>
      <div class="pub-footer-logo">GAUK <span>Antiques</span></div>
      <div class="pub-footer-tagline">AI-powered antique identification and valuation. Built for collectors, dealers and curious minds.</div>
    </div>
    <div>
      <div class="pub-footer-heading">Discover</div>
      <a href="/" class="pub-footer-link">Identify an Item</a>
      <a href="/pricing" class="pub-footer-link">Pricing</a>
      <a href="/auth/signup" class="pub-footer-link">Create Account</a>
    </div>
    <div>
      <div class="pub-footer-heading">Network</div>
      <a href="https://gaukmotorbuzz.com" class="pub-footer-link">MotorBuzz</a>
      <a href="https://gauk.co.uk" class="pub-footer-link">GAUK Motors</a>
    </div>
  </div>
  <div class="pub-footer-bottom">
    <div class="pub-footer-copy">&copy; {new Date().getFullYear()} GAUK Media. All rights reserved.</div>
    <div class="pub-footer-copy">AI appraisals are estimates only and do not constitute formal valuations.</div>
  </div>
</footer>

<script>
  import { createClient } from '@supabase/supabase-js'
  const sb = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY)
  const ham = document.getElementById('pub-ham')
  const drawer = document.getElementById('pub-drawer')
  ham?.addEventListener('click', () => {
    ham.classList.toggle('open')
    drawer?.classList.toggle('open')
  })

  // Scroll behaviour — darken nav on scroll
  const nav = document.querySelector('.pub-nav')
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) nav?.classList.add('scrolled')
    else nav?.classList.remove('scrolled')
  })

  const { data: { session } } = await sb.auth.getSession()
  if (session) {
    const cta = document.getElementById('pub-cta')
    const signin = document.getElementById('pub-signin')
    const account = document.getElementById('pub-account')
    if (cta) cta.classList.add('hidden')
    if (signin) signin.style.display = 'none'
    if (account) account.classList.add('visible')
  }
</script>
</Layout>
