---
import Layout from '../../layouts/Layout.astro'
import { createClient } from '@supabase/supabase-js'

const { id } = Astro.params

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const { data: item } = await supabase
  .from('identifications')
  .select('*')
  .eq('id', id)
  .single()

if (!item) return Astro.redirect('/')

const r = item.result_json
const imageUrl = `https://pub-c3f96dd742f540188b92599aeed807c7.r2.dev/${item.image_key}`
---
<Layout title={`${r.subcategory} — GAUK Antiques Valuation`}>
  <style>
    .card-wrap {
      max-width: 560px; margin: 0 auto;
      padding: 0 0 120px;
    }

    /* ─── HEADER ─── */
    .card-header {
      position: sticky; top: 0; z-index: 50;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px;
      background: rgba(13,11,9,.92); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .card-logo {
      font-family: 'Prata', Georgia, serif;
      font-size: 12px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--text);
    }
    .card-logo span { color: var(--goldHi); }
    .card-date {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      color: var(--textMute);
    }

    /* ─── IMAGE ─── */
    .card-image {
      width: 100%; aspect-ratio: 4/3;
      object-fit: contain;
      background: var(--surface);
      display: block;
    }

    /* ─── CATEGORY BADGE ─── */
    .card-badges {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px 0;
    }
    .card-category {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold);
    }
    .card-confidence {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      padding: 4px 10px; border: 1px solid var(--border); color: var(--textMute);
    }

    /* ─── TITLE ─── */
    .card-title {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: clamp(22px, 5vw, 32px); font-weight: 400; line-height: 1.2;
      color: var(--text); padding: 12px 20px 0;
    }

    /* ─── DESCRIPTION — typewriter ─── */
    .card-desc {
      padding: 16px 20px 20px;
      font-family: 'Prata', Georgia, serif;
      font-size: 16px; line-height: 1.9; color: var(--textDim);
      border-bottom: 1px solid var(--border);
      min-height: 80px;
    }
    .cursor {
      display: inline-block; width: 2px; height: 1em;
      background: var(--goldHi); margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink .7s step-end infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* ─── ID TABLE ─── */
    .id-table { padding: 0 20px; border-bottom: 1px solid var(--border); }
    .id-row {
      display: flex; gap: 16px; align-items: flex-start;
      padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .id-row:last-child { border-bottom: none; }
    .id-key {
      width: 100px; flex-shrink: 0;
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--textMute); padding-top: 2px;
    }
    .id-val {
      font-family: 'Prata', Georgia, serif;
      font-size: 16px; color: var(--text); line-height: 1.5; flex: 1;
    }

    /* ─── VALUE SECTION ─── */
    .value-section {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 32px 20px; text-align: center;
    }
    .value-label {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--textMute); margin-bottom: 12px;
    }
    .value-number {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: clamp(36px, 8vw, 56px); font-weight: 400; line-height: 1;
      color: var(--goldHi); letter-spacing: -1px; margin-bottom: 8px;
    }
    .value-strip {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--border); margin-top: 24px;
    }
    .value-strip-cell {
      background: var(--surface); padding: 14px 8px;
    }
    .value-strip-label {
      font-family: 'Prata', Georgia, serif;
      font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--textMute); margin-bottom: 6px;
    }
    .value-strip-val {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 20px; color: var(--text);
    }

    /* ─── CONDITION NOTES ─── */
    .notes-section { padding: 24px 20px; border-bottom: 1px solid var(--border); }
    .notes-heading {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--textMute); margin-bottom: 14px;
    }
    .notes-text {
      font-family: 'Prata', Georgia, serif;
      font-size: 16px; line-height: 1.9; color: var(--textDim);
    }

    /* ─── BLUR GATE ─── */
    .blur-gate {
      position: relative;
    }
    .blur-content {
      filter: blur(6px);
      pointer-events: none;
      user-select: none;
    }
    .blur-overlay {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 24px; gap: 12px;
      background: linear-gradient(to bottom, transparent 0%, rgba(13,11,9,.7) 30%, rgba(13,11,9,.95) 100%);
    }
    .blur-headline {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 22px; font-weight: 400; color: var(--text);
      text-align: center; line-height: 1.3; margin-bottom: 4px;
    }
    .blur-sub {
      font-family: 'Prata', Georgia, serif;
      font-size: 13px; color: var(--textDim);
      text-align: center; line-height: 1.7; margin-bottom: 8px;
    }
    .btn-register {
      width: 100%; max-width: 320px; padding: 16px;
      background: var(--text); border: none;
      font-family: 'Prata', Georgia, serif;
      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--bg); cursor: pointer; text-decoration: none;
      display: block; text-align: center; transition: opacity .2s;
    }
    .btn-register:hover { opacity: .9; }
    .btn-pay {
      width: 100%; max-width: 320px; padding: 15px;
      background: transparent; border: 1px solid var(--goldLo);
      font-family: 'Prata', Georgia, serif;
      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
      color: var(--goldHi); cursor: pointer; text-decoration: none;
      display: block; text-align: center; transition: border-color .2s;
    }
    .btn-pay:hover { border-color: var(--goldHi); }
    .blur-divider {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      color: var(--textMute);
    }

    /* ─── FOOTER ─── */
    .card-footer {
      padding: 24px 20px;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-brand {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 13px; font-style: italic; color: var(--gold);
    }
    .footer-id {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; color: var(--textMute);
    }

    /* ─── STICKY ACTIONS ─── */
    .sticky-actions {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      max-width: 560px; margin: 0 auto;
      background: rgba(13,11,9,.95); backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
      padding: 12px 20px 24px;
      display: flex; gap: 10px;
    }
    .action-btn {
      flex: 1; padding: 14px;
      background: transparent; border: 1px solid var(--border);
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      color: var(--textDim); cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      transition: border-color .2s, color .2s;
    }
    .action-btn:hover { border-color: var(--borderHi); color: var(--text); }
    .action-btn.primary {
      background: var(--text); border-color: var(--text); color: var(--bg);
    }
    .action-btn.primary:hover { opacity: .9; }
  </style>

  <div class="card-wrap">
    <header class="card-header">
      <div class="card-logo">GAUK <span>Antiques</span></div>
      <div class="card-date" id="card-date"></div>
    </header>

    <img class="card-image" src={imageUrl} alt={r.subcategory} />

    <div class="card-badges">
      <div class="card-category">{r.category}</div>
      <div class="card-confidence">{r.confidence}</div>
    </div>

    <h1 class="card-title">{r.subcategory}</h1>

    <div class="card-desc" id="card-desc">
      <span id="typed-text"></span><span class="cursor" id="cursor"></span>
    </div>

    <div class="id-table">
      {r.maker && (
        <div class="id-row">
          <div class="id-key">Maker</div>
          <div class="id-val">{r.maker}</div>
        </div>
      )}
      {r.period && (
        <div class="id-row">
          <div class="id-key">Period</div>
          <div class="id-val">{r.period}{r.circa ? ` — ${r.circa}` : ''}</div>
        </div>
      )}
      {r.country_of_origin && (
        <div class="id-row">
          <div class="id-key">Origin</div>
          <div class="id-val">{r.country_of_origin}</div>
        </div>
      )}
      <div class="id-row">
        <div class="id-key">Condition</div>
        <div class="id-val">{r.condition}</div>
      </div>
    </div>

    <!-- BLUR GATE wraps value + notes -->
    <div class="blur-gate" id="blur-gate">
      <div class="blur-content">
        <div class="value-section">
          <div class="value-label">Estimated Value</div>
          <div class="value-number">
            £{(r.value_range_low || 0).toLocaleString()} – £{(r.value_range_high || 0).toLocaleString()}
          </div>
          <div class="value-strip">
            <div class="value-strip-cell">
              <div class="value-strip-label">Low estimate</div>
              <div class="value-strip-val">£{(r.value_range_low || 0).toLocaleString()}</div>
            </div>
            <div class="value-strip-cell">
              <div class="value-strip-label">High estimate</div>
              <div class="value-strip-val">£{(r.value_range_high || 0).toLocaleString()}</div>
            </div>
          </div>
        </div>

        {r.condition_notes && (
          <div class="notes-section">
            <div class="notes-heading">Condition Notes</div>
            <div class="notes-text">{r.condition_notes}</div>
          </div>
        )}

        {r.confidence_notes && (
          <div class="notes-section">
            <div class="notes-heading">Appraiser Notes</div>
            <div class="notes-text">{r.confidence_notes}</div>
          </div>
        )}
      </div>

      <div class="blur-overlay" id="blur-overlay">
        <div class="blur-headline">Your valuation is ready</div>
        <div class="blur-sub">
          Create a free account to unlock the full report —<br/>value range, condition notes, and appraiser commentary.
        </div>
        <a href="/auth/signup" class="btn-register">Register Free</a>
        <div class="blur-divider">or</div>
        <a href="#" class="btn-pay">Full Certificate — £29.99</a>
      </div>
    </div>

    <div class="card-footer">
      <div class="footer-brand">GAUK Antiques</div>
      <div class="footer-id">REF {item.id.slice(0, 8).toUpperCase()}</div>
    </div>
  </div>

  <div class="sticky-actions">
    <button class="action-btn" onclick="window.print()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="6 9 6 2 18 2 18 9"/>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
        <rect x="6" y="14" width="12" height="8"/>
      </svg>
      Print
    </button>
    <button class="action-btn" id="share-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      Share
    </button>
    <a href="/" class="action-btn primary">New Identification</a>
  </div>
</Layout>

<script define:vars={{ description: r.description, itemId: item.id }}>
  // Date
  document.getElementById('card-date').textContent =
    new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })

  // Typewriter
  const target = document.getElementById('typed-text')
  const cursor = document.getElementById('cursor')
  const text = description || ''
  let i = 0
  function type() {
    if (i < text.length) {
      target.textContent += text[i]
      i++
      setTimeout(type, 28)
    } else {
      cursor.style.display = 'none'
    }
  }
  setTimeout(type, 400)

  // Auth check — remove blur if logged in
  async function checkAuth() {
    try {
      const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2')
      const supabase = createClient(
        document.querySelector('meta[name="supabase-url"]')?.content || '',
        document.querySelector('meta[name="supabase-anon"]')?.content || ''
      )
      const { data: { session } } = await supabase.auth.getSession()
      if (session) {
        document.getElementById('blur-overlay').style.display = 'none'
        document.querySelector('.blur-content').style.filter = 'none'
      }
    } catch(e) {}
  }
  checkAuth()

  // Share
  document.getElementById('share-btn').addEventListener('click', () => {
    if (navigator.share) {
      navigator.share({ title: 'GAUK Antiques Valuation', url: window.location.href })
    } else {
      navigator.clipboard.writeText(window.location.href)
      document.getElementById('share-btn').textContent = 'Copied'
    }
  })
</script>
