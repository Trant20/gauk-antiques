      const { terms, texts, dimensions, historical } = await fetchObjDetail(o.object_id)
      const extra = document.getElementById('art-obj-extra')
      if (!extra) return
      let html = ''
      if (terms.length) {
        const g = terms.reduce((a,t) => { (a[t.term_type]=a[t.term_type]||[]).push(t.term); return a }, {})
        html += Object.entries(g).map(([type,ts]) => `<div class="col-section-label">${type}</div><div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:4px">${ts.map(t=>badge(t,'gray')).join('')}</div>`).join('')
      }
      if (historical.length) {
        html += `<div class="col-section-label">Attribution history</div>${historical.map(h => `<div class="col-hist-block"><div class="col-hist-text">${h.forward_text}</div>${h.effective_date?`<div class="col-hist-meta">${h.data_type} · ${h.effective_date}</div>`:''}</div>`).join('')}`
      }
      if (texts.length) {
        const g = texts.reduce((a,t) => { (a[t.text_type]=a[t.text_type]||[]).push(t); return a }, {})
        html += Object.entries(g).map(([type,entries]) => `<div class="col-section-label">${type.replace(/_/g,' ')}</div>${entries.map(e=>`<div class="col-text-block">${e.year?`<span style="color:var(--text3);margin-right:6px">${e.year}</span>`:''}${e.text}</div>`).join('')}`).join('')
      }
      extra.innerHTML = html || ''
    })
  })
}

document.getElementById('art-search').addEventListener('input', e => {
  clearTimeout(artTimer); artTimer = setTimeout(() => fetchArtists(e.target.value.trim(), artLetter), 350)
})

// Alphabet filter
let artLetter = ''
document.querySelectorAll('.col-alpha').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.col-alpha').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    artLetter = btn.dataset.letter
    const q = document.getElementById('art-search').value.trim()
    fetchArtists(q, artLetter)
  })
})

// ── INIT WITH SERVER DATA ────────────────────────────────────
const initialEl = document.getElementById('col-initial-data')
if (initialEl) {
  const preloaded = JSON.parse(initialEl.dataset.objects || '[]')
  const preloadedCount = parseInt(initialEl.dataset.count || '0')
  if (preloaded.length) {
    // Seed cache so first search is instant
    searchCache.set('__', { data: preloaded, total: String(preloadedCount) })
    document.getElementById('obj-count').textContent = `${preloadedCount.toLocaleString()} objects`
    renderObjList(preloaded)
  } else {
    refreshObjs()
  }
} else {
  refreshObjs()
}

// ── HOVER PRELOAD ─────────────────────────────────────────────
document.getElementById('obj-list').addEventListener('mouseover', e => {
  const row = e.target.closest('.col-row')
  if (!row || !row.dataset.obj) return
  const o = JSON.parse(row.dataset.obj)
  if (!detailCache.has(o.object_id)) fetchObjDetail(o.object_id)
})
</script>
