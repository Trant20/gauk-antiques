---
import PublicShell from '../../layouts/PublicShell.astro'
import { supabase } from '../../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

const [
  { count: objects },
  { count: artists },
  { count: withImage },
] = await Promise.all([
  supabase.from('gauk_objects').select('*', { count: 'exact', head: true }),
  supabase.from('gauk_artists').select('*', { count: 'exact', head: true }),
  supabase.from('gauk_objects').select('*', { count: 'exact', head: true }).not('image_url', 'is', null),
])

const stats = {
  objects: objects ?? 0,
  artists: artists ?? 0,
  withImage: withImage ?? 0,
}

const { data: heroSetting } = await supabase
  .from('site_settings').select('value')
  .eq('site_id', SITE_ID).eq('key', 'category_hero_collections').single()

const { data: titleSetting } = await supabase
  .from('site_settings').select('value')
  .eq('site_id', SITE_ID).eq('key', 'category_title_collections').single()

const { data: subtitleSetting } = await supabase
  .from('site_settings').select('value')
  .eq('site_id', SITE_ID).eq('key', 'category_subtitle_collections').single()

// Fetch public source IDs
const { data: publicSources } = await supabase
  .from('gauk_sources')
  .select('id')
  .eq('is_public', true)
const publicSourceIds = (publicSources || []).map((s: any) => s.id)
const hasPublicSources = publicSourceIds.length > 0
const sourceFilter = hasPublicSources ? `{${publicSourceIds.join(',')}}` : null

const heroImage    = heroSetting?.value || ''
const heroTitle    = titleSetting?.value || 'The GAUK Knowledge Collection'
const heroSubtitle = subtitleSetting?.value || 'Search 145,000 works from world-class collections — paintings, sculpture, decorative arts and more.'

// Preload first 50 objects with images server-side
let initialQuery = supabase
  .from('gauk_objects')
  .select('gauk_id,title,display_date,attribution,classification,thumb_url,image_url,medium,dimensions,credit_line,provenance,slug,external_ids,properties')
  .not('image_url', 'is', null)
  .order('date_from', { ascending: true, nullsFirst: false })
  .limit(50)
if (sourceFilter) initialQuery = initialQuery.overlaps('sources', publicSourceIds)
const { data: initialObjects } = await initialQuery

const initialCount = stats.withImage
---
<PublicShell title="Museum Collection — GAUK Antiques" description="Search 145,000 works from world-class art collections">

<style is:global>
  :root {
    --pc: #1C1810; --pc2: rgba(28,24,16,.95);
    --card: rgba(239,231,217,.04); --border: rgba(200,160,96,.2);
    --surface: rgba(239,231,217,.03); --text: #EFE7D9;
    --text2: rgba(239,231,217,.7); --text3: rgba(239,231,217,.4);
    --t1: #C8A060; --tglow: rgba(200,160,96,.08);
    --radius: 4px; --radius2: 4px;
    --prata: 'Prata', Georgia, serif;
    --playfair: 'Playfair Display', Didot, Georgia, serif;
  }
  .col-hero { position: relative; min-height: 55vh; display: flex; align-items: flex-end; overflow: hidden; background: var(--pc); }
  .col-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .col-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.97) 0%, rgba(13,8,4,.55) 55%, rgba(13,8,4,.2) 100%); }
  .col-hero-content { position: relative; z-index: 2; width: 100%; max-width: 800px; margin: 0 auto; padding: 60px 40px; text-align: center; }
  @media (max-width: 767px) { .col-hero-content { padding: 80px 16px 40px; } }
  .col-hero-eyebrow { font-family: var(--prata); font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--t1); margin-bottom: 16px; }
  .col-hero-title { font-family: var(--playfair); font-size: clamp(36px,7vw,72px); font-weight: 400; font-style: italic; color: var(--text); line-height: 1.1; margin-bottom: 16px; }
  .col-hero-sub { font-family: var(--prata); font-size: 16px; color: var(--text3); line-height: 1.8; max-width: 560px; margin: 0 auto; }
  .col-body { background: var(--pc); min-height: 100vh; padding: 32px; }
  .col-inner { max-width: 1400px; margin: 0 auto; }
  .col-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 24px; }
  @media (max-width: 480px) { .col-stats { grid-template-columns: 1fr; gap: 8px; } }
  .col-stat { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius2); padding: 24px; }
  .col-stat-label { font-family: var(--prata); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 8px; }
  .col-stat-value { font-family: var(--playfair); font-style: italic; font-size: 28px; color: var(--text); line-height: 1; }
  .col-tabs { border-bottom: 1px solid var(--border); margin-bottom: 24px; display: flex; }
  .col-tab { padding: 10px 20px; cursor: pointer; border: none; background: transparent; border-bottom: 2px solid transparent; font-family: var(--prata); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); transition: all .15s; margin-bottom: -1px; }
  .col-tab.active { color: var(--t1); border-bottom-color: var(--t1); }
  .col-controls { display: flex; gap: 10px; margin-bottom: 16px; align-items: center; flex-wrap: wrap; }
  .col-search { flex: 1; padding: 8px 12px; font-family: var(--prata); font-size: 13px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card); color: var(--text); outline: none; }
  .col-search::placeholder { color: var(--text3); }
  .col-pill { padding: 6px 12px; font-family: var(--prata); font-size: 10px; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; border: 1px solid var(--border); border-radius: var(--radius); background: var(--card); color: var(--text3); transition: all .15s; }
  .col-pill.active { background: var(--tglow); color: var(--t1); border-color: var(--t1); }
  .col-count { font-family: var(--prata); font-size: 11px; color: var(--text3); margin-left: auto; letter-spacing: 0.05em; }
  .col-layout { display: flex; gap: 16px; align-items: flex-start; }
  .col-list { flex-shrink: 0; border: 1px solid var(--border); border-radius: var(--radius2); overflow: hidden; background: var(--card); }
  .col-list.full { width: 100%; } .col-list.narrow { width: 320px; }
  .col-row { padding: 10px 14px; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; gap: 10px; align-items: flex-start; background: transparent; border-left: 2px solid transparent; transition: background .15s; }
  .col-row:hover { background: var(--tglow); }
  .col-row.selected { background: var(--tglow); border-left-color: var(--t1); }
  .col-thumb { width: 44px; height: 44px; border-radius: var(--radius); background: var(--surface); border: 1px solid var(--border); flex-shrink: 0; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .col-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .col-thumb-empty { font-size: 18px; color: var(--text3); }
  .col-row-title { font-family: var(--playfair); font-size: 13px; font-style: italic; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
  .col-row-attr { font-family: var(--prata); font-size: 10px; color: var(--text3); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-badge { display: inline-block; font-family: var(--prata); font-size: 9px; letter-spacing: 0.05em; padding: 2px 7px; border-radius: var(--radius); margin-right: 4px; margin-top: 4px; }
  .col-badge-blue { background: rgba(24,95,165,.15); color: #7EB8F5; }
  .col-badge-purple { background: rgba(83,74,183,.15); color: #B8AEFF; }
  .col-badge-green { background: rgba(99,153,34,.15); color: #9FD46A; }
  .col-badge-amber { background: rgba(186,117,23,.15); color: #F5C97A; }
  .col-badge-gray { background: rgba(239,231,217,.08); color: var(--text3); }
  .col-detail { flex: 1; border: 1px solid var(--border); border-radius: var(--radius2); background: var(--card); padding: 24px; position: sticky; top: 80px; max-height: calc(100vh - 120px); overflow-y: auto; }
  .col-detail-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .col-detail-label-sm { font-family: var(--prata); font-size: 10px; color: var(--text3); letter-spacing: 0.08em; text-transform: uppercase; }
  .col-close { background: none; border: none; cursor: pointer; color: var(--text3); font-size: 16px; }
  .col-detail-img { width: 100%; max-height: 300px; object-fit: contain; border-radius: var(--radius); margin-bottom: 16px; background: var(--surface); }
  .col-detail-title { font-family: var(--playfair); font-size: 16px; font-style: italic; color: var(--text); margin-bottom: 4px; }
  .col-detail-attr { font-family: var(--playfair); font-size: 13px; font-style: italic; color: var(--t1); margin-bottom: 4px; }
  .col-detail-date { font-family: var(--prata); font-size: 11px; color: var(--text3); margin-bottom: 12px; }
  .col-field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
  .col-field-label { font-family: var(--prata); font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
  .col-field-val { font-family: var(--prata); font-size: 13px; color: var(--text2); line-height: 1.5; }
  .col-section-label { font-family: var(--prata); font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; margin-top: 16px; }
  .col-text-block { font-family: var(--prata); font-size: 13px; color: var(--text2); line-height: 1.6; padding: 8px 10px; background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 6px; }
  .col-wikidata { font-family: var(--prata); font-size: 11px; color: var(--t1); text-decoration: none; letter-spacing: 0.05em; }
  .col-artist-row { padding: 10px 14px; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; gap: 10px; align-items: center; background: transparent; border-left: 2px solid transparent; transition: background .15s; }
  .col-artist-row:hover { background: var(--tglow); }
  .col-artist-row.selected { background: var(--tglow); border-left-color: var(--t1); }
  .col-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--tglow); border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--t1); font-family: var(--playfair); font-style: italic; font-size: 15px; }
  .col-artist-name { font-family: var(--playfair); font-size: 13px; font-style: italic; color: var(--text); }
  .col-artist-meta { font-family: var(--prata); font-size: 10px; color: var(--text3); margin-top: 2px; }
  .col-work-row { display: flex; gap: 10px; align-items: center; padding: 8px; background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border); margin-bottom: 6px; cursor: pointer; }
  .col-work-thumb { width: 36px; height: 36px; object-fit: cover; border-radius: 4px; flex-shrink: 0; }
  .col-work-title { font-family: var(--playfair); font-size: 12px; font-style: italic; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-work-meta { font-family: var(--prata); font-size: 10px; color: var(--text3); }
  .col-empty { padding: 32px; text-align: center; font-family: var(--prata); font-size: 12px; color: var(--text3); }
  .col-hidden { display: none; }
  .col-alpha-bar { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 16px; }
  .col-alpha { font-family: var(--prata); font-size: 10px; letter-spacing: 0.08em; padding: 4px 8px; background: transparent; border: 1px solid var(--border); color: var(--text3); cursor: pointer; transition: all .15s; border-radius: var(--radius); min-width: 28px; text-align: center; }
  .col-alpha:hover { border-color: var(--t1); color: var(--t1); }
  .col-alpha.active { background: var(--tglow); border-color: var(--t1); color: var(--t1); }
</style>

<!-- HERO -->
<div class="col-hero">
  {heroImage && <div class="col-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="col-hero-overlay"></div>
  <div class="col-hero-content">
    <div class="col-hero-eyebrow">Museum Collection</div>
    <h1 class="col-hero-title">{heroTitle}</h1>
    <p class="col-hero-sub">{heroSubtitle}</p>
  </div>
</div>

<div id="col-initial-data" data-objects={JSON.stringify(initialObjects || [])} data-count={initialCount} data-sources={JSON.stringify(publicSourceIds)} style="display:none"></div>

<div class="col-body">
  <div class="col-inner">
    <div class="col-stats">
      <div class="col-stat"><div class="col-stat-label">Objects</div><div class="col-stat-value">{stats.objects.toLocaleString()}</div></div>
      <div class="col-stat"><div class="col-stat-label">Artists</div><div class="col-stat-value">{stats.artists.toLocaleString()}</div></div>
      <div class="col-stat"><div class="col-stat-label">With image</div><div class="col-stat-value">{stats.withImage.toLocaleString()}</div></div>
    </div>
    <div class="col-tabs">
      <button class="col-tab active" data-tab="objects">Objects</button>
      <button class="col-tab" data-tab="artists">Artists</button>
    </div>
    <div id="tab-objects">
      <div class="col-controls">
        <input class="col-search" id="obj-search" placeholder="Search title, attribution, medium..." autocomplete="off" />
        {['', 'Painting', 'Sculpture', 'Decorative Art', 'Print', 'Drawing', 'Photograph'].map(c => (
          <button class={`col-pill${c === '' ? ' active' : ''}`} data-cls={c}>{c || 'All'}</button>
        ))}
        <div class="col-count" id="obj-count">Loading…</div>
      </div>
      <div class="col-layout">
        <div class="col-list full" id="obj-list"><div class="col-empty">Loading…</div></div>
        <div class="col-detail col-hidden" id="obj-detail"></div>
      </div>
    </div>
    <div id="tab-artists" class="col-hidden">
      <div class="col-controls">
        <input class="col-search" id="art-search" placeholder="Search artist name, nationality..." autocomplete="off" />
        <div class="col-count" id="art-count"></div>
      </div>
      <div class="col-alpha-bar" id="col-alpha-bar">
        <button class="col-alpha active" data-letter="">All</button>
        {'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map(l => (
          <button class="col-alpha" data-letter={l}>{l}</button>
        ))}
      </div>
      <div class="col-layout">
        <div class="col-list full" id="art-list"><div class="col-empty">Loading…</div></div>
        <div class="col-detail col-hidden" id="art-detail"></div>
      </div>
    </div>
  </div>
</div>

<!-- LIGHTBOX -->
<div id="lb" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(10,8,5,.96);flex-direction:column;align-items:center;justify-content:center;">
  <button id="lb-close" style="position:absolute;top:16px;right:20px;background:none;border:none;color:rgba(245,239,230,.6);font-size:32px;cursor:pointer;line-height:1;z-index:10;">&times;</button>
  <div style="position:relative;flex:1;display:flex;align-items:center;justify-content:center;width:100%;padding:40px;box-sizing:border-box;">
    <button id="lb-prev" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#F5EFE6;font-size:24px;width:48px;height:48px;border-radius:50%;cursor:pointer;z-index:10;">&#8249;</button>
    <img id="lb-img" src="" alt="" style="max-width:90vw;max-height:78vh;object-fit:contain;display:block;border-radius:2px;cursor:zoom-in;transition:transform .3s ease;transform-origin:center;" />
    <button id="lb-next" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#F5EFE6;font-size:24px;width:48px;height:48px;border-radius:50%;cursor:pointer;z-index:10;">&#8250;</button>
  </div>
  <div id="lb-caption" style="font-family:'Prata',Georgia,serif;font-size:13px;font-style:italic;color:rgba(245,239,230,.6);letter-spacing:.04em;padding:8px 40px;text-align:center;min-height:28px;"></div>
  <div id="lb-counter" style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:rgba(245,239,230,.25);letter-spacing:.1em;padding-bottom:12px;text-align:center;"></div>
  <div id="lb-thumbs" style="display:flex;gap:8px;padding:8px 40px 24px;overflow-x:auto;justify-content:center;max-width:100vw;"></div>
</div>

<script is:inline>
(function(){
  var _it=[], _i=0, _zoomed=false;
  window._lbOpen = function(i, items) { _it=items; _i=i; _zoomed=false; render(); document.getElementById('lb').style.display='flex'; document.body.style.overflow='hidden'; };
  function close(){ document.getElementById('lb').style.display='none'; document.body.style.overflow=''; _zoomed=false; document.getElementById('lb-img').style.transform=''; }
  function nav(d){ _i=(_i+d+_it.length)%_it.length; _zoomed=false; document.getElementById('lb-img').style.transform=''; render(); }
  function render(){
    var it=_it[_i], img=document.getElementById('lb-img');
    img.src=it.url; img.alt=it.caption||'';
    document.getElementById('lb-caption').textContent=it.caption||'';
    document.getElementById('lb-counter').textContent=(_i+1)+' / '+_it.length;
    var tb=document.getElementById('lb-thumbs'); tb.innerHTML='';
    _it.forEach(function(t,idx){ var th=document.createElement('img'); th.src=t.url; th.alt=''; th.style.cssText='width:56px;height:42px;object-fit:cover;border-radius:2px;cursor:pointer;opacity:'+(idx===_i?'1':'0.4')+';border:1px solid '+(idx===_i?'#C8A060':'transparent')+';flex-shrink:0;transition:opacity .2s;'; th.setAttribute('data-ti',String(idx)); tb.appendChild(th); });
  }
  document.addEventListener('click',function(e){
    var t=e.target;
    if(t.id==='lb-close'||t.id==='lb'){close();return;}
    if(t.id==='lb-prev'){nav(-1);return;}
    if(t.id==='lb-next'){nav(1);return;}
    if(t.id==='lb-img'){ _zoomed=!_zoomed; t.style.transform=_zoomed?'scale(2)':''; t.style.cursor=_zoomed?'zoom-out':'zoom-in'; return; }
    var ti=t.getAttribute('data-ti');
    if(ti!==null){_i=parseInt(ti,10);_zoomed=false;document.getElementById('lb-img').style.transform='';render();return;}
  });
  document.addEventListener('keydown',function(e){
    if(document.getElementById('lb').style.display==='none') return;
    if(e.key==='ArrowRight') nav(1); if(e.key==='ArrowLeft') nav(-1); if(e.key==='Escape') close();
  });
  var _tx=0;
  document.addEventListener('touchstart',function(e){ if(document.getElementById('lb').style.display!=='none') _tx=e.touches[0].clientX; },{passive:true});
  document.addEventListener('touchend',function(e){ if(document.getElementById('lb').style.display==='none') return; var d=_tx-e.changedTouches[0].clientX; if(Math.abs(d)>50) nav(d>0?1:-1); });
})();
</script>

</PublicShell>

<script>
const searchCache = new Map()
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY
const H = { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` }

const initialEl2 = document.getElementById('col-initial-data')
const publicSourceIds = JSON.parse(initialEl2?.dataset.sources || '[]')
const sourceParam = publicSourceIds.length ? `&sources=ov.{${publicSourceIds.join(',')}}` : ''

let objClass = '', objTimer = null, artTimer = null, selObjId = null, selArtId = null, artLetter = ''

function classColor(c) {
  if (c === 'Painting') return 'blue'
  if (c === 'Sculpture') return 'purple'
  if (c === 'Decorative Art') return 'green'
  if (c === 'Print' || c === 'Drawing') return 'amber'
  return 'gray'
}
function badge(label, color) { return `<span class="col-badge col-badge-${color||'gray'}">${label}</span>` }

// ── TABS ──────────────────────────────────────────────────────
document.querySelectorAll('.col-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.col-tab').forEach(t => t.classList.remove('active'))
    tab.classList.add('active')
    const target = tab.dataset.tab
    document.getElementById('tab-objects').classList.toggle('col-hidden', target !== 'objects')
    document.getElementById('tab-artists').classList.toggle('col-hidden', target !== 'artists')
    if (target === 'artists' && document.getElementById('art-list').querySelector('.col-empty')) fetchArtists('', artLetter)
  })
})

// ── OBJECTS ───────────────────────────────────────────────────
async function fetchObjects(q, cls) {
  const cacheKey = `${q}__${cls}`
  if (searchCache.has(cacheKey)) return searchCache.get(cacheKey)
  const p = new URLSearchParams({
    select: 'gauk_id,title,display_date,attribution,classification,thumb_url,image_url,medium,dimensions,credit_line,provenance,slug,external_ids,properties',
    limit: '50', order: 'date_from.asc.nullslast'
  })
  p.append('image_url', 'not.is.null')
  if (cls) p.append('classification', `eq.${cls}`)
  if (q) p.append('title', `ilike.*${q}*`)
  const res = await fetch(`${SUPA_URL}/rest/v1/gauk_objects?${p}${sourceParam}`, { headers: { ...H, Prefer: 'count=exact' } })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  const result = { data: Array.isArray(data) ? data : [], total }
  if (searchCache.size >= 20) searchCache.delete(searchCache.keys().next().value)
  searchCache.set(cacheKey, result)
  return result
}

async function fetchArtistForObject(gauk_id) {
  const relRes = await fetch(
    `${SUPA_URL}/rest/v1/gauk_entity_relations?from_gauk_id=eq.${gauk_id}&relation_type=eq.made_by&select=to_gauk_id&limit=1`,
    { headers: H }
  )
  const rels = await relRes.json()
  if (!rels.length) return null
  const artRes = await fetch(
    `${SUPA_URL}/rest/v1/gauk_artists?gauk_id=eq.${rels[0].to_gauk_id}&select=gauk_id,preferred_name,nationality,birth_year,death_year,portrait_url,slug`,
    { headers: H }
  )
  const artists = await artRes.json()
  return artists[0] || null
}

async function fetchArtistWorks(gauk_id) {
  const relRes = await fetch(
    `${SUPA_URL}/rest/v1/gauk_entity_relations?to_gauk_id=eq.${gauk_id}&relation_type=eq.made_by&select=from_gauk_id&limit=24`,
    { headers: H }
  )
  const rels = await relRes.json()
  if (!rels.length) return []
  const ids = rels.map(r => r.from_gauk_id).join(',')
  const res = await fetch(
    `${SUPA_URL}/rest/v1/gauk_objects?gauk_id=in.(${ids})&select=gauk_id,title,display_date,classification,thumb_url,slug&image_url=not.is.null`,
    { headers: H }
  )
  return await res.json()
}

function renderObjList(objects) {
  const list = document.getElementById('obj-list')
  if (!objects.length) { list.innerHTML = '<div class="col-empty">No results</div>'; return }
  list.innerHTML = objects.map(o => `
    <div class="col-row${o.gauk_id === selObjId ? ' selected' : ''}" data-id="${o.gauk_id}" data-obj='${JSON.stringify(o).replace(/'/g,"&#39;")}'>
      <div class="col-thumb">${o.thumb_url ? `<img src="${o.thumb_url}" alt="" loading="lazy"/>` : '<span class="col-thumb-empty">◻</span>'}</div>
      <div style="flex:1;min-width:0">
        <div class="col-row-title">${o.title || 'Untitled'}</div>
        <div class="col-row-attr">${o.attribution || 'Unknown'}${o.display_date ? ' · ' + o.display_date : ''}</div>
        <div style="margin-top:3px">${badge(o.classification, classColor(o.classification))}</div>
      </div>
    </div>`).join('')
  list.querySelectorAll('.col-row').forEach(row => row.addEventListener('click', () => {
    const o = JSON.parse(row.dataset.obj)
    selObjId = o.gauk_id
    list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
    row.classList.add('selected')
    list.classList.replace('full', 'narrow')
    showObjDetail(o)
  }))
}

async function showObjDetail(o) {
  const panel = document.getElementById('obj-detail')
  panel.classList.remove('col-hidden')
  const wikidata_id = o.external_ids?.wikidata
  const accession = o.external_ids?.nga_accession
  panel.innerHTML = `
    <div class="col-detail-header">
      <div class="col-detail-label-sm">Object detail</div>
      <button class="col-close" id="obj-close">✕</button>
    </div>
    ${o.image_url ? `<img class="col-detail-img" src="${o.image_url}" alt="" loading="lazy"/>` : ''}
    <div class="col-detail-title">${o.title || 'Untitled'}</div>
    ${o.attribution ? `<div class="col-detail-attr">${o.attribution}</div>` : ''}
    ${o.display_date ? `<div class="col-detail-date">${o.display_date}</div>` : ''}
    <div style="margin-bottom:16px">${badge(o.classification, classColor(o.classification))}</div>
    <div class="col-field-grid">
      ${accession ? `<div><div class="col-field-label">Accession</div><div class="col-field-val">${accession}</div></div>` : ''}
      ${o.medium ? `<div><div class="col-field-label">Medium</div><div class="col-field-val">${o.medium}</div></div>` : ''}
      ${o.dimensions ? `<div><div class="col-field-label">Dimensions</div><div class="col-field-val">${o.dimensions}</div></div>` : ''}
    </div>
    ${o.credit_line ? `<div class="col-section-label">Credit line</div><div class="col-field-val" style="margin-bottom:8px">${o.credit_line}</div>` : ''}
    ${o.provenance ? `<div class="col-section-label">Provenance</div><div class="col-field-val" style="margin-bottom:8px;font-size:13px;line-height:1.8">${o.provenance.split(';').map(s => s.trim()).filter(Boolean).map(s => `<div style="margin-bottom:8px">${s};</div>`).join('')}</div>` : ''}
    ${wikidata_id ? `<div style="margin-top:8px"><a class="col-wikidata" href="https://www.wikidata.org/wiki/${wikidata_id}" target="_blank" rel="noopener">Wikidata →</a></div>` : ''}
    <div style="margin-top:12px"><a class="col-wikidata" style="display:inline-block;padding:7px 14px;border:1px solid rgba(200,160,96,.4);border-radius:4px;" href="/collection/${o.slug}">View Object →</a></div>
    <div id="obj-artist" style="margin-top:16px"><div class="col-section-label">Loading artist…</div></div>`

  document.getElementById('obj-close').addEventListener('click', () => {
    panel.classList.add('col-hidden'); selObjId = null
    const list = document.getElementById('obj-list')
    list.classList.replace('narrow', 'full')
    list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
  })

  const artist = await fetchArtistForObject(o.gauk_id)
  const artDiv = document.getElementById('obj-artist')
  if (!artDiv) return
  if (artist) {
    const dateRange = [artist.birth_year, artist.death_year].filter(Boolean).join('–')
    artDiv.innerHTML = `
      <div class="col-section-label">Artist</div>
      <div class="col-work-row" style="cursor:pointer" onclick="window.location='/artists/${artist.slug}'">
        <div style="width:36px;height:36px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--tglow);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--playfair);font-style:italic;font-size:15px;color:var(--t1)">
          ${artist.portrait_url ? `<img src="${artist.portrait_url}" style="width:100%;height:100%;object-fit:cover;" loading="lazy"/>` : artist.preferred_name.charAt(0)}
        </div>
        <div style="flex:1;min-width:0">
          <div class="col-work-title">${artist.preferred_name}</div>
          <div class="col-work-meta">${[artist.nationality, dateRange].filter(Boolean).join(' · ')}</div>
        </div>
      </div>`
  } else {
    artDiv.innerHTML = ''
  }
}

async function refreshObjs() {
  const q = document.getElementById('obj-search').value.trim()
  document.getElementById('obj-count').textContent = 'Searching…'
  const { data, total } = await fetchObjects(q, objClass)
  document.getElementById('obj-count').textContent = `${parseInt(total).toLocaleString()} objects`
  renderObjList(data)
}

document.getElementById('obj-search').addEventListener('input', () => { clearTimeout(objTimer); objTimer = setTimeout(refreshObjs, 350) })
document.querySelectorAll('.col-pill').forEach(p => p.addEventListener('click', () => {
  document.querySelectorAll('.col-pill').forEach(x => x.classList.remove('active'))
  p.classList.add('active'); objClass = p.dataset.cls; refreshObjs()
}))

// ── ARTISTS ───────────────────────────────────────────────────
async function fetchArtists(q, letter = '') {
  const p = new URLSearchParams({
    select: 'gauk_id,preferred_name,nationality,birth_year,death_year,portrait_url,signature_url,slug,external_ids',
    limit: '50', order: 'preferred_name.asc'
  })
  if (q) p.append('preferred_name', `ilike.*${q}*`)
  if (letter) p.append('preferred_name', `ilike.${letter}*`)
  const res = await fetch(`${SUPA_URL}/rest/v1/gauk_artists?${p}${sourceParam}`, { headers: { ...H, Prefer: 'count=exact' } })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  document.getElementById('art-count').textContent = `${parseInt(total).toLocaleString()} artists`
  renderArtistList(Array.isArray(data) ? data : [])
}

function renderArtistList(artists) {
  const list = document.getElementById('art-list')
  if (!artists.length) { list.innerHTML = '<div class="col-empty">No results</div>'; return }
  list.innerHTML = artists.map(a => `
    <div class="col-artist-row${a.gauk_id === selArtId ? ' selected' : ''}" data-id="${a.gauk_id}" data-art='${JSON.stringify(a).replace(/'/g,"&#39;")}'>
      <div class="col-avatar">${a.portrait_url ? `<img src="${a.portrait_url}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" loading="lazy"/>` : a.preferred_name.charAt(0)}</div>
      <div style="flex:1;min-width:0">
        <div class="col-artist-name">${a.preferred_name}</div>
        <div class="col-artist-meta">${[a.nationality, [a.birth_year, a.death_year].filter(Boolean).join('–')].filter(Boolean).join(' · ')}</div>
      </div>
    </div>`).join('')
  list.querySelectorAll('.col-artist-row').forEach(row => row.addEventListener('click', () => {
    const a = JSON.parse(row.dataset.art)
    selArtId = a.gauk_id
    list.querySelectorAll('.col-artist-row').forEach(r => r.classList.remove('selected'))
    row.classList.add('selected')
    list.classList.replace('full', 'narrow')
    showArtistDetail(a)
  }))
}

async function showArtistDetail(a) {
  const panel = document.getElementById('art-detail')
  panel.classList.remove('col-hidden')
  const dateRange = [a.birth_year, a.death_year].filter(Boolean).join('–')
  const wikidata_id = a.external_ids?.wikidata
  panel.innerHTML = `
    <div class="col-detail-header">
      <div class="col-detail-label-sm">Artist</div>
      <button class="col-close" id="art-close">✕</button>
    </div>
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px">
      <div class="col-avatar" style="width:52px;height:52px;font-size:20px;flex-shrink:0;overflow:hidden;">
        ${a.portrait_url ? `<img src="${a.portrait_url}" alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" loading="lazy"/>` : a.preferred_name.charAt(0)}
      </div>
      <div>
        <div style="font-family:'Playfair Display',Didot,Georgia,serif;font-size:16px;font-style:italic;color:#EFE7D9">${a.preferred_name}</div>
        <div style="font-family:'Prata',Georgia,serif;font-size:11px;color:rgba(239,231,217,.4);margin-top:3px">${[a.nationality, dateRange].filter(Boolean).join(' · ')}</div>
      </div>
    </div>
    ${a.signature_url ? `<div style="margin-bottom:16px;padding:10px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);text-align:center"><div class="col-field-label" style="margin-bottom:6px">Signature</div><img src="${a.signature_url}" alt="signature" style="max-height:40px;max-width:100%;object-fit:contain;filter:invert(1) opacity(.7);" loading="lazy"/></div>` : ''}
    ${wikidata_id ? `<div style="margin-bottom:12px"><a class="col-wikidata" href="https://www.wikidata.org/wiki/${wikidata_id}" target="_blank" rel="noopener">Wikidata →</a></div>` : ''}
    <div style="margin-bottom:16px"><a class="col-wikidata" style="display:inline-block;padding:7px 14px;border:1px solid rgba(200,160,96,.4);border-radius:4px;" href="/artists/${a.slug}">View Full Profile →</a></div>
    <div id="art-works"><div class="col-section-label">Loading works…</div></div>`

  document.getElementById('art-close').addEventListener('click', () => {
    panel.classList.add('col-hidden'); selArtId = null
    const list = document.getElementById('art-list')
    list.classList.replace('narrow', 'full')
    list.querySelectorAll('.col-artist-row').forEach(r => r.classList.remove('selected'))
  })

  const works = await fetchArtistWorks(a.gauk_id)
  const worksDiv = document.getElementById('art-works')
  if (!worksDiv) return
  if (works.length) {
    worksDiv.innerHTML = `
      <div class="col-section-label">Works in collection (${works.length})</div>
      ${works.map(w => `
        <div class="col-work-row" onclick="window.location='/collection/${w.slug || w.gauk_id}'">
          ${w.thumb_url ? `<img class="col-work-thumb" src="${w.thumb_url}" alt="" loading="lazy"/>` : ''}
          <div style="flex:1;min-width:0">
            <div class="col-work-title">${w.title || 'Untitled'}</div>
            <div class="col-work-meta">${[w.display_date, w.classification].filter(Boolean).join(' · ')}</div>
          </div>
        </div>`).join('')}`
  } else {
    worksDiv.innerHTML = '<div class="col-section-label">No works with images in collection</div>'
  }
}

document.getElementById('art-search').addEventListener('input', e => {
  clearTimeout(artTimer); artTimer = setTimeout(() => fetchArtists(e.target.value.trim(), artLetter), 350)
})

document.querySelectorAll('.col-alpha').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.col-alpha').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    artLetter = btn.dataset.letter
    fetchArtists(document.getElementById('art-search').value.trim(), artLetter)
  })
})

// ── INIT ──────────────────────────────────────────────────────
const initialEl = document.getElementById('col-initial-data')
if (initialEl) {
  const preloaded = JSON.parse(initialEl.dataset.objects || '[]')
  const preloadedCount = parseInt(initialEl.dataset.count || '0')
  if (preloaded.length) {
    searchCache.set('__', { data: preloaded, total: String(preloadedCount) })
    document.getElementById('obj-count').textContent = `${preloadedCount.toLocaleString()} objects with images`
    renderObjList(preloaded)
  } else {
    refreshObjs()
  }
} else {
  refreshObjs()
}
</script>
