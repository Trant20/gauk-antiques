---
import PublicShell from '../../layouts/PublicShell.astro'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

const { data: heroSetting } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', SITE_ID)
  .eq('key', 'category_hero_collections')
  .single()

const heroImage = heroSetting?.value || ''
const heroTitle = 'The Museum Collection'
const heroSubtitle = 'Search 116,000 works from the National Gallery of Art — paintings, sculpture, decorative arts and more. CC0 open data.'
---
<PublicShell title="Museum Collection — GAUK Antiques" description={heroSubtitle} ogImage={heroImage}>
<style>
  /* HERO */
  .col-hero {
    position: relative; min-height: 60vh;
    display: flex; align-items: flex-end;
    overflow: hidden; background: #1C1810;
  }
  .col-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .col-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.95) 0%, rgba(13,8,4,.5) 50%, rgba(13,8,4,.2) 100%); }
  .col-hero-content { position: relative; z-index: 2; width: 100%; max-width: 800px; margin: 0 auto; padding: 60px 40px; text-align: center; }
  .col-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: #C8A060; margin-bottom: 16px; }
  .col-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(36px,7vw,72px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.1; margin-bottom: 16px; }
  .col-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 17px; color: rgba(239,231,217,.65); line-height: 1.8; max-width: 560px; margin: 0 auto; }

  /* BODY */
  .col-body { background: #EFE7D9; }

  /* SEARCH SECTION */
  .col-section { max-width: 1100px; margin: 0 auto; padding: 64px 32px; }
  .col-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .col-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .col-heading { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(22px,4vw,36px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 8px; }
  .col-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: #8A7A66; line-height: 1.8; margin-bottom: 28px; max-width: 600px; }

  /* CONTROLS */
  .col-controls { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
  .col-search { flex: 1; min-width: 200px; padding: 10px 16px; background: #fff; border: 1px solid #C4B49E; color: #1C1810; font-family: 'Prata', Georgia, serif; font-size: 14px; outline: none; }
  .col-search::placeholder { color: #C4B49E; }
  .col-pill { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; padding: 7px 14px; background: transparent; border: 1px solid #C4B49E; color: #8A7A66; cursor: pointer; transition: all .15s; }
  .col-pill.active { border-color: #7A5C20; color: #7A5C20; background: rgba(122,92,32,.06); }
  .col-count { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; color: #8A7A66; margin-left: auto; }

  /* LIST + DETAIL */
  .col-layout { display: flex; gap: 16px; align-items: flex-start; }
  .col-list { flex-shrink: 0; border: 1px solid #C4B49E; overflow: hidden; background: #fff; }
  .col-list.narrow { width: 300px; }
  .col-list.full { width: 100%; }
  .col-row { padding: 12px 14px; border-bottom: 1px solid #EFE7D9; cursor: pointer; display: flex; gap: 12px; align-items: flex-start; transition: background .15s; }
  .col-row:hover { background: #FAF6EF; }
  .col-row.selected { background: #F5EDD9; border-left: 2px solid #7A5C20; }
  .col-thumb { width: 48px; height: 48px; flex-shrink: 0; background: #EFE7D9; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .col-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .col-thumb-empty { font-size: 20px; color: #C4B49E; }
  .col-row-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #1C1810; line-height: 1.3; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-row-attr { font-family: 'Prata', Georgia, serif; font-size: 10px; color: #8A7A66; letter-spacing: 1px; }
  .col-row-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 2px 6px; border: 1px solid #C4B49E; color: #7A5C20; margin-top: 4px; }

  /* DETAIL PANEL */
  .col-detail { flex: 1; border: 1px solid #C4B49E; background: #fff; padding: 24px; position: sticky; top: 80px; max-height: calc(100vh - 100px); overflow-y: auto; }
  .col-detail-img { width: 100%; max-height: 280px; object-fit: contain; background: #EFE7D9; margin-bottom: 20px; }
  .col-detail-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 20px; font-style: italic; color: #1C1810; margin-bottom: 6px; line-height: 1.3; }
  .col-detail-attr { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #7A5C20; margin-bottom: 4px; }
  .col-detail-date { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #8A7A66; letter-spacing: 2px; margin-bottom: 16px; }
  .col-detail-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 3px 8px; border: 1px solid #C4B49E; color: #7A5C20; margin-right: 6px; margin-bottom: 12px; }
  .col-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .col-detail-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #8A7A66; margin-bottom: 3px; }
  .col-detail-val { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #1C1810; line-height: 1.5; }
  .col-detail-section { margin-top: 16px; border-top: 1px solid #EFE7D9; padding-top: 14px; }
  .col-detail-section-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #7A5C20; margin-bottom: 10px; }
  .col-detail-text { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #5C5040; line-height: 1.8; padding: 10px 12px; border: 1px solid #EFE7D9; margin-bottom: 6px; background: #FAF6EF; }
  .col-detail-term { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 1px; padding: 3px 8px; border: 1px solid #C4B49E; color: #5C5040; margin: 2px; }
  .col-empty { padding: 48px; text-align: center; font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; }
  .col-close { float: right; background: none; border: none; color: #8A7A66; font-size: 18px; cursor: pointer; }
  .col-wikidata { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #7A5C20; letter-spacing: 1px; text-decoration: none; }
  .col-wikidata:hover { color: #5C4018; }
</style>

<!-- HERO -->
<div class="col-hero">
  {heroImage && <div class="col-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="col-hero-overlay"></div>
  <div class="col-hero-content">
    <div class="col-hero-eyebrow">Museum Collection</div>
    <h1 class="col-hero-title">{heroTitle}</h1>
    <p class="col-hero-sub">{heroSubtitle}</p>
  </div>
</div>

<!-- BODY -->
<div class="col-body">
  <div class="col-section">
    <div class="col-cap">National Gallery of Art</div>
    <h2 class="col-heading">Search the collection</h2>
    <p class="col-sub">116,000 works in public domain. Filter by classification or search by title, artist or medium.</p>

    <div class="col-controls">
      <input class="col-search" id="col-search" placeholder="Search title, artist, medium..." autocomplete="off" />
      <button class="col-pill active" data-cls="">All</button>
      <button class="col-pill" data-cls="Painting">Painting</button>
      <button class="col-pill" data-cls="Sculpture">Sculpture</button>
      <button class="col-pill" data-cls="Decorative Art">Decorative Art</button>
      <button class="col-pill" data-cls="Print">Print</button>
      <button class="col-pill" data-cls="Drawing">Drawing</button>
      <span class="col-count" id="col-count">Loading…</span>
    </div>

    <div class="col-layout">
      <div class="col-list full" id="col-list">
        <div class="col-empty">Loading collection…</div>
      </div>
      <div class="col-detail" id="col-detail" style="display:none"></div>
    </div>
  </div>
</div>
</PublicShell>

<script>
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY

let currentClass = ''
let searchTimer = null
let selectedId = null

function iiifMedium(url) {
  if (!url) return null
  return url.replace(/\/full\/![^/]+\//, '/full/!600,600/')
}

async function fetchObjects(q, cls) {
  const params = new URLSearchParams({
    select: 'object_id,title,display_date,attribution,classification,subclassification,nga_thumb_url,medium,accession_num,dimensions,credit_line,on_view,wikidata_id',
    limit: 50,
    order: 'begin_year.asc.nullslast'
  })
  if (cls) params.append('classification', `eq.${cls}`)
  if (q) params.append('fts', `search_vector.${q}`)

  const res = await fetch(`${SUPA_URL}/rest/v1/nga_objects?${params}`, {
    headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}`, Prefer: 'count=exact' }
  })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  return { data: Array.isArray(data) ? data : [], total }
}

async function fetchDetail(id) {
  const headers = { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` }
  const [terms, texts, historical] = await Promise.all([
    fetch(`${SUPA_URL}/rest/v1/nga_object_terms?object_id=eq.${id}&select=term_type,term`, { headers }).then(r => r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_object_texts?object_id=eq.${id}&select=text_type,text,year`, { headers }).then(r => r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_object_historical?object_id=eq.${id}&select=data_type,forward_text,effective_date,remarks&order=display_order.asc`, { headers }).then(r => r.json()),
  ])
  return { terms, texts, historical }
}

function renderList(objects) {
  const list = document.getElementById('col-list')
  if (!objects.length) { list.innerHTML = '<div class="col-empty">No results found</div>'; return }
  list.innerHTML = objects.map(obj => `
    <div class="col-row${obj.object_id === selectedId ? ' selected' : ''}" data-id="${obj.object_id}" data-obj='${JSON.stringify(obj).replace(/'/g, '\u0027')}'>
      <div class="col-thumb">
        ${obj.nga_thumb_url ? `<img src="${obj.nga_thumb_url}" alt="" loading="lazy" />` : '<span class="col-thumb-empty">◻</span>'}
      </div>
      <div style="flex:1;min-width:0">
        <div class="col-row-title">${obj.title || 'Untitled'}</div>
        <div class="col-row-attr">${obj.attribution || 'Unknown'}${obj.display_date ? ' · ' + obj.display_date : ''}</div>
        <span class="col-row-badge">${obj.classification || ''}</span>
      </div>
    </div>
  `).join('')

  list.querySelectorAll('.col-row').forEach(row => {
    row.addEventListener('click', () => {
      const obj = JSON.parse(row.dataset.obj)
      selectedId = obj.object_id
      list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
      row.classList.add('selected')
      list.classList.remove('full')
      list.classList.add('narrow')
      showDetail(obj)
    })
  })
}

async function showDetail(obj) {
  const panel = document.getElementById('col-detail')
  panel.style.display = 'block'
  panel.innerHTML = `
    <button class="col-close" id="col-close">✕</button>
    ${obj.nga_thumb_url ? `<img class="col-detail-img" src="${iiifMedium(obj.nga_thumb_url)}" alt="${(obj.title||'').replace(/"/g,'&quot;')}" />` : ''}
    <div class="col-detail-title">${obj.title || 'Untitled'}</div>
    ${obj.attribution ? `<div class="col-detail-attr">${obj.attribution}</div>` : ''}
    ${obj.display_date ? `<div class="col-detail-date">${obj.display_date}</div>` : ''}
    <div>
      <span class="col-detail-badge">${obj.classification || ''}</span>
      ${obj.subclassification ? `<span class="col-detail-badge">${obj.subclassification}</span>` : ''}
      ${obj.on_view ? '<span class="col-detail-badge">On view</span>' : ''}
    </div>
    <div class="col-detail-grid" style="margin-top:16px">
      ${obj.accession_num ? `<div><div class="col-detail-label">Accession</div><div class="col-detail-val">${obj.accession_num}</div></div>` : ''}
      ${obj.medium ? `<div><div class="col-detail-label">Medium</div><div class="col-detail-val">${obj.medium}</div></div>` : ''}
      ${obj.dimensions ? `<div><div class="col-detail-label">Dimensions</div><div class="col-detail-val">${obj.dimensions}</div></div>` : ''}
      ${obj.credit_line ? `<div><div class="col-detail-label">Credit line</div><div class="col-detail-val">${obj.credit_line}</div></div>` : ''}
    </div>
    ${obj.wikidata_id ? `<a class="col-wikidata" href="https://www.wikidata.org/wiki/${obj.wikidata_id}" target="_blank" rel="noopener">Wikidata →</a>` : ''}
    <div id="col-detail-extra"><div class="col-detail-text" style="margin-top:12px;color:#C4B49E">Loading detail…</div></div>
  `

  document.getElementById('col-close')?.addEventListener('click', () => {
    panel.style.display = 'none'
    selectedId = null
    const list = document.getElementById('col-list')
    list.classList.remove('narrow')
    list.classList.add('full')
    list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
  })

  const { terms, texts, historical } = await fetchDetail(obj.object_id)
  const extra = document.getElementById('col-detail-extra')
  if (!extra) return
  let html = ''

  if (terms.length) {
    const grouped = terms.reduce((acc, t) => { (acc[t.term_type] = acc[t.term_type] || []).push(t.term); return acc }, {})
    html += Object.entries(grouped).map(([type, ts]) => `
      <div class="col-detail-section">
        <div class="col-detail-section-label">${type}</div>
        <div>${ts.map(t => `<span class="col-detail-term">${t}</span>`).join('')}</div>
      </div>
    `).join('')
  }

  if (historical.length) {
    html += `<div class="col-detail-section"><div class="col-detail-section-label">Attribution history</div>`
    html += historical.map(h => `<div class="col-detail-text">${h.forward_text}${h.effective_date ? ' <span style="color:#8A7A66"> · ' + h.effective_date + '</span>' : ''}</div>`).join('')
    html += '</div>'
  }

  if (texts.length) {
    const grouped = texts.reduce((acc, t) => { (acc[t.text_type] = acc[t.text_type] || []).push(t); return acc }, {})
    html += Object.entries(grouped).map(([type, entries]) => `
      <div class="col-detail-section">
        <div class="col-detail-section-label">${type.replace(/_/g,' ')}</div>
        ${entries.slice(0,3).map(e => `<div class="col-detail-text">${e.year ? '<span style="color:#8A7A66;margin-right:6px">' + e.year + '</span>' : ''}${e.text}</div>`).join('')}
      </div>
    `).join('')
  }

  extra.innerHTML = html || ''
}

async function refresh() {
  const q = document.getElementById('col-search').value.trim()
  const countEl = document.getElementById('col-count')
  countEl.textContent = 'Searching…'
  const { data, total } = await fetchObjects(q, currentClass)
  countEl.textContent = `${parseInt(total).toLocaleString()} works`
  renderList(data)
}

document.getElementById('col-search').addEventListener('input', () => {
  clearTimeout(searchTimer)
  searchTimer = setTimeout(refresh, 350)
})

document.querySelectorAll('.col-pill').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.col-pill').forEach(p => p.classList.remove('active'))
    pill.classList.add('active')
    currentClass = pill.dataset.cls
    refresh()
  })
})

refresh()
</script>
