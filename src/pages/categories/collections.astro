---
import PublicShell from '../../layouts/PublicShell.astro'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

const { data: heroSetting } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', SITE_ID)
  .eq('key', 'category_hero_collections')
  .single()

const heroImage = heroSetting?.value || ''
const heroTitle = 'The Museum Collection'
const heroSubtitle = 'Search 116,000 works from the National Gallery of Art — paintings, sculpture, decorative arts and more.'
---
<PublicShell title="Museum Collection — GAUK Antiques" description={heroSubtitle} ogImage={heroImage}>
<style>
  /* HERO */
  .col-hero {
    position: relative; min-height: 55vh;
    display: flex; align-items: flex-end;
    overflow: hidden; background: #1C1810;
  }
  .col-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .col-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.97) 0%, rgba(13,8,4,.55) 55%, rgba(13,8,4,.2) 100%); }
  .col-hero-content { position: relative; z-index: 2; width: 100%; max-width: 800px; margin: 0 auto; padding: 60px 40px; text-align: center; }
  .col-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: #C8A060; margin-bottom: 16px; }
  .col-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(36px,7vw,72px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.1; margin-bottom: 16px; }
  .col-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: rgba(239,231,217,.6); line-height: 1.8; max-width: 560px; margin: 0 auto; }

  /* BODY — full dark */
  .col-body { background: #13100C; min-height: 100vh; }

  /* TABS */
  .col-tabs { background: #1C1810; border-bottom: 1px solid rgba(255,255,255,.07); display: flex; padding: 0 32px; position: sticky; top: 64px; z-index: 50; }
  .col-tab { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: rgba(239,231,217,.4); padding: 16px 20px; border-bottom: 2px solid transparent; cursor: pointer; background: none; border-top: none; border-left: none; border-right: none; transition: all .15s; }
  .col-tab.active { color: #C8A060; border-bottom-color: #C8A060; }

  /* SECTION */
  .col-section { max-width: 1200px; margin: 0 auto; padding: 40px 32px; }

  /* CONTROLS */
  .col-controls { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
  .col-search { flex: 1; min-width: 200px; padding: 10px 16px; background: rgba(239,231,217,.05); border: 1px solid rgba(200,160,96,.2); color: #EFE7D9; font-family: 'Prata', Georgia, serif; font-size: 14px; outline: none; transition: border-color .15s; }
  .col-search:focus { border-color: rgba(200,160,96,.5); }
  .col-search::placeholder { color: rgba(239,231,217,.25); }
  .col-pill { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; padding: 7px 14px; background: transparent; border: 1px solid rgba(200,160,96,.2); color: rgba(239,231,217,.4); cursor: pointer; transition: all .15s; }
  .col-pill.active, .col-pill:hover { border-color: #C8A060; color: #C8A060; background: rgba(200,160,96,.06); }
  .col-count { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; color: rgba(239,231,217,.3); margin-left: auto; }

  /* LAYOUT */
  .col-layout { display: flex; gap: 16px; align-items: flex-start; }

  /* LIST */
  .col-list { flex-shrink: 0; border: 1px solid rgba(255,255,255,.07); overflow: hidden; background: rgba(239,231,217,.02); }
  .col-list.narrow { width: 320px; }
  .col-list.full { width: 100%; }
  .col-row { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,.05); cursor: pointer; display: flex; gap: 12px; align-items: flex-start; transition: background .15s; border-left: 2px solid transparent; }
  .col-row:hover { background: rgba(200,160,96,.04); }
  .col-row.selected { background: rgba(200,160,96,.07); border-left-color: #C8A060; }
  .col-thumb { width: 48px; height: 48px; flex-shrink: 0; background: rgba(255,255,255,.05); overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .col-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .col-thumb-empty { font-size: 20px; color: rgba(255,255,255,.15); }
  .col-row-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #EFE7D9; line-height: 1.3; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-row-attr { font-family: 'Prata', Georgia, serif; font-size: 10px; color: rgba(239,231,217,.35); letter-spacing: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-row-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 2px 6px; border: 1px solid rgba(200,160,96,.25); color: #C8A060; margin-top: 4px; }
  .col-empty { padding: 48px; text-align: center; font-family: 'Prata', Georgia, serif; font-size: 13px; color: rgba(239,231,217,.25); }

  /* DETAIL PANEL */
  .col-detail { flex: 1; border: 1px solid rgba(200,160,96,.15); background: rgba(239,231,217,.03); padding: 24px; position: sticky; top: 120px; max-height: calc(100vh - 140px); overflow-y: auto; }
  .col-detail-img { width: 100%; max-height: 300px; object-fit: contain; background: rgba(255,255,255,.03); margin-bottom: 20px; }
  .col-detail-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 20px; font-style: italic; color: #EFE7D9; margin-bottom: 6px; line-height: 1.3; }
  .col-detail-attr { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #C8A060; margin-bottom: 4px; }
  .col-detail-date { font-family: 'Prata', Georgia, serif; font-size: 11px; color: rgba(239,231,217,.35); letter-spacing: 2px; margin-bottom: 16px; }
  .col-detail-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 3px 8px; border: 1px solid rgba(200,160,96,.25); color: #C8A060; margin-right: 6px; margin-bottom: 12px; }
  .col-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .col-detail-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(239,231,217,.3); margin-bottom: 3px; }
  .col-detail-val { font-family: 'Prata', Georgia, serif; font-size: 12px; color: rgba(239,231,217,.65); line-height: 1.5; }
  .col-section-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #C8A060; margin-bottom: 10px; margin-top: 16px; border-top: 1px solid rgba(255,255,255,.06); padding-top: 14px; }
  .col-detail-text { font-family: 'Prata', Georgia, serif; font-size: 11px; color: rgba(239,231,217,.5); line-height: 1.8; padding: 10px 12px; border: 1px solid rgba(255,255,255,.05); margin-bottom: 6px; background: rgba(239,231,217,.02); }
  .col-detail-term { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 1px; padding: 3px 8px; border: 1px solid rgba(255,255,255,.08); color: rgba(239,231,217,.45); margin: 2px; }
  .col-close { float: right; background: none; border: none; color: rgba(239,231,217,.3); font-size: 18px; cursor: pointer; }
  .col-close:hover { color: #EFE7D9; }
  .col-wikidata { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #C8A060; letter-spacing: 1px; text-decoration: none; }

  /* ARTIST LIST */
  .col-artist-row { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,.05); cursor: pointer; display: flex; gap: 12px; align-items: center; transition: background .15s; border-left: 2px solid transparent; }
  .col-artist-row:hover { background: rgba(200,160,96,.04); }
  .col-artist-row.selected { background: rgba(200,160,96,.07); border-left-color: #C8A060; }
  .col-artist-avatar { width: 36px; height: 36px; border-radius: 50%; background: rgba(200,160,96,.1); border: 1px solid rgba(200,160,96,.2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #C8A060; }
  .col-artist-name { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #EFE7D9; margin-bottom: 2px; }
  .col-artist-meta { font-family: 'Prata', Georgia, serif; font-size: 10px; color: rgba(239,231,217,.35); letter-spacing: 1px; }

  /* ARTIST WORKS */
  .col-work-row { display: flex; gap: 10px; align-items: center; padding: 8px; border: 1px solid rgba(255,255,255,.05); margin-bottom: 6px; background: rgba(239,231,217,.02); }
  .col-work-thumb { width: 36px; height: 36px; flex-shrink: 0; object-fit: cover; }
  .col-work-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 12px; font-style: italic; color: #EFE7D9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-work-meta { font-family: 'Prata', Georgia, serif; font-size: 10px; color: rgba(239,231,217,.35); }

  .col-hidden { display: none; }
</style>

<!-- HERO -->
<div class="col-hero">
  {heroImage && <div class="col-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="col-hero-overlay"></div>
  <div class="col-hero-content">
    <div class="col-hero-eyebrow">Museum Collection</div>
    <h1 class="col-hero-title">{heroTitle}</h1>
    <p class="col-hero-sub">{heroSubtitle}</p>
  </div>
</div>

<div class="col-body">
  <!-- TABS -->
  <div class="col-tabs">
    <button class="col-tab active" data-tab="objects">Objects</button>
    <button class="col-tab" data-tab="artists">Artists</button>
  </div>

  <!-- OBJECTS -->
  <div class="col-section" id="tab-objects">
    <div class="col-controls">
      <input class="col-search" id="obj-search" placeholder="Search title, artist, medium..." autocomplete="off" />
      <button class="col-pill active" data-cls="">All</button>
      <button class="col-pill" data-cls="Painting">Painting</button>
      <button class="col-pill" data-cls="Sculpture">Sculpture</button>
      <button class="col-pill" data-cls="Decorative Art">Decorative Art</button>
      <button class="col-pill" data-cls="Print">Print</button>
      <button class="col-pill" data-cls="Drawing">Drawing</button>
      <span class="col-count" id="obj-count">Loading…</span>
    </div>
    <div class="col-layout">
      <div class="col-list full" id="obj-list"><div class="col-empty">Loading…</div></div>
      <div class="col-detail col-hidden" id="obj-detail"></div>
    </div>
  </div>

  <!-- ARTISTS -->
  <div class="col-section col-hidden" id="tab-artists">
    <div class="col-controls">
      <input class="col-search" id="art-search" placeholder="Search artist name, nationality..." autocomplete="off" />
      <span class="col-count" id="art-count"></span>
    </div>
    <div class="col-layout">
      <div class="col-list full" id="art-list"><div class="col-empty">Loading…</div></div>
      <div class="col-detail col-hidden" id="art-detail"></div>
    </div>
  </div>
</div>
</PublicShell>

<script>
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY
const H = { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` }

let objClass = '', objTimer = null, artTimer = null
let selObjId = null, selArtId = null

function iiif(url) {
  return url ? url.replace(/\/full\/![^/]+\//, '/full/!600,600/') : null
}

// ── TABS ──────────────────────────────────────────────────────
document.querySelectorAll('.col-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.col-tab').forEach(t => t.classList.remove('active'))
    tab.classList.add('active')
    const target = tab.dataset.tab
    document.getElementById('tab-objects').classList.toggle('col-hidden', target !== 'objects')
    document.getElementById('tab-artists').classList.toggle('col-hidden', target !== 'artists')
    if (target === 'artists' && document.getElementById('art-list').querySelector('.col-empty')) {
      fetchArtists('')
    }
  })
})

// ── OBJECTS ───────────────────────────────────────────────────
async function fetchObjects(q, cls) {
  const p = new URLSearchParams({
    select: 'object_id,title,display_date,attribution,classification,subclassification,nga_thumb_url,medium,accession_num,dimensions,credit_line,on_view,wikidata_id,department_abbr',
    limit: '50', order: 'begin_year.asc.nullslast'
  })
  if (cls) p.append('classification', `eq.${cls}`)
  if (q) p.append('search_vector', `fts.${encodeURIComponent(q)}`)
  const res = await fetch(`${SUPA_URL}/rest/v1/nga_objects?${p}`, { headers: { ...H, Prefer: 'count=exact' } })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  return { data: Array.isArray(data) ? data : [], total }
}

async function fetchObjDetail(id) {
  const [terms, texts, hist] = await Promise.all([
    fetch(`${SUPA_URL}/rest/v1/nga_object_terms?object_id=eq.${id}&select=term_type,term`, { headers: H }).then(r => r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_object_texts?object_id=eq.${id}&select=text_type,text,year`, { headers: H }).then(r => r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_object_historical?object_id=eq.${id}&select=forward_text,effective_date&order=display_order.asc`, { headers: H }).then(r => r.json()),
  ])
  return { terms, texts, hist }
}

function renderObjList(objects) {
  const list = document.getElementById('obj-list')
  if (!objects.length) { list.innerHTML = '<div class="col-empty">No results found</div>'; return }
  list.innerHTML = objects.map(o => `
    <div class="col-row${o.object_id === selObjId ? ' selected' : ''}" data-id="${o.object_id}" data-obj='${JSON.stringify(o).replace(/'/g,'\u0027')}'>
      <div class="col-thumb">${o.nga_thumb_url ? `<img src="${o.nga_thumb_url}" alt="" loading="lazy"/>` : '<span class="col-thumb-empty">◻</span>'}</div>
      <div style="flex:1;min-width:0">
        <div class="col-row-title">${o.title||'Untitled'}</div>
        <div class="col-row-attr">${o.attribution||'Unknown'}${o.display_date?' · '+o.display_date:''}</div>
        <span class="col-row-badge">${o.classification||''}</span>
      </div>
    </div>`).join('')
  list.querySelectorAll('.col-row').forEach(row => row.addEventListener('click', () => {
    const o = JSON.parse(row.dataset.obj)
    selObjId = o.object_id
    list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
    row.classList.add('selected')
    list.classList.replace('full','narrow')
    showObjDetail(o)
  }))
}

async function showObjDetail(o) {
  const panel = document.getElementById('obj-detail')
  panel.classList.remove('col-hidden')
  panel.innerHTML = `
    <button class="col-close" id="obj-close">✕</button>
    ${o.nga_thumb_url ? `<img class="col-detail-img" src="${iiif(o.nga_thumb_url)}" alt=""/>` : ''}
    <div class="col-detail-title">${o.title||'Untitled'}</div>
    ${o.attribution?`<div class="col-detail-attr">${o.attribution}</div>`:''}
    ${o.display_date?`<div class="col-detail-date">${o.display_date}</div>`:''}
    <div>
      <span class="col-detail-badge">${o.classification||''}</span>
      ${o.subclassification?`<span class="col-detail-badge">${o.subclassification}</span>`:''}
      ${o.on_view?'<span class="col-detail-badge">On view</span>':''}
    </div>
    <div class="col-detail-grid" style="margin-top:16px">
      ${o.accession_num?`<div><div class="col-detail-label">Accession</div><div class="col-detail-val">${o.accession_num}</div></div>`:''}
      ${o.department_abbr?`<div><div class="col-detail-label">Department</div><div class="col-detail-val">${o.department_abbr}</div></div>`:''}
      ${o.medium?`<div><div class="col-detail-label">Medium</div><div class="col-detail-val">${o.medium}</div></div>`:''}
      ${o.dimensions?`<div><div class="col-detail-label">Dimensions</div><div class="col-detail-val">${o.dimensions}</div></div>`:''}
      ${o.credit_line?`<div style="grid-column:1/-1"><div class="col-detail-label">Credit line</div><div class="col-detail-val">${o.credit_line}</div></div>`:''}
    </div>
    ${o.wikidata_id?`<a class="col-wikidata" href="https://www.wikidata.org/wiki/${o.wikidata_id}" target="_blank" rel="noopener">Wikidata →</a>`:''}
    <div id="obj-extra"><div class="col-detail-text" style="margin-top:12px;color:rgba(239,231,217,.2)">Loading detail…</div></div>`

  document.getElementById('obj-close').addEventListener('click', () => {
    panel.classList.add('col-hidden')
    selObjId = null
    const list = document.getElementById('obj-list')
    list.classList.replace('narrow','full')
    list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
  })

  const { terms, texts, hist } = await fetchObjDetail(o.object_id)
  const extra = document.getElementById('obj-extra')
  if (!extra) return
  let html = ''
  if (terms.length) {
    const g = terms.reduce((a,t)=>{(a[t.term_type]=a[t.term_type]||[]).push(t.term);return a},{})
    html += Object.entries(g).map(([type,ts])=>`<div class="col-section-label">${type}</div><div>${ts.map(t=>`<span class="col-detail-term">${t}</span>`).join('')}</div>`).join('')
  }
  if (hist.length) {
    html += `<div class="col-section-label">Attribution history</div>${hist.map(h=>`<div class="col-detail-text">${h.forward_text}${h.effective_date?` <span style="opacity:.5">· ${h.effective_date}</span>`:''}</div>`).join('')}`
  }
  if (texts.length) {
    const g = texts.reduce((a,t)=>{(a[t.text_type]=a[t.text_type]||[]).push(t);return a},{})
    html += Object.entries(g).map(([type,entries])=>`<div class="col-section-label">${type.replace(/_/g,' ')}</div>${entries.slice(0,3).map(e=>`<div class="col-detail-text">${e.year?`<span style="opacity:.5;margin-right:6px">${e.year}</span>`:''}${e.text}</div>`).join('')}`).join('')
  }
  extra.innerHTML = html || ''
}

async function refreshObjs() {
  const q = document.getElementById('obj-search').value.trim()
  document.getElementById('obj-count').textContent = 'Searching…'
  const { data, total } = await fetchObjects(q, objClass)
  document.getElementById('obj-count').textContent = `${parseInt(total).toLocaleString()} works`
  renderObjList(data)
}

document.getElementById('obj-search').addEventListener('input', () => { clearTimeout(objTimer); objTimer = setTimeout(refreshObjs, 350) })
document.querySelectorAll('.col-pill').forEach(p => p.addEventListener('click', () => {
  document.querySelectorAll('.col-pill').forEach(x => x.classList.remove('active'))
  p.classList.add('active'); objClass = p.dataset.cls; refreshObjs()
}))

// ── ARTISTS ───────────────────────────────────────────────────
async function fetchArtists(q) {
  const p = new URLSearchParams({ select: 'constituent_id,preferred_name,last_name,display_date,nationality,constituent_type,ulan_id,wikidata_id', limit: '50', order: 'last_name.asc.nullslast' })
  if (q) p.append('search_vector', `fts.${encodeURIComponent(q)}`)
  const res = await fetch(`${SUPA_URL}/rest/v1/nga_constituents?${p}`, { headers: { ...H, Prefer: 'count=exact' } })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  document.getElementById('art-count').textContent = `${parseInt(total).toLocaleString()} artists`
  renderArtistList(Array.isArray(data) ? data : [])
}

async function fetchArtistWorks(id) {
  const links = await fetch(`${SUPA_URL}/rest/v1/nga_object_constituents?constituent_id=eq.${id}&select=object_id&limit=12`, { headers: H }).then(r=>r.json())
  if (!links.length) return []
  const ids = links.map(l=>l.object_id).join(',')
  return fetch(`${SUPA_URL}/rest/v1/nga_objects?object_id=in.(${ids})&select=object_id,title,display_date,classification,nga_thumb_url,medium`, { headers: H }).then(r=>r.json())
}

async function fetchArtistDetail(id) {
  const [altnames, texts] = await Promise.all([
    fetch(`${SUPA_URL}/rest/v1/nga_constituent_altnames?constituent_id=eq.${id}&select=display_name,name_type`, { headers: H }).then(r=>r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_constituent_texts?constituent_id=eq.${id}&select=text_type,text,year&order=year.asc`, { headers: H }).then(r=>r.json()),
  ])
  return { altnames, texts }
}

function renderArtistList(artists) {
  const list = document.getElementById('art-list')
  if (!artists.length) { list.innerHTML = '<div class="col-empty">No results found</div>'; return }
  list.innerHTML = artists.map(a => `
    <div class="col-artist-row${a.constituent_id===selArtId?' selected':''}" data-id="${a.constituent_id}" data-art='${JSON.stringify(a).replace(/'/g,'\u0027')}'>
      <div class="col-artist-avatar">${(a.last_name||a.preferred_name||'?').charAt(0)}</div>
      <div style="flex:1;min-width:0">
        <div class="col-artist-name">${a.preferred_name||''}</div>
        <div class="col-artist-meta">${[a.nationality,a.display_date].filter(Boolean).join(' · ')}</div>
      </div>
    </div>`).join('')
  list.querySelectorAll('.col-artist-row').forEach(row => row.addEventListener('click', () => {
    const a = JSON.parse(row.dataset.art)
    selArtId = a.constituent_id
    list.querySelectorAll('.col-artist-row').forEach(r => r.classList.remove('selected'))
    row.classList.add('selected')
    list.classList.replace('full','narrow')
    showArtistDetail(a)
  }))
}

async function showArtistDetail(a) {
  const panel = document.getElementById('art-detail')
  panel.classList.remove('col-hidden')
  panel.innerHTML = `
    <button class="col-close" id="art-close">✕</button>
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px">
      <div class="col-artist-avatar" style="width:52px;height:52px;font-size:20px;flex-shrink:0">${(a.last_name||a.preferred_name||'?').charAt(0)}</div>
      <div>
        <div class="col-detail-title" style="margin-bottom:4px">${a.preferred_name||''}</div>
        <div class="col-detail-date">${[a.nationality,a.display_date].filter(Boolean).join(' · ')}</div>
      </div>
    </div>
    <div class="col-detail-grid">
      ${a.constituent_type?`<div><div class="col-detail-label">Type</div><div class="col-detail-val">${a.constituent_type}</div></div>`:''}
      ${a.ulan_id?`<div><div class="col-detail-label">ULAN ID</div><div class="col-detail-val">${a.ulan_id}</div></div>`:''}
    </div>
    ${a.wikidata_id?`<a class="col-wikidata" href="https://www.wikidata.org/wiki/${a.wikidata_id}" target="_blank" rel="noopener">Wikidata →</a>`:''}
    <div id="art-extra"><div class="col-detail-text" style="margin-top:12px;color:rgba(239,231,217,.2)">Loading…</div></div>`

  document.getElementById('art-close').addEventListener('click', () => {
    panel.classList.add('col-hidden')
    selArtId = null
    const list = document.getElementById('art-list')
    list.classList.replace('narrow','full')
    list.querySelectorAll('.col-artist-row').forEach(r => r.classList.remove('selected'))
  })

  const [detail, works] = await Promise.all([fetchArtistDetail(a.constituent_id), fetchArtistWorks(a.constituent_id)])
  const extra = document.getElementById('art-extra')
  if (!extra) return
  let html = ''

  if (detail.altnames.length) {
    html += `<div class="col-section-label">Also known as</div><div>${detail.altnames.map(n=>`<span class="col-detail-term">${n.display_name} (${n.name_type})</span>`).join('')}</div>`
  }

  if (works.length) {
    html += `<div class="col-section-label">Works in collection</div>${works.map(w=>`
      <div class="col-work-row">
        ${w.nga_thumb_url?`<img class="col-work-thumb" src="${w.nga_thumb_url}" alt="" loading="lazy"/>`:''}
        <div style="flex:1;min-width:0">
          <div class="col-work-title">${w.title||'Untitled'}</div>
          <div class="col-work-meta">${w.display_date||''} · ${w.classification||''}</div>
        </div>
      </div>`).join('')}`
  }

  if (detail.texts.length) {
    html += `<div class="col-section-label">Bibliography (${detail.texts.length})</div><div style="max-height:200px;overflow-y:auto">${detail.texts.slice(0,10).map(t=>`<div class="col-detail-text">${t.year?`<span style="opacity:.5;margin-right:6px">${t.year}</span>`:''}${t.text}</div>`).join('')}</div>`
  }

  extra.innerHTML = html || ''
}

document.getElementById('art-search').addEventListener('input', e => {
  clearTimeout(artTimer); artTimer = setTimeout(() => fetchArtists(e.target.value.trim()), 350)
})

// ── INIT ──────────────────────────────────────────────────────
refreshObjs()
</script>
