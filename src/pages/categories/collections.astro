async function refreshObjs() {
  const q = document.getElementById('obj-search').value.trim()
  document.getElementById('obj-count').textContent = 'Searching…'
  const { data, total } = await fetchObjects(q, objClass)
  document.getElementById('obj-count').textContent = `${parseInt(total).toLocaleString()} objects`
  renderObjList(data)
}

document.getElementById('obj-search').addEventListener('input', () => { clearTimeout(objTimer); objTimer = setTimeout(refreshObjs, 350) })
document.querySelectorAll('.col-pill').forEach(p => p.addEventListener('click', () => {
  document.querySelectorAll('.col-pill').forEach(x => x.classList.remove('active'))
  p.classList.add('active'); objClass = p.dataset.cls; refreshObjs()
}))

// ── ARTISTS ───────────────────────────────────────────────────
async function fetchArtists(q, letter = '') {
  const p = new URLSearchParams({ select: 'constituent_id,preferred_name,forward_name,last_name,display_date,nationality,constituent_type,ulan_id,wikidata_id', limit: '50', order: 'last_name.asc.nullslast' })
  if (q) p.append('search_vector', `fts.${encodeURIComponent(q)}`)
  if (letter) p.append('last_name', `ilike.${letter}*`)
  const res = await fetch(`${SUPA_URL}/rest/v1/nga_constituents?${p}`, { headers: { ...H, Prefer: 'count=exact' } })
  const data = await res.json()
  const total = res.headers.get('content-range')?.split('/')[1] || '?'
  document.getElementById('art-count').textContent = `${parseInt(total).toLocaleString()} artists`
  renderArtistList(Array.isArray(data) ? data : [])
}

async function fetchArtistWorks(id) {
  const links = await fetch(`${SUPA_URL}/rest/v1/nga_object_constituents?constituent_id=eq.${id}&select=object_id&limit=20`, { headers: H }).then(r => r.json())
  if (!links.length) return []
  const ids = links.map(l => l.object_id).join(',')
  return fetch(`${SUPA_URL}/rest/v1/nga_objects?object_id=in.(${ids})&select=object_id,title,display_date,classification,nga_thumb_url,medium`, { headers: H }).then(r => r.json())
}

async function fetchArtistDetail(id) {
  const [altnames, texts] = await Promise.all([
    fetch(`${SUPA_URL}/rest/v1/nga_constituent_altnames?constituent_id=eq.${id}&select=display_name,name_type`, { headers: H }).then(r => r.json()),
    fetch(`${SUPA_URL}/rest/v1/nga_constituent_texts?constituent_id=eq.${id}&select=text_type,text,year&order=year.asc`, { headers: H }).then(r => r.json()),
  ])
  return { altnames, texts }
}

function renderArtistList(artists) {
  const list = document.getElementById('art-list')
  if (!artists.length) { list.innerHTML = '<div class="col-empty">No results</div>'; return }
  list.innerHTML = artists.map(a => `
    <div class="col-artist-row${a.constituent_id===selArtId?' selected':''}" data-id="${a.constituent_id}" data-art='${JSON.stringify(a).replace(/'/g,'\u0027')}'>
