---
import PublicShell from '../../layouts/PublicShell.astro'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
const CATEGORY = 'Pottery'
const R2 = 'https://pub-c3f96dd742f540188b92599aeed807c7.r2.dev'

// Recent identifications for social proof
const { data: recent } = await supabase
  .from('identifications')
  .select('id, image_key, result_json, created_at')
  .eq('site_id', SITE_ID)
  .eq('category', CATEGORY)
  .not('image_key', 'is', null)
  .order('created_at', { ascending: false })
  .limit(6)

// Notable makers
const { data: makerRows } = await supabase
  .from('identifications')
  .select('result_json')
  .eq('site_id', SITE_ID)
  .eq('category', CATEGORY)
  .not('result_json->>maker', 'is', null)

const makerCounts: Record<string, number> = {}
makerRows?.forEach(r => {
  const m = r.result_json?.maker
  if (m) makerCounts[m] = (makerCounts[m] || 0) + 1
})
const makers = Object.entries(makerCounts).sort((a, b) => b[1] - a[1]).slice(0, 6)

// Total count
const { count } = await supabase
  .from('identifications')
  .select('id', { count: 'exact', head: true })
  .eq('site_id', SITE_ID)
  .eq('category', CATEGORY)

// Hero image from site_settings
const { data: settings } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', SITE_ID)
  .eq('key', 'category_hero_pottery')
  .single()

const heroImage = settings?.value || ''
---
<PublicShell title="Pottery & Ceramics — GAUK Antiques">
<style>
  /* HERO */
  .cat-hero {
    position: relative; width: 100%; height: 60vh; min-height: 400px;
    display: flex; align-items: flex-end;
    overflow: hidden;
  }
  .cat-hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    background-color: #2C1810;
  }
  .cat-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(28,24,16,.9) 0%, rgba(28,24,16,.4) 60%, transparent 100%);
  }
  .cat-hero-content {
    position: relative; z-index: 2;
    padding: 40px 40px 48px; width: 100%;
  }
  .cat-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #C8A060; margin-bottom: 10px; }
  .cat-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(36px,6vw,64px); font-weight: 400; color: #EFE7D9; line-height: 1.1; margin-bottom: 10px; }
  .cat-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: rgba(239,231,217,.7); max-width: 500px; line-height: 1.7; }
  .cat-hero-count { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #C8A060; margin-top: 16px; }

  /* SECTIONS */
  .cat-wrap { max-width: 960px; margin: 0 auto; padding: 60px 24px 80px; }
  .cat-section { margin-bottom: 64px; }
  .cat-section-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 6px; display: flex; align-items: center; gap: 12px; }
  .cat-section-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .cat-section-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(22px,4vw,32px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 8px; }
  .cat-section-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: #8A7A66; line-height: 1.8; margin-bottom: 32px; max-width: 640px; }

  /* ID CARDS */
  .id-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 600px) { .id-grid { grid-template-columns: repeat(2, 1fr); } }
  .id-card { background: #EFE7D9; text-decoration: none; color: #1C1810; display: flex; flex-direction: column; transition: background .15s; }
  .id-card:hover { background: #E6DCCB; }
  .id-card-img-wrap { width: 100%; aspect-ratio: 1/1; overflow: hidden; position: relative; background: #E6DCCB; }
  .id-card-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; }
  .id-card-body { padding: 14px; border-top: 1px solid #C4B49E; }
  .id-card-maker { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #7A5C20; margin-bottom: 4px; }
  .id-card-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #1C1810; margin-bottom: 8px; line-height: 1.3; }
  .id-card-value { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 13px; color: #7A5C20; }
  .id-card-meta { font-family: 'Prata', Georgia, serif; font-size: 9px; color: #8A7A66; margin-top: 4px; text-transform: uppercase; letter-spacing: 1px; }

  /* MAKERS */
  .makers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  @media (max-width: 600px) { .makers-grid { grid-template-columns: repeat(2, 1fr); } }
  .maker-card { background: #E6DCCB; border: 1px solid #C4B49E; padding: 20px; text-decoration: none; color: #1C1810; transition: background .15s; }
  .maker-card:hover { background: #DDD0BF; }
  .maker-card-name { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 18px; font-style: italic; color: #1C1810; margin-bottom: 6px; }
  .maker-card-count { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #8A7A66; }

  /* INTRO */
  .cat-intro { font-family: 'Prata', Georgia, serif; font-size: 17px; color: #5C5040; line-height: 1.9; max-width: 720px; }

  /* CTA */
  .cat-cta-block { background: #E6DCCB; border: 1px solid #C4B49E; padding: 40px; text-align: center; margin-top: 64px; }
  .cat-cta-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 26px; font-style: italic; color: #1C1810; margin-bottom: 10px; }
  .cat-cta-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: #8A7A66; margin-bottom: 24px; line-height: 1.7; }
  .cat-cta-btn { display: inline-block; padding: 14px 36px; background: #B8860B; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #fff; text-decoration: none; transition: background .2s; }
  .cat-cta-btn:hover { background: #9A7009; }
</style>

<!-- HERO -->
<div class="cat-hero">
  <div class="cat-hero-bg" style={heroImage ? `background-image:url('${heroImage}')` : 'background-color:#2C1810'}></div>
  <div class="cat-hero-overlay"></div>
  <div class="cat-hero-content">
    <div class="cat-hero-eyebrow">Category</div>
    <h1 class="cat-hero-title">Pottery & Ceramics</h1>
    <p class="cat-hero-sub">From Art Pottery to fine porcelain — one of the most collected and valued categories in the antiques world.</p>
    {count && <div class="cat-hero-count">{count} pieces identified on GAUK Antiques</div>}
  </div>
</div>

<div class="cat-wrap">

  <!-- INTRO -->
  <div class="cat-section">
    <p class="cat-intro">Pottery and ceramics span thousands of years of human craft, from ancient earthenware to the bold geometric designs of the Art Deco period. The category encompasses studio pottery, factory-produced pieces, fine porcelain and everything between. Makers such as Clarice Cliff, Moorcroft, Wedgwood and Royal Doulton have become household names among collectors, while rarer studio pieces command prices that rival fine art.</p>
  </div>

  <!-- RECENT IDENTIFICATIONS -->
  {recent && recent.length > 0 && (
    <div class="cat-section">
      <div class="cat-section-cap">Recently Identified</div>
      <h2 class="cat-section-title">From the collection</h2>
      <p class="cat-section-sub">Real pieces identified by our AI — values are estimates based on current market data.</p>
      <div class="id-grid">
        {recent.map(item => {
          const r = item.result_json || {}
          return (
            <div class="id-card">
              <div class="id-card-img-wrap">
                {item.image_key && <img class="id-card-img" src={`${R2}/${item.image_key}`} alt={r.subcategory} loading="lazy" />}
              </div>
              <div class="id-card-body">
                {r.maker && <div class="id-card-maker">{r.maker}</div>}
                <div class="id-card-title">{r.subcategory || 'Pottery Item'}</div>
                <div class="id-card-value">£{(r.value_range_low || 0).toLocaleString()} – £{(r.value_range_high || 0).toLocaleString()}</div>
                <div class="id-card-meta">{r.condition}</div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )}

  <!-- NOTABLE MAKERS -->
  {makers.length > 0 && (
    <div class="cat-section">
      <div class="cat-section-cap">Notable Makers</div>
      <h2 class="cat-section-title">Potters & Studios</h2>
      <p class="cat-section-sub">The most identified makers in our collection. Click to explore their history, marks and values.</p>
      <div class="makers-grid">
        {makers.map(([maker, count]) => (
          <a href={`/makers/${maker.toLowerCase().replace(/\s+/g, '-')}`} class="maker-card">
            <div class="maker-card-name">{maker}</div>
            <div class="maker-card-count">{count} {count === 1 ? 'piece' : 'pieces'} identified</div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- CTA -->
  <div class="cat-cta-block">
    <div class="cat-cta-title">Have a piece of pottery to identify?</div>
    <div class="cat-cta-sub">Upload a photograph and our AI will identify the maker, period, condition and value in seconds.</div>
    <a href="/" class="cat-cta-btn">Identify Your Piece</a>
  </div>

</div>
</PublicShell>
