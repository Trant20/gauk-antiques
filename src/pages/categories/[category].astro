  .col-thumb { width: 48px; height: 48px; flex-shrink: 0; background: rgba(255,255,255,.05); overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .col-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .col-thumb-empty { font-size: 20px; opacity: .3; }
  .col-row-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 14px; font-style: italic; color: #EFE7D9; line-height: 1.3; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .col-row-attr { font-family: 'Prata', Georgia, serif; font-size: 10px; color: rgba(239,231,217,.4); letter-spacing: 1px; }
  .col-row-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 2px 6px; border: 1px solid rgba(200,160,96,.3); color: #C8A060; margin-top: 4px; }
  .col-detail { flex: 1; border: 1px solid rgba(200,160,96,.2); background: rgba(239,231,217,.03); padding: 24px; position: sticky; top: 80px; max-height: calc(100vh - 100px); overflow-y: auto; }
  .col-detail-img { width: 100%; max-height: 280px; object-fit: contain; background: rgba(255,255,255,.04); margin-bottom: 20px; }
  .col-detail-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 20px; font-style: italic; color: #EFE7D9; margin-bottom: 6px; line-height: 1.3; }
  .col-detail-attr { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #C8A060; margin-bottom: 4px; }
  .col-detail-date { font-family: 'Prata', Georgia, serif; font-size: 11px; color: rgba(239,231,217,.4); letter-spacing: 2px; margin-bottom: 16px; }
  .col-detail-badge { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; padding: 3px 8px; border: 1px solid rgba(200,160,96,.3); color: #C8A060; margin-right: 6px; margin-bottom: 12px; }
  .col-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .col-detail-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(239,231,217,.35); margin-bottom: 3px; }
  .col-detail-val { font-family: 'Prata', Georgia, serif; font-size: 12px; color: rgba(239,231,217,.7); line-height: 1.5; }
  .col-detail-section { margin-top: 16px; border-top: 1px solid rgba(255,255,255,.06); padding-top: 14px; }
  .col-detail-section-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #C8A060; margin-bottom: 10px; }
  .col-detail-text { font-family: 'Prata', Georgia, serif; font-size: 12px; color: rgba(239,231,217,.55); line-height: 1.8; padding: 10px 12px; border: 1px solid rgba(255,255,255,.05); margin-bottom: 6px; }
  .col-detail-term { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 1px; padding: 3px 8px; border: 1px solid rgba(255,255,255,.1); color: rgba(239,231,217,.5); margin: 2px; }
  .col-empty { padding: 48px; text-align: center; font-family: 'Prata', Georgia, serif; font-size: 13px; color: rgba(239,231,217,.3); }
  .col-close { float: right; background: none; border: none; color: rgba(239,231,217,.4); font-size: 18px; cursor: pointer; }
</style>

<!-- HERO -->
<div class="cat-hero">
  {heroImage && <div class="cat-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="cat-hero-overlay"></div>
  <div class="cat-hero-content">
    <div class="cat-hero-eyebrow">Category</div>
    <h1 class="cat-hero-title">{meta.headline}</h1>
    <p class="cat-hero-sub">{meta.sub}</p>
    {count && <div class="cat-hero-count">{count} pieces identified</div>}
    <div class="cat-ask-wrap">
      <div class="cat-ask-bar">
        <input class="cat-ask-input" placeholder={meta.ask} readonly />
        <button class="cat-ask-btn">Ask</button>
      </div>
      <div class="cat-ask-note">Intelligent search — coming soon</div>
    </div>
  </div>
</div>

<!-- ANCHOR NAV -->
<nav class="cat-anchor-nav">
  <a href="#collection" class="cat-anchor-link">Collection</a>
  <a href="#articles" class="cat-anchor-link">Articles</a>
  <a href="#recent" class="cat-anchor-link">Recent Finds</a>
  <a href="#auctions" class="cat-anchor-link">Auction Watch</a>
  <a href="#makers" class="cat-anchor-link">Makers</a>
  <a href="#trade" class="cat-anchor-link">From the Trade</a>
</nav>


{normalisedSlug === 'collections' && (
  <div class="col-section" id="collection">
    <div class="col-inner">
      <div class="col-cap">Museum Collection</div>
      <h2 class="col-heading">Search the National Gallery of Art</h2>
      <p class="col-sub">116,000 works — paintings, sculpture, decorative arts and more. CC0 open data.</p>
      <div class="col-controls">
        <input class="col-search" id="col-search" placeholder="Search title, artist, medium..." autocomplete="off" />
        <button class="col-pill active" data-cls="">All</button>
        <button class="col-pill" data-cls="Painting">Painting</button>
        <button class="col-pill" data-cls="Sculpture">Sculpture</button>
        <button class="col-pill" data-cls="Decorative Art">Decorative Art</button>
        <button class="col-pill" data-cls="Print">Print</button>
        <button class="col-pill" data-cls="Drawing">Drawing</button>
        <span class="col-count" id="col-count">Loading…</span>
      </div>
      <div class="col-layout">
        <div class="col-list full" id="col-list">
          <div class="col-empty">Loading collection…</div>
        </div>
        <div class="col-detail" id="col-detail" style="display:none"></div>
      </div>
    </div>
  </div>
)}

<div class="cat-body">

  <!-- STORY STACK -->
  <div class="cat-section" id="articles">
    <div class="cat-cap">From the archive</div>
    <h2 class="cat-heading">Essential reading</h2>
    <p class="cat-sub">Guides, histories and collector reference for {dbCategory.toLowerCase()}.</p>
    <a href={`/categories/${cleanSlug}/articles`} class="cat-view-all" style="display:inline-block;margin-bottom:24px;">View all articles →</a>
    {articles && articles.length > 0 ? (
      <div class="story-stack">
        {articles.map((a, i) => (
          <a href={`/learn/${a.slug}`} class="story-card">
            <div class="story-num">0{i + 1}</div>
            <div>
              <div class="story-cat">{meta.title}</div>
              <div class="story-title">{a.title}</div>
              {a.excerpt && <div class="story-excerpt">{a.excerpt}</div>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="story-placeholder">
        <div class="story-placeholder-text">Articles for this category are being added — check back soon.<br/>Meanwhile, explore our <a href="/explore" style="color:#7A5C20">knowledge base</a>.</div>
      </div>
    )}
  </div>

  <!-- IDENTIFICATION INTERRUPT -->
  <div class="id-interrupt">
    <div class="id-interrupt-eyebrow">Free Identification</div>
    <div class="id-interrupt-title">What is your {dbCategory.toLowerCase()} worth?</div>
    <div class="id-interrupt-sub">Upload a photograph and our AI identifies maker, period, condition and estimated value in seconds.</div>
    <a href="/" class="id-interrupt-btn">Identify Your Piece Free</a>
  </div>

  <!-- RECENT IDENTIFICATIONS -->
  {recent && recent.length > 0 && (
    <div class="cat-section" id="recent">
      <div class="cat-cap">Community</div>
      <h2 class="cat-heading">Recently identified</h2>
      <p class="cat-sub">Real pieces identified this week — values are AI market estimates.</p>
      <a href={`/categories/${cleanSlug}/recent`} class="cat-view-all" style="display:inline-block;margin-bottom:24px;">View all →</a>
      <div class="id-strip">
        {recent.slice(0, 4).map(item => {
          const r = item.result_json || {}
          return (
            <div class="id-strip-card">
              <div class="id-strip-img">
                {item.image_key && <img src={`${R2}/${item.image_key}`} alt={r.subcategory || ''} loading="lazy" />}
              </div>
              <div class="id-strip-body">
                {r.maker && <div class="id-strip-maker">{r.maker}</div>}
                <div class="id-strip-title">{r.subcategory || 'Antique Item'}</div>
                <div class="id-strip-value">£{(r.value_range_low || 0).toLocaleString()} – £{(r.value_range_high || 0).toLocaleString()}</div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )}

  <!-- AUCTION WATCH -->
  <div class="cat-section" id="auctions">
    <div class="cat-cap">Auction Watch</div>
    <h2 class="cat-heading">Recent results</h2>
    <p class="cat-sub">Real prices from the major auction houses — updated as results come in.</p>
    <a href={`/categories/${cleanSlug}/auctions`} class="cat-view-all" style="display:inline-block;margin-bottom:24px;">View all results →</a>
    {auctions && auctions.length > 0 ? (
      <div class="auction-grid">
        {auctions.map(a => (
          <div class="auction-card">
            <div class="auction-house">{a.auction_house}</div>
            <div class="auction-title">{a.title}</div>
            <div class="auction-price">£{((a.price_pence || 0) / 100).toLocaleString()}</div>
            <div class="auction-date">{a.sold_date ? new Date(a.sold_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''}</div>
          </div>
        ))}
      </div>
    ) : (
      <div class="auction-placeholder">
        <div class="auction-placeholder-text">Auction results for {meta.title.toLowerCase()} are being compiled.<br/>Results from Bonhams, Christie's and Sotheby's will appear here.</div>
      </div>
    )}
  </div>

  <!-- NOTABLE MAKERS -->
  {makers.length > 0 && (
    <div class="cat-section" id="makers">
      <div class="cat-cap">Notable Makers</div>
      <h2 class="cat-heading">The names collectors know</h2>
      <p class="cat-sub">The most identified makers in our collection — click to explore their history, marks and values.</p>
      <a href={`/categories/${cleanSlug}/makers`} class="cat-view-all" style="display:inline-block;margin-bottom:24px;">View all makers →</a>
      <div class="makers-grid">
        {makers.map(([maker, count]) => (
          <a href={`/makers/${maker.toLowerCase().replace(/\s+/g, '-')}`} class="maker-card">
            <div class="maker-name">{maker}</div>
            <div class="maker-count">{count} {count === 1 ? 'piece' : 'pieces'} identified</div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- FROM THE TRADE -->
  <div class="cat-section" id="trade">
    <div class="cat-cap">From the Trade</div>
    <h2 class="cat-heading">Latest news & insights</h2>
    <p class="cat-sub">Curated from the best antiques publications and auction houses.</p>
    {external && external.length > 0 ? (
      <div class="trade-grid">
        {external.map(a => (
          <a href={a.url} target="_blank" rel="noopener" class="trade-card" style="text-decoration:none">
            {a.image_url
              ? <img class="trade-thumb" src={a.image_url} alt={a.title} loading="lazy" />
              : <div class="trade-thumb"></div>
            }
            <div>
              <div class="trade-source">{a.source_name}</div>
              <div class="trade-title">{a.title}</div>
              {a.published_at && <div class="trade-date">{new Date(a.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}</div>}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="trade-placeholder">
        <div class="trade-placeholder-text">Live news feed from Antiques Trade Gazette, Christie's, Bonhams and more — launching shortly.</div>
      </div>
    )}
  </div>

  <!-- NEWSLETTER -->
  <div class="newsletter">
    <div class="newsletter-eyebrow">Weekly Digest</div>
    <div class="newsletter-title">The best of {dbCategory}</div>
    <div class="newsletter-sub">Top identifications, auction results and market insights — every week.</div>
    <div class="newsletter-form">
      <input class="newsletter-input" type="email" placeholder="your@email.com" />
      <button class="newsletter-btn">Subscribe</button>
    </div>
  </div>

</div>

<script>
if (document.getElementById('col-search')) {
  const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL
  const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY

  let currentClass = ''
  let searchTimer = null
  let selectedId = null

  function iiifMedium(url) {
    if (!url) return null
    return url.replace(/\/full\/![^/]+\//, '/full/!600,600/')
  }

  async function fetchObjects(q, cls) {
    const params = new URLSearchParams({ select: 'object_id,title,display_date,attribution,classification,subclassification,nga_thumb_url,medium,accession_num,dimensions,credit_line,on_view,wikidata_id', limit: 50, order: 'begin_year.asc.nullslast' })
    if (cls) params.append('classification', `eq.${cls}`)
    if (q) params.append('search_vector', `fts.${q}`)
    const countParams = new URLSearchParams(params)
    countParams.set('select', 'object_id')

    const [res, countRes] = await Promise.all([
      fetch(`${SUPA_URL}/rest/v1/nga_objects?${params}`, { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}`, Prefer: 'count=exact' } }),
      fetch(`${SUPA_URL}/rest/v1/nga_objects?${countParams}`, { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}`, Prefer: 'count=exact' } })
    ])

    const data = await res.json()
    const total = countRes.headers.get('content-range')?.split('/')[1] || '?'
    return { data, total }
  }

  async function fetchDetail(id) {
    const [terms, texts, historical] = await Promise.all([
      fetch(`${SUPA_URL}/rest/v1/nga_object_terms?object_id=eq.${id}&select=term_type,term`, { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` } }).then(r => r.json()),
      fetch(`${SUPA_URL}/rest/v1/nga_object_texts?object_id=eq.${id}&select=text_type,text,year`, { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` } }).then(r => r.json()),
      fetch(`${SUPA_URL}/rest/v1/nga_object_historical?object_id=eq.${id}&select=data_type,forward_text,effective_date,remarks&order=display_order.asc`, { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` } }).then(r => r.json()),
    ])
    return { terms, texts, historical }
  }

  function renderList(objects) {
    const list = document.getElementById('col-list')
    if (!objects.length) { list.innerHTML = '<div class="col-empty">No results found</div>'; return }
    list.innerHTML = objects.map(obj => `
      <div class="col-row${obj.object_id === selectedId ? ' selected' : ''}" data-id="${obj.object_id}" data-obj='${JSON.stringify(obj).replace(/'/g, "\u0027")}'>
        <div class="col-thumb">
          ${obj.nga_thumb_url ? `<img src="${obj.nga_thumb_url}" alt="" loading="lazy" />` : '<span class="col-thumb-empty">◻</span>'}
        </div>
        <div style="flex:1;min-width:0">
          <div class="col-row-title">${obj.title || 'Untitled'}</div>
          <div class="col-row-attr">${obj.attribution || 'Unknown'}${obj.display_date ? ' · ' + obj.display_date : ''}</div>
          <span class="col-row-badge">${obj.classification || ''}</span>
        </div>
      </div>
    `).join('')
    list.querySelectorAll('.col-row').forEach(row => {
      row.addEventListener('click', () => {
        const obj = JSON.parse(row.dataset.obj)
        selectedId = obj.object_id
        list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
        row.classList.add('selected')
        list.classList.remove('full')
        list.classList.add('narrow')
        showDetail(obj)
      })
    })
  }

  async function showDetail(obj) {
    const panel = document.getElementById('col-detail')
    panel.style.display = 'block'
    panel.innerHTML = `
      <button class="col-close" id="col-close">✕</button>
      ${obj.nga_thumb_url ? `<img class="col-detail-img" src="${iiifMedium(obj.nga_thumb_url)}" alt="${(obj.title||'').replace(/"/g,'')}" />` : ''}
      <div class="col-detail-title">${obj.title || 'Untitled'}</div>
      ${obj.attribution ? `<div class="col-detail-attr">${obj.attribution}</div>` : ''}
      ${obj.display_date ? `<div class="col-detail-date">${obj.display_date}</div>` : ''}
      <span class="col-detail-badge">${obj.classification || ''}</span>
      ${obj.subclassification ? `<span class="col-detail-badge">${obj.subclassification}</span>` : ''}
      ${obj.on_view ? '<span class="col-detail-badge">On view</span>' : ''}
      <div class="col-detail-grid">
        ${obj.accession_num ? `<div><div class="col-detail-label">Accession</div><div class="col-detail-val">${obj.accession_num}</div></div>` : ''}
        ${obj.medium ? `<div><div class="col-detail-label">Medium</div><div class="col-detail-val">${obj.medium}</div></div>` : ''}
        ${obj.dimensions ? `<div><div class="col-detail-label">Dimensions</div><div class="col-detail-val">${obj.dimensions}</div></div>` : ''}
        ${obj.credit_line ? `<div><div class="col-detail-label">Credit line</div><div class="col-detail-val">${obj.credit_line}</div></div>` : ''}
      </div>
      ${obj.wikidata_id ? `<a href="https://www.wikidata.org/wiki/${obj.wikidata_id}" target="_blank" rel="noopener" style="font-family:'Prata',Georgia,serif;font-size:11px;color:#C8A060;letter-spacing:1px;">Wikidata →</a>` : ''}
      <div id="col-detail-extra" style="margin-top:8px"><div style="font-family:'Prata',Georgia,serif;font-size:11px;color:rgba(239,231,217,.3);letter-spacing:2px;">Loading detail…</div></div>
    `
    document.getElementById('col-close')?.addEventListener('click', () => {
      panel.style.display = 'none'
      selectedId = null
      const list = document.getElementById('col-list')
      list.classList.remove('narrow')
      list.classList.add('full')
      list.querySelectorAll('.col-row').forEach(r => r.classList.remove('selected'))
    })

    const { terms, texts, historical } = await fetchDetail(obj.object_id)
    const extra = document.getElementById('col-detail-extra')
    if (!extra) return
    let html = ''

    if (terms.length) {
      const grouped = terms.reduce((acc, t) => { (acc[t.term_type] = acc[t.term_type] || []).push(t.term); return acc }, {})
      html += Object.entries(grouped).map(([type, ts]) => `
        <div class="col-detail-section">
          <div class="col-detail-section-label">${type}</div>
          <div>${ts.map(t => `<span class="col-detail-term">${t}</span>`).join('')}</div>
        </div>
      `).join('')
    }

    if (historical.length) {
      html += `<div class="col-detail-section"><div class="col-detail-section-label">Attribution history</div>`
      html += historical.map(h => `<div class="col-detail-text">${h.forward_text}${h.effective_date ? ' <span style="opacity:.5">· ' + h.effective_date + '</span>' : ''}</div>`).join('')
      html += '</div>'
    }

    if (texts.length) {
      const grouped = texts.reduce((acc, t) => { (acc[t.text_type] = acc[t.text_type] || []).push(t); return acc }, {})
      html += Object.entries(grouped).map(([type, entries]) => `
        <div class="col-detail-section">
          <div class="col-detail-section-label">${type.replace(/_/g,' ')}</div>
          ${entries.slice(0,3).map(e => `<div class="col-detail-text">${e.year ? '<span style="opacity:.5;margin-right:6px">' + e.year + '</span>' : ''}${e.text}</div>`).join('')}
        </div>
      `).join('')
    }

    extra.innerHTML = html || ''
  }

  async function refresh() {
    const q = document.getElementById('col-search').value.trim()
    const countEl = document.getElementById('col-count')
    countEl.textContent = 'Searching…'
    const { data, total } = await fetchObjects(q, currentClass)
    countEl.textContent = `${parseInt(total).toLocaleString()} works`
    renderList(data)
  }

  document.getElementById('col-search').addEventListener('input', () => {
    clearTimeout(searchTimer)
    searchTimer = setTimeout(refresh, 350)
  })

  document.querySelectorAll('.col-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.col-pill').forEach(p => p.classList.remove('active'))
      pill.classList.add('active')
      currentClass = pill.dataset.cls
      refresh()
    })
  })

  refresh()
}
</script>

