  .cat-ask-btn { background: #B8860B; color: #fff; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; padding: 10px 18px; border: none; white-space: nowrap; }
  .cat-ask-note { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: rgba(200,160,96,.4); text-align: center; margin-top: 10px; }

  /* ANCHOR NAV */
  .cat-anchor-nav {
    background: #1C1810; padding: 0 32px;
    display: flex; gap: 0; overflow-x: auto;
    scrollbar-width: none; border-bottom: 1px solid rgba(255,255,255,.08);
    position: sticky; top: 64px; z-index: 50;
  }
  .cat-anchor-nav::-webkit-scrollbar { display: none; }
  .cat-anchor-link {
    font-family: 'Prata', Georgia, serif; font-size: 9px;
    letter-spacing: 2px; text-transform: uppercase;
    color: rgba(239,231,217,.5); text-decoration: none;
    padding: 14px 20px; white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color .2s, border-color .2s;
  }
  .cat-anchor-link:hover { color: #EFE7D9; border-bottom-color: #C8A060; }

  /* VIEW ALL */
  .cat-view-all {
    display: inline-block; font-family: 'Prata', Georgia, serif;
    font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
    color: #7A5C20; text-decoration: none; border-bottom: 1px solid #C4B49E;
    padding-bottom: 2px; transition: color .2s, border-color .2s;
  }
  .cat-view-all:hover { color: #1C1810; border-color: #1C1810; }

  /* SECTIONS */
  .cat-body { background: #EFE7D9; }
  .cat-section { max-width: 1100px; margin: 0 auto; padding: 64px 32px; border-bottom: 1px solid #C4B49E; }
  .cat-section:last-child { border-bottom: none; }
  .cat-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .cat-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .cat-heading { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(22px,4vw,36px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 8px; }
  .cat-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: #8A7A66; line-height: 1.8; margin-bottom: 32px; max-width: 600px; }

  /* STORY STACK */
