  .cat-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 17px; color: rgba(239,231,217,.65); line-height: 1.8; max-width: 560px; margin: 0 auto 32px; }
  .cat-hero-count { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #C8A060; margin-bottom: 32px; }

  /* ASK BAR */
  .cat-ask-wrap { max-width: 560px; margin: 0 auto; }
  .cat-ask-bar { background: rgba(239,231,217,.08); border: 1px solid rgba(200,160,96,.3); padding: 16px 24px; display: flex; gap: 14px; align-items: center; }
