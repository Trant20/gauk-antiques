<div class="yt-modal-overlay" id="yt-modal-overlay">
  <div class="yt-modal" id="yt-modal">
    <button class="yt-modal-close" id="yt-modal-close">&#x2715;</button>
    <iframe id="yt-modal-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    <div class="yt-modal-title" id="yt-modal-title"></div>
  </div>
</div>

<script>
  const overlay = document.getElementById('yt-modal-overlay')
  const iframe = document.getElementById('yt-modal-iframe')
  const titleEl = document.getElementById('yt-modal-title')
  const closeBtn = document.getElementById('yt-modal-close')

  document.querySelectorAll('.video-card[data-video-id]').forEach(card => {
    card.addEventListener('click', () => {
      const videoId = card.getAttribute('data-video-id')
      const title = card.getAttribute('data-video-title')
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`
      titleEl.textContent = title
      overlay.classList.add('open')
      document.body.style.overflow = 'hidden'
    })
  })

  function closeModal() {
    overlay.classList.remove('open')
    iframe.src = ''
    document.body.style.overflow = ''
  }

  closeBtn.addEventListener('click', closeModal)
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal() })
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal() })
</script>

<script>
  import { supabase } from '../../lib/supabase-browser'

  const { data: { session } } = await supabase.auth.getSession()
  if (session) {
    window.__gauk_user_id = session.user.id
    window.__gauk_token = session.access_token
  }

  document.addEventListener('widget-reset-result', () => {
    const ro = document.getElementById('cat-result-outer')
    if (ro) ro.style.display = 'none'
  })

  document.addEventListener('identification-complete', (e: any) => {
    const identifyData = e.detail
    const r = identifyData.result

    document.getElementById('cat-result-category')!.textContent = r.category
    document.getElementById('cat-result-confidence')!.textContent = r.confidence
    document.getElementById('cat-result-title')!.textContent = r.subcategory
    document.getElementById('cat-result-condition')!.textContent = r.condition

    const notes = [r.condition_notes, r.confidence_notes].filter(Boolean).join(' ')
    const notesEl = document.getElementById('cat-result-notes')
    if (notesEl && notes) notesEl.textContent = notes

    const typedText = document.getElementById('cat-typed-text')
    const typedCursor = document.getElementById('cat-typed-cursor')
    if (typedText && typedCursor) {
      const desc = r.description || ''
      let ti = 0
      typedText.textContent = ''
      typedCursor.style.display = 'inline-block'
      function typeChar() {
        if (ti < desc.length) { typedText.textContent += desc[ti]; ti++; setTimeout(typeChar, 22) }
        else { typedCursor.style.display = 'none' }
      }
      setTimeout(typeChar, 400)
    }

    document.getElementById('cat-result-value')!.textContent =
      '£' + (r.value_range_low || 0).toLocaleString() + ' – £' + (r.value_range_high || 0).toLocaleString()

    if (r.maker) {
      document.getElementById('cat-result-maker')!.textContent = r.maker
      const row = document.getElementById('cat-row-maker')
      if (row) row.style.display = 'flex'
    }
    if (r.period) {
      document.getElementById('cat-result-period')!.textContent = r.period + (r.circa ? ' — ' + r.circa : '')
      const row = document.getElementById('cat-row-period')
      if (row) row.style.display = 'flex'
    }
    if (identifyData.id) {
      const ref = document.getElementById('cat-result-ref')
      if (ref) ref.textContent = 'REF ' + identifyData.id.slice(0,8).toUpperCase()
      if (session) {
        const viewReport = document.getElementById('cat-result-view-report')
        const viewLink = document.getElementById('cat-view-report-link') as HTMLAnchorElement
        if (viewReport) viewReport.style.display = 'block'
        if (viewLink) viewLink.href = '/valuation/' + identifyData.id
      }
    }

    const outer = document.getElementById('cat-result-outer')
    if (outer) {
      outer.style.display = 'block'
      outer.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }

    if (session) {
      const bc = document.getElementById('cat-blur-content')
      const bo = document.getElementById('cat-blur-overlay')
      if (bc) bc.style.filter = 'none'
      if (bo) bo.style.display = 'none'
      if (session.user.id && identifyData.id) {
        fetch('/api/deduct-credits', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${session.access_token}` },
          body: JSON.stringify({ site_id: 'add6d12c-ecd8-4517-b2e5-0f4977603744', identification_id: identifyData.id, amount: 1 })
        })
      }
    }
  })
</script>

