  .id-interrupt-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(28px,5vw,48px); font-style: italic; color: #EFE7D9; margin-bottom: 12px; }
  .id-interrupt-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: rgba(239,231,217,.6); line-height: 1.8; margin-bottom: 32px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .id-interrupt-btn { display: inline-block; background: #B8860B; color: #fff; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; padding: 16px 40px; text-decoration: none; transition: background .2s; }
  .id-interrupt-btn:hover { background: #9A7009; }

  /* IDENTIFICATION STRIP */
  .id-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 700px) { .id-strip { grid-template-columns: repeat(2, 1fr); } }
  .id-strip-card { background: #EFE7D9; }
  .id-strip-img { width: 100%; aspect-ratio: 1/1; overflow: hidden; position: relative; background: #E6DCCB; }
  .id-strip-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; }
  .id-strip-body { padding: 12px; border-top: 1px solid #C4B49E; }
  .id-strip-maker { font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: #7A5C20; margin-bottom: 3px; }
  .id-strip-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 13px; font-style: italic; color: #1C1810; margin-bottom: 4px; line-height: 1.3; }
  .id-strip-value { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 12px; color: #7A5C20; }

  /* AUCTION WATCH */
  .auction-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  @media (max-width: 600px) { .auction-grid { grid-template-columns: 1fr; } }
  .auction-card { background: #E6DCCB; border: 1px solid #C4B49E; padding: 20px; }
  .auction-house { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #7A5C20; margin-bottom: 6px; }
  .auction-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 16px; font-style: italic; color: #1C1810; margin-bottom: 10px; line-height: 1.3; }
  .auction-price { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 28px; color: #7A5C20; line-height: 1; margin-bottom: 4px; }
  .auction-date { font-family: 'Prata', Georgia, serif; font-size: 10px; color: #8A7A66; letter-spacing: 1px; }
  .auction-placeholder { background: #E6DCCB; border: 1px dashed #C4B49E; padding: 40px; text-align: center; }
  .auction-placeholder-text { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; line-height: 1.7; }

  /* MAKERS */
  .makers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  @media (max-width: 600px) { .makers-grid { grid-template-columns: repeat(2, 1fr); } }
