  .story-card:hover { background: #E6DCCB; }
  .story-num { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 36px; color: #C4B49E; line-height: 1; flex-shrink: 0; width: 48px; }
  .story-cat { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #7A5C20; margin-bottom: 6px; }
  .story-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 18px; font-style: italic; color: #1C1810; line-height: 1.3; margin-bottom: 8px; }
  .story-excerpt { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; line-height: 1.7; }
