---
import PublicShell from '../../layouts/PublicShell.astro'
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
const R2 = 'https://pub-c3f96dd742f540188b92599aeed807c7.r2.dev'

const { category } = Astro.params
if (!category) return Astro.redirect('/explore')

// Normalise slug — decode URI and clean
const decodedCategory = decodeURIComponent(category)

// Validate category exists in the list
const { data: catListSetting } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', SITE_ID)
  .eq('key', 'categories')
  .single()

const validCategories: string[] = catListSetting?.value ? JSON.parse(catListSetting.value) : []
const validSlugs = validCategories.map((c: string) => 
  c.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
)
const normalisedSlug = decodedCategory.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')

// Look up display name from categories list — preserves 'Clocks & Watches' etc
const dbCategory = validCategories.find((c: string) =>
  c.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') === normalisedSlug
) || decodedCategory.charAt(0).toUpperCase() + decodedCategory.slice(1)

// Check for redirect (renamed categories)
const { data: redirectSetting } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', SITE_ID)
  .eq('key', `category_redirect_${category}`)
  .single()

if (redirectSetting?.value) {
  return Astro.redirect(`/categories/${redirectSetting.value}`, 301)
}

if (!validSlugs.includes(normalisedSlug)) {
  return Astro.redirect('/explore', 302)
}

// Canonical redirect — if URL isn't the clean slug, redirect to it
if (category !== normalisedSlug) {
  return Astro.redirect(`/categories/${normalisedSlug}`, 301)
}

// Load all category settings from DB in one query
const { data: allSettings } = await supabase
  .from('site_settings')
  .select('key, value')
  .eq('site_id', SITE_ID)
  .in('key', [
    `category_hero_${category}`,
    `category_title_${category}`,
    `category_subtitle_${category}`,
  ])

const settingsMap: Record<string, string> = {}
allSettings?.forEach(s => { settingsMap[s.key] = s.value })

const cleanSlug = decodedCategory.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
const heroImage = settingsMap[`category_hero_${cleanSlug}`] || settingsMap[`category_hero_${category}`] || ''
const heroTitle = settingsMap[`category_title_${cleanSlug}`] || settingsMap[`category_title_${category}`] || `The World of ${dbCategory}`
const heroSubtitle = settingsMap[`category_subtitle_${cleanSlug}`] || settingsMap[`category_subtitle_${category}`] || `Explore ${dbCategory} — identification, valuation, auction results and collector guides.`
const askPlaceholder = `Ask anything about ${dbCategory.toLowerCase()}...`

const meta = {
  title: dbCategory,
  headline: heroTitle,
  sub: heroSubtitle,
  ask: askPlaceholder
}

// Recent identifications
const { data: recent, count } = await supabase
  .from('identifications')
  .select('id, image_key, result_json, created_at', { count: 'exact' })
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .not('image_key', 'is', null)
  .order('created_at', { ascending: false })
  .limit(8)

// Notable makers from identifications
const { data: makerRows } = await supabase
  .from('identifications')
  .select('result_json')
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .not('result_json->>maker', 'is', null)

const makerCounts: Record<string, number> = {}
makerRows?.forEach(r => {
  const m = r.result_json?.maker
  if (m) makerCounts[m] = (makerCounts[m] || 0) + 1
})
const makers = Object.entries(makerCounts).sort((a, b) => b[1] - a[1]).slice(0, 6)

// Articles (placeholder until articles table populated)
const { data: articles } = await supabase
  .from('articles')
  .select('id, title, slug, excerpt, published_at')
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .eq('published', true)
  .order('published_at', { ascending: false })
  .limit(5)

// Auction results
const { data: auctions } = await supabase
  .from('auction_results')
  .select('id, title, maker, price_pence, auction_house, sold_date')
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .order('sold_date', { ascending: false })
  .limit(4)

// External articles
const { data: external } = await supabase
  .from('external_articles')
  .select('id, title, url, source_name, published_at, image_url')
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .order('published_at', { ascending: false })
  .limit(4)
---
<PublicShell title={`${heroTitle} — GAUK Antiques`} description={heroSubtitle} ogImage={heroImage}>
<link rel="canonical" href={`https://gaukantiques.com/categories/${cleanSlug}`} slot="head" />
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": heroTitle,
  "description": heroSubtitle,
  "url": `https://gaukantiques.com/categories/${category}`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gaukantiques.com" },
      { "@type": "ListItem", "position": 2, "name": "Explore", "item": "https://gaukantiques.com/explore" },
      { "@type": "ListItem", "position": 3, "name": heroTitle, "item": `https://gaukantiques.com/categories/${category}` }
    ]
  }
})} />
<style>
  /* HERO */
  .cat-hero {
    position: relative; min-height: 70vh;
    display: flex; align-items: flex-end;
    overflow: hidden; background: #1C1810;
  }
  .cat-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .cat-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.95) 0%, rgba(13,8,4,.5) 50%, rgba(13,8,4,.2) 100%); }
  .cat-hero-content { position: relative; z-index: 2; width: 100%; max-width: 800px; margin: 0 auto; padding: 60px 40px; text-align: center; }
  .cat-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: #C8A060; margin-bottom: 16px; }
