---
import { ANTIQUES_SITE_ID } from '../lib/constants'
import { decodeTitle } from '../lib/utils'
import PublicShell from '../layouts/PublicShell.astro'
import { supabase } from '../lib/supabase'


// Category filter from query string
const categoryFilter = Astro.url.searchParams.get('category') || ''

// Load categories from site_settings
const { data: catSetting } = await supabase
  .from('site_settings')
  .select('value')
  .eq('site_id', ANTIQUES_SITE_ID)
  .eq('key', 'categories')
  .single()

const allCategories: string[] = catSetting?.value ? JSON.parse(catSetting.value) : []

function slugify(s: string): string {
  return s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}

// Find display name from slug
const activeCategoryName = categoryFilter
  ? allCategories.find(c => slugify(c) === categoryFilter) || ''
  : ''

// Load hero images — videos listing hero and category hero if filtered
const [
  { data: videosHeroSetting },
  { data: categoryHeroSetting },
] = await Promise.all([
  supabase.from('site_settings').select('value').eq('site_id', ANTIQUES_SITE_ID).eq('key', 'videos_hero').single(),
  categoryFilter
    ? supabase.from('site_settings').select('value').eq('site_id', ANTIQUES_SITE_ID).eq('key', `category_hero_${categoryFilter}`).single()
    : Promise.resolve({ data: null }),
])
const videosHeroImage: string = videosHeroSetting?.value || ''
const categoryHeroImage: string = categoryHeroSetting?.value || ''

// Load active YouTube channels
const { data: channels } = await supabase
  .from('publishers')
  .select('id, name, slug, logo_url, description')
  .eq('has_youtube', true)
  .eq('active', true)
  .order('name')
  .limit(20)

// Load videos — filtered or all (category filter view)
type VideoRow = { id: string; title: string; url: string; video_id: string; thumbnail_url: string; published_at: string; source_name: string; categories: string[]; publisher_id: string }
let allVideos: VideoRow[] = []
if (activeCategoryName) {
  const { data } = await supabase
    .from('external_articles')
    .select('id, title, url, video_id, thumbnail_url, published_at, source_name, categories, publisher_id')
    .eq('site_id', ANTIQUES_SITE_ID)
    .eq('content_type', 'video')
    .eq('is_public', true)
    .contains('categories', [activeCategoryName])
    .order('published_at', { ascending: false })
    .limit(200)
  allVideos = data || []
}

// Latest videos — top 24 for primary grid on unfiltered view
const { data: latestVideos } = !activeCategoryName ? await supabase
  .from('external_articles')
  .select('id, title, url, video_id, thumbnail_url, published_at, source_name, categories, publisher_id')
  .eq('site_id', ANTIQUES_SITE_ID)
  .eq('content_type', 'video')
  .eq('is_public', true)
  .order('published_at', { ascending: false })
  .limit(8) : { data: [] }

// Build category sections — single query, group in JS
type CategorySection = { videos: VideoRow[]; total: number }
const categoryVideos: Record<string, CategorySection> = {}

if (!activeCategoryName) {
  const { data: allCatVideos } = await supabase
    .from('external_articles')
    .select('id, title, url, video_id, thumbnail_url, published_at, source_name, categories, publisher_id')
    .eq('site_id', ANTIQUES_SITE_ID)
    .eq('content_type', 'video')
    .eq('is_public', true)
    .order('published_at', { ascending: false })
    .limit(500)

  for (const cat of allCategories) {
    const vids = (allCatVideos ?? []).filter(v => Array.isArray(v.categories) && v.categories.includes(cat)).slice(0, 8)
    if (vids.length > 0) {
      categoryVideos[cat] = { videos: vids, total: vids.length }
    }
  }
}

const pageTitle = activeCategoryName
  ? `${activeCategoryName} Videos — GAUK Antiques`
  : 'Videos & Guides — GAUK Antiques'

const pageDescription = activeCategoryName
  ? `Video guides, auction coverage and collector advice for ${activeCategoryName.toLowerCase()} antiques.`
  : 'Video guides, auction coverage and collector advice — curated from the best antiques channels on YouTube.'

---
<PublicShell title={pageTitle} description={pageDescription}>
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `https://gaukantiques.com/videos${categoryFilter ? '?category=' + categoryFilter : ''}`,
  "publisher": { "@type": "Organization", "name": "GAUK Antiques", "url": "https://gaukantiques.com" }
})} />

<style is:global>
  /* PAGE WRAP */
  .vid-page { background: #EFE7D9; min-height: 100vh; }

  /* HERO */
  .vid-hero { position: relative; background: #1C1810; padding: 100px 32px 56px; text-align: center; overflow: hidden; }
  .vid-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .vid-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.95) 0%, rgba(13,8,4,.6) 60%, rgba(13,8,4,.4) 100%); }
  .vid-hero-inner { position: relative; z-index: 2; }
  .vid-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: #C8A060; margin-bottom: 16px; }
  .vid-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(32px,6vw,56px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.1; margin-bottom: 12px; }
  .vid-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: rgba(239,231,217,.6); max-width: 520px; margin: 0 auto; line-height: 1.8; }
  @media (max-width: 767px) { .vid-hero { padding: 80px 16px 40px; } }

  /* CATEGORY FILTER */
  .vid-filter-wrap { position: relative; background: #1C1810; border-top: 1px solid rgba(255,255,255,.08); }
  .vid-filter-wrap::after { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 120px; background: linear-gradient(to right, transparent, #1C1810); pointer-events: none; z-index: 1; }
  .vid-filter { padding: 0 32px; display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .vid-filter::-webkit-scrollbar { display: none; }
  @media (max-width: 767px) { .vid-filter { padding: 0 8px; } .vid-filter-link { padding: 14px 10px; font-size: 8px; } }
  .vid-filter-link { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(239,231,217,.5); text-decoration: none; padding: 14px 16px; white-space: nowrap; border-bottom: 2px solid transparent; transition: color .2s, border-color .2s; flex-shrink: 0; }
  .vid-filter-link:hover { color: #EFE7D9; border-bottom-color: rgba(200,160,96,.4); }
  .vid-filter-link.active { color: #C8A060; border-bottom-color: #C8A060; }
  @media (max-width: 767px) { .vid-filter { padding: 0 8px; } .vid-filter-link { padding: 14px 10px; font-size: 8px; } }

  /* MY FEED */
  .vid-feed-gate { background: #E6DCCB; border: 1px solid #C4B49E; padding: 32px; text-align: center; }
  .vid-feed-gate-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 20px; font-style: italic; color: #1C1810; margin-bottom: 8px; }
  .vid-feed-gate-sub { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; margin-bottom: 20px; line-height: 1.8; }
  .vid-feed-gate-btn { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; padding: 12px 28px; background: #1C1810; color: #EFE7D9; text-decoration: none; transition: background .2s; }
  .vid-feed-gate-btn:hover { background: #2C2418; }
  .vid-feed-loading { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: #8A7A66; letter-spacing: 2px; text-transform: uppercase; padding: 32px 0; text-align: center; }

  /* LATEST SECTION */
  .vid-latest { max-width: 1100px; margin: 0 auto; padding: 48px 32px 0; }
  @media (max-width: 767px) { .vid-latest { padding: 40px 16px 0; } }
  .vid-latest-count { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; margin-bottom: 24px; }

  /* CHANNELS STRIP */
  .vid-channels { max-width: 1100px; margin: 0 auto; padding: 48px 32px 0; }
  .vid-section-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .vid-section-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .vid-section-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(20px,3vw,28px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 24px; }
  .channels-strip-wrap { position: relative; }
  .channels-strip-wrap::after { content: ''; position: absolute; top: 0; right: 0; bottom: 8px; width: 100px; background: linear-gradient(to right, transparent, #EFE7D9); pointer-events: none; z-index: 1; }
  .channels-strip { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px; scrollbar-width: none; }
  .channels-strip::-webkit-scrollbar { display: none; }
  .channel-chip { display: flex; align-items: center; gap: 10px; background: #E6DCCB; border: 1px solid #C4B49E; padding: 10px 16px; text-decoration: none; flex-shrink: 0; transition: border-color .15s, background .15s; }
  .channel-chip:hover { border-color: #7A5C20; background: #DDD0BF; }
  .channel-chip-logo { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; background: #C4B49E; flex-shrink: 0; }
  .channel-chip-logo-placeholder { width: 28px; height: 28px; border-radius: 50%; background: #7A5C20; display: flex; align-items: center; justify-content: center; font-family: 'Prata', Georgia, serif; font-size: 12px; color: #EFE7D9; flex-shrink: 0; }
  .channel-chip-name { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #1C1810; white-space: nowrap; }
  @media (max-width: 767px) { .vid-channels { padding: 40px 16px 0; } }

  /* VIDEO GRID */
  .vid-section { max-width: 1100px; margin: 0 auto; padding: 48px 32px; border-bottom: 1px solid #C4B49E; }
  .vid-section:last-child { border-bottom: none; }
  .vid-section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
  .vid-view-all { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #7A5C20; text-decoration: none; border-bottom: 1px solid #C4B49E; padding-bottom: 2px; transition: color .2s, border-color .2s; }
  .vid-view-all:hover { color: #1C1810; border-color: #1C1810; }
  .video-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 900px) { .video-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .video-grid { grid-template-columns: repeat(2, 1fr); } }
  .video-card { background: #EFE7D9; text-decoration: none; display: block; cursor: pointer; transition: background .15s; }
  .video-card:hover { background: #E6DCCB; }
  .video-thumb-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; background: #E6DCCB; }
  .video-thumb-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.25); transition: background .2s; }
  .video-card:hover .video-play { background: rgba(0,0,0,0.4); }
  .video-play-icon { width: 44px; height: 44px; background: rgba(255,255,255,.92); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .video-body { padding: 12px; }
  .video-source { font-family: var(--mono); font-size: 9px; color: #8A7A66; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
  .video-title { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #1C1810; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  @media (max-width: 767px) { .vid-section { padding: 40px 16px; } }

  /* MODAL */
  .yt-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; padding: 20px; }
  .yt-modal-overlay.open { display: flex; }
  .yt-modal { position: relative; width: 100%; max-width: 960px; aspect-ratio: 16/9; background: #000; }
  .yt-modal iframe { width: 100%; height: 100%; border: none; }
  .yt-modal-close { position: absolute; top: -44px; right: 0; background: none; border: none; color: #fff; font-size: 28px; cursor: pointer; line-height: 1; padding: 4px 8px; opacity: .7; transition: opacity .2s; }
  .yt-modal-close:hover { opacity: 1; }
  .yt-modal-title { position: absolute; bottom: -36px; left: 0; right: 0; color: rgba(255,255,255,.6); font-family: 'Prata', Georgia, serif; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* EMPTY STATE */
  .vid-empty { padding: 64px 32px; text-align: center; }
  .vid-empty-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 24px; font-style: italic; color: #1C1810; margin-bottom: 10px; }
  .vid-empty-sub { font-family: 'Prata', Georgia, serif; font-size: 14px; color: #8A7A66; line-height: 1.8; }
</style>

<div class="vid-page">

  <!-- HERO -->
  <div class="vid-hero">
    {(categoryHeroImage || videosHeroImage) && <div class="vid-hero-bg" style={`background-image:url('${categoryHeroImage || videosHeroImage}')`}></div>}
    <div class="vid-hero-overlay"></div>
    <div class="vid-hero-inner">
      <div class="vid-hero-eyebrow">Video Library</div>
      <h1 class="vid-hero-title">
        {activeCategoryName ? `${activeCategoryName} Videos` : 'Videos & Guides'}
      </h1>
      <p class="vid-hero-sub">{pageDescription}</p>
    </div>
  </div>

  <!-- CATEGORY FILTER -->
  <div class="vid-filter-wrap">
  <nav class="vid-filter">
    <a href="/videos" class={`vid-filter-link${!categoryFilter ? ' active' : ''}`}>All</a>
    {allCategories.map(cat => {
      const slug = slugify(cat)
      return (
        <a
          href={`/videos?category=${slug}`}
          class={`vid-filter-link${categoryFilter === slug ? ' active' : ''}`}
        >{cat}</a>
      )
    })}
  </nav>
  </div>

  <!-- MY FEED — shown on unfiltered view -->
  {!activeCategoryName && (
    <div class="vid-latest" id="vid-feed-wrap">
      <div class="vid-section-header">
        <div>
          <div class="vid-section-cap">My Feed</div>
          <div class="vid-section-title">Channels you follow</div>
        </div>
        <a href="/feed" class="vid-view-all">Go to feed →</a>
      </div>
      <div id="vid-feed-content">
        <div class="vid-feed-loading">Loading your feed...</div>
      </div>
    </div>
  )}

  <!-- LATEST VIDEOS — primary view when no category filter -->
  {!activeCategoryName && latestVideos && latestVideos.length > 0 && (
    <div class="vid-latest">
      <div class="vid-section-cap">Latest</div>
      <div class="vid-section-title">Recently added</div>
      <div class="vid-latest-count">{latestVideos.length} of 1,000+ videos</div>
      <div class="video-grid">
        {latestVideos.map(v => (
          <a href={`/videos/${v.id}`} class="video-card">
            <div class="video-thumb-wrap">
              {v.thumbnail_url
                ? <img src={v.thumbnail_url} alt="" loading="lazy" />
                : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
              }
              <div class="video-play">
                <div class="video-play-icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                </div>
              </div>
            </div>
            <div class="video-body">
              {v.source_name && <div class="video-source">{v.source_name}</div>}
              <div class="video-title" set:text={decodeTitle(v.title)}></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- CHANNELS STRIP — only on unfiltered view -->
  {!activeCategoryName && channels && channels.length > 0 && (
    <div class="vid-channels">
      <div class="vid-section-header">
        <div>
          <div class="vid-section-cap">Channels</div>
          <div class="vid-section-title">Featured channels</div>
        </div>
        <a href="/channels" class="vid-view-all">View all →</a>
      </div>
      <div class="channels-strip-wrap">
      <div class="channels-strip">
        {channels.map(c => (
          <a href={`/channels/${c.slug}`} class="channel-chip">
            {c.logo_url
              ? <img class="channel-chip-logo" src={c.logo_url} alt={c.name} loading="lazy" />
              : <div class="channel-chip-logo-placeholder">{c.name.charAt(0).toUpperCase()}</div>
            }
            <span class="channel-chip-name">{c.name}</span>
          </a>
        ))}
      </div>
      </div>
    </div>
  )}

  <!-- FILTERED VIEW — all matching videos in one grid -->
  {activeCategoryName && (
    <div class="vid-section">
      <div class="vid-section-cap">{activeCategoryName}</div>
      <div class="vid-section-title">
        {(allVideos || []).length} video{(allVideos || []).length !== 1 ? 's' : ''}
      </div>
      {allVideos && allVideos.length > 0 ? (
        <div class="video-grid">
          {allVideos.map(v => (
            <a href={`/videos/${v.id}`} class="video-card">
              <div class="video-thumb-wrap">
                {v.thumbnail_url
                  ? <img src={v.thumbnail_url} alt={v.title} loading="lazy" />
                  : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
                }
                <div class="video-play">
                  <div class="video-play-icon">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                  </div>
                </div>
              </div>
              <div class="video-body">
                {v.source_name && <div class="video-source">{v.source_name}</div>}
                <div class="video-title" set:text={decodeTitle(v.title)}></div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="vid-empty">
          <div class="vid-empty-title">No videos yet</div>
          <div class="vid-empty-sub">Videos for this category are being added — check back soon.</div>
        </div>
      )}
    </div>
  )}

  <!-- CATEGORY SECTIONS — unfiltered view -->
  {!activeCategoryName && Object.entries(categoryVideos).map(([cat, section]) => (
    <div class="vid-section">
      <div class="vid-section-header">
        <div>
          <div class="vid-section-cap">{cat}</div>
          <div class="vid-section-title">{cat} guides & coverage</div>
        </div>
        <a href={`/videos?category=${slugify(cat)}`} class="vid-view-all">View all {section.total} →</a>
      </div>
      <div class="video-grid">
        {(section.videos || []).map(v => (
          <a href={`/videos/${v.id}`} class="video-card">
            <div class="video-thumb-wrap">
              {v.thumbnail_url
                ? <img src={v.thumbnail_url} alt={v.title} loading="lazy" />
                : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
              }
              <div class="video-play">
                <div class="video-play-icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                </div>
              </div>
            </div>
            <div class="video-body">
              {v.source_name && <div class="video-source">{v.source_name}</div>}
              <div class="video-title" set:text={decodeTitle(v.title)}></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  {!activeCategoryName && Object.keys(categoryVideos).length === 0 && (
    <div class="vid-empty">
      <div class="vid-empty-title">Videos coming soon</div>
      <div class="vid-empty-sub">Our video library is being built — check back shortly.</div>
    </div>
  )}

</div>

<!-- MODAL -->
<div class="yt-modal-overlay" id="yt-modal-overlay">
  <div class="yt-modal" id="yt-modal">
    <button class="yt-modal-close" id="yt-modal-close">&#x2715;</button>
    <iframe id="yt-modal-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    <div class="yt-modal-title" id="yt-modal-title"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase-browser'

  async function loadFeed() {
    const feedContent = document.getElementById('vid-feed-content')
    if (!feedContent) return
    const { data: { session } } = await supabase.auth.getSession()
    if (!session) {
      feedContent.innerHTML = `<div class="vid-feed-gate">
        <div class="vid-feed-gate-title">Your personal feed</div>
        <div class="vid-feed-gate-sub">Follow channels to build a feed of videos tailored to your interests.</div>
        <a href="/auth/signin" class="vid-feed-gate-btn">Sign In to Follow Channels</a>
      </div>`
      return
    }
    const res = await fetch('/api/feed?limit=8', {
      headers: { Authorization: `Bearer ${session.access_token}` }
    })
    const json = await res.json()
    if (!json.videos?.length) {
      feedContent.innerHTML = `<div class="vid-feed-gate">
        <div class="vid-feed-gate-title">Your feed is empty</div>
        <div class="vid-feed-gate-sub">Follow some channels and their latest videos will appear here.</div>
        <a href="/channels" class="vid-feed-gate-btn">Browse Channels</a>
      </div>`
      return
    }
    feedContent.innerHTML = `<div class="video-grid">${json.videos.map((v: any) => `
      <a href="/videos/${v.id}" class="video-card">
        <div class="video-thumb-wrap">
          ${v.thumbnail_url ? `<img src="${v.thumbnail_url}" alt="" loading="lazy" />` : '<div style="width:100%;height:100%;background:#E6DCCB;"></div>'}
          <div class="video-play"><div class="video-play-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg></div></div>
        </div>
        <div class="video-body">
          ${v.source_name ? `<div class="video-source">${v.source_name}</div>` : ''}
          <div class="video-title">${v.title}</div>
        </div>
      </a>`).join('')}</div>`
  }

  loadFeed()

function decodeHtml(str) {
  if (!str) return ''
  return str
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&apos;/g, "'")
    .replace(/&#x27;/g, "'")
    .replace(/&ndash;/g, '–')
    .replace(/&mdash;/g, '—')
    .replace(/&hellip;/g, '…')
    .replace(/&#\d+;/g, (m) => String.fromCharCode(parseInt(m.slice(2,-1))))
}

  const overlay = document.getElementById('yt-modal-overlay') as HTMLElement
  const iframe = document.getElementById('yt-modal-iframe') as HTMLIFrameElement
  const titleEl = document.getElementById('yt-modal-title') as HTMLElement
  const closeBtn = document.getElementById('yt-modal-close') as HTMLButtonElement

  function openModal(videoId: string, title: string) {
    iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`
    titleEl.textContent = title
    overlay.classList.add('open')
    document.body.style.overflow = 'hidden'
  }

  function closeModal() {
    overlay.classList.remove('open')
    iframe.src = ''
    document.body.style.overflow = ''
  }

  document.querySelectorAll('.video-card[data-video-id]').forEach(card => {
    card.addEventListener('click', () => {
      const videoId = (card as HTMLElement).dataset.videoId || ''
      const title = (card as HTMLElement).dataset.videoTitle || ''
      if (videoId) openModal(videoId, title)
    })
  })

  closeBtn.addEventListener('click', closeModal)
  overlay.addEventListener('click', e => {
    if (e.target === overlay) closeModal()
  })
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeModal()
  })
</script>
