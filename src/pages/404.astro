---
import PublicShell from '../layouts/PublicShell.astro'

const categories = [
  'Ceramics','Glass','Jewellery','Metalware','Furniture','Art','Clocks & Watches',
  'Textiles','Books & Literature','Toys','Militaria','Associations','Music',
  'Film & Media','Articles & Guides','Artists, Authors, Designers','Stamps & Coins',
  'Memorabilia','Collectibles & Decorative Arts','Factories, Studios & Workshops',
  'Historical Figures & History','Collections'
]

function slugify(s: string) {
  return s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}
---
<PublicShell title="Page Not Found — GAUK Antiques" description="Explore antiques by category — ceramics, glass, jewellery, furniture and more.">

<style>
  .exp-hero {
    background: #1C1810; padding: 80px 24px 64px;
    text-align: center; position: relative; overflow: hidden;
  }
  .exp-hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, #3C2415 0%, #1C1810 70%);
    opacity: .6;
  }
  .exp-hero-content { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; }
  .exp-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #C8A060; margin-bottom: 14px; }
  .exp-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(32px,6vw,56px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.15; margin-bottom: 16px; }
  .exp-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: rgba(239,231,217,.65); line-height: 1.8; margin-bottom: 32px; }

  .exp-wrap { max-width: 960px; margin: 0 auto; padding: 56px 24px 80px; }
  .exp-section { margin-bottom: 56px; }
  .exp-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 6px; display: flex; align-items: center; gap: 12px; }
  .exp-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .exp-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(20px,4vw,28px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 6px; }
  .exp-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: #8A7A66; line-height: 1.8; margin-bottom: 24px; max-width: 560px; }

  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  @media (max-width: 600px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
  .cat-tile { background: #E6DCCB; border: 1px solid #C4B49E; padding: 20px 14px; text-align: center; text-decoration: none; color: #1C1810; transition: background .15s; display: block; }
  .cat-tile:hover { background: #DDD0BF; }
  .cat-tile-name { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 16px; font-style: italic; color: #1C1810; }

  .exp-cta { background: #E6DCCB; border: 1px solid #C4B49E; padding: 48px; text-align: center; margin-top: 56px; }
  .exp-cta-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 26px; font-style: italic; color: #1C1810; margin-bottom: 10px; }
  .exp-cta-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: #8A7A66; margin-bottom: 24px; line-height: 1.8; }
  .exp-cta-btn { display: inline-block; background: #1C1810; color: #EFE7D9; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; padding: 14px 32px; text-decoration: none; transition: opacity .2s; }
  .exp-cta-btn:hover { opacity: .85; }
</style>

<!-- HERO -->
<div class="exp-hero">
  <div class="exp-hero-bg"></div>
  <div class="exp-hero-content">
    <div class="exp-hero-eyebrow">Page Not Found</div>
    <h1 class="exp-hero-title">Everything antiques.<br>In one place.</h1>
    <p class="exp-hero-sub">The page you were looking for doesn't exist. Browse by category below or identify a new piece.</p>
  </div>
</div>

<div class="exp-wrap">
  <div class="exp-section">
    <div class="exp-cap">Browse by category</div>
    <h2 class="exp-title">What are you collecting?</h2>
    <p class="exp-sub">Explore makers, values and recent finds across every category.</p>
    <div class="cat-grid">
      {categories.map(cat => (
        <a href={`/categories/${slugify(cat)}`} class="cat-tile">
          <div class="cat-tile-name">{cat}</div>
        </a>
      ))}
    </div>
  </div>

  <div class="exp-cta">
    <div class="exp-cta-title">Have a piece to identify?</div>
    <div class="exp-cta-sub">Upload a photograph and our AI identifies maker, period, condition and estimated value in seconds.</div>
    <a href="/" class="exp-cta-btn">Identify free →</a>
  </div>
</div>

</PublicShell>
