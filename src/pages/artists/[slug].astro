---
import PublicShell from '../../layouts/PublicShell.astro'
import { supabase } from '../../lib/supabase'

/** Derive slug from preferred_name */
function nameToSlug(name: string): string {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}

const { slug } = Astro.params
if (!slug) return Astro.redirect('/categories/collections')

// Find constituent directly by slug column
const { data: artist } = await supabase
  .from('nga_constituents')
  .select('constituent_id,preferred_name,forward_name,last_name,display_date,begin_year,end_year,nationality,constituent_type,ulan_id,wikidata_id,portrait_url,signature_url')
  .eq('slug', slug)
  .single()
if (!artist) return Astro.redirect('/categories/collections', 302)

// Wikidata enrichment
const { data: wd } = artist.wikidata_id
  ? await supabase
      .from('wikidata_entities')
      .select('label,description,portrait_url,signature_url,birth_date,death_date,birth_place,death_place,movements,occupations,influenced_by_ids,notable_work_ids')
      .eq('wikidata_id', artist.wikidata_id)
      .single()
  : { data: null }

// Works in NGA collection
const { data: links } = await supabase
  .from('nga_object_constituents')
  .select('object_id')
  .eq('constituent_id', artist.constituent_id)
  .limit(48)

const objectIds = (links || []).map(l => l.object_id)
const { data: works } = objectIds.length
  ? await supabase
      .from('nga_objects')
      .select('object_id,title,display_date,classification,subclassification,nga_thumb_url,nga_image_url,accession_num,medium')
      .in('object_id', objectIds)
  : { data: [] }

const portrait = wd?.portrait_url || artist.portrait_url
const signature = wd?.signature_url || artist.signature_url
const bio = wd?.description || null
const movements: string[] = wd?.movements || []
const occupations: string[] = wd?.occupations || []
const influencedBy: string[] = wd?.influenced_by_ids || []
const birthPlace = wd?.birth_place || null
const deathPlace = wd?.death_place || null
const birthDate = wd?.birth_date ? wd.birth_date.slice(0, 4) : (artist.begin_year || null)
const deathDate = wd?.death_date ? wd.death_date.slice(0, 4) : (artist.end_year || null)

const displayName = artist.preferred_name
const dateRange = [birthDate, deathDate].filter(Boolean).join('–')
const placeLine = [birthPlace, deathPlace].filter(Boolean).join(' → ')

const pageTitle = `${displayName} — Artist Profile`
const pageDesc = bio || `${displayName}${dateRange ? ', ' + dateRange : ''}. ${works?.length || 0} works in the NGA collection.`

const canonicalSlug = artist.slug || nameToSlug(displayName)

// JSON-LD Person schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: displayName,
  ...(birthDate && { birthDate }),
  ...(deathDate && { deathDate }),
  ...(birthPlace && { birthPlace }),
  ...(artist.nationality && { nationality: artist.nationality }),
  ...(portrait && { image: portrait }),
  ...(artist.wikidata_id && { sameAs: `https://www.wikidata.org/wiki/${artist.wikidata_id}` }),
}
---

<PublicShell title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

<style is:global>
  :root {
    --pc: #1C1810;
    --card: rgba(239,231,217,.04);
    --border: rgba(200,160,96,.2);
    --surface: rgba(239,231,217,.03);
    --text: #EFE7D9;
    --text2: rgba(239,231,217,.7);
    --text3: rgba(239,231,217,.4);
    --t1: #C8A060;
    --tglow: rgba(200,160,96,.08);
    --radius: 4px;
    --prata: 'Prata', Georgia, serif;
    --playfair: 'Playfair Display', Didot, Georgia, serif;
  }

  .ap-body { background: var(--pc); min-height: 100vh; }

  /* HERO */
  .ap-hero { position: relative; background: var(--pc); border-bottom: 1px solid var(--border); }
  .ap-hero-inner { max-width: 1100px; margin: 0 auto; padding: 80px 40px 48px; display: flex; gap: 48px; align-items: flex-start; }
  @media (max-width: 767px) { .ap-hero-inner { flex-direction: column; padding: 80px 16px 32px; gap: 24px; } }

  .ap-portrait { width: 220px; flex-shrink: 0; }
  @media (max-width: 767px) { .ap-portrait { width: 140px; } }
  .ap-portrait img { width: 100%; border-radius: 4px; display: block; border: 1px solid var(--border); }
  .ap-portrait-placeholder { width: 220px; height: 280px; background: var(--tglow); border: 1px solid var(--border); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-family: var(--playfair); font-style: italic; font-size: 64px; color: var(--t1); }
  @media (max-width: 767px) { .ap-portrait-placeholder { width: 140px; height: 180px; font-size: 40px; } }

  .ap-meta { flex: 1; padding-top: 8px; }
  .ap-eyebrow { font-family: var(--prata); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--t1); margin-bottom: 12px; }
  .ap-name { font-family: var(--playfair); font-size: clamp(32px, 5vw, 56px); font-weight: 400; font-style: italic; color: var(--text); line-height: 1.1; margin-bottom: 8px; }
  .ap-dates { font-family: var(--prata); font-size: 13px; color: var(--text3); margin-bottom: 16px; letter-spacing: 0.05em; }
  .ap-bio { font-family: var(--prata); font-size: 14px; color: var(--text2); line-height: 1.8; max-width: 600px; margin-bottom: 20px; }
  .ap-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
  .ap-tag { font-family: var(--prata); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 10px; border: 1px solid var(--border); border-radius: var(--radius); color: var(--text3); }
  .ap-tag-gold { border-color: rgba(200,160,96,.4); color: var(--t1); }
  .ap-links { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .ap-link { font-family: var(--prata); font-size: 11px; letter-spacing: 0.08em; color: var(--t1); text-decoration: none; }
  .ap-link:hover { text-decoration: underline; }

  /* SIGNATURE */
  .ap-sig { margin-top: 20px; display: inline-block; padding: 10px 16px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
  .ap-sig-label { font-family: var(--prata); font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; }
  .ap-sig img { max-height: 36px; max-width: 200px; object-fit: contain; filter: invert(1) opacity(0.65); display: block; }

  /* CONTENT */
  .ap-content { max-width: 1100px; margin: 0 auto; padding: 48px 40px; }
  @media (max-width: 767px) { .ap-content { padding: 32px 16px; } }

  .ap-section-label { font-family: var(--prata); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--t1); margin-bottom: 24px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }

  /* WORKS GRID */
  .ap-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 48px; }
  @media (max-width: 900px) { .ap-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .ap-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; } }

  .ap-work { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; cursor: pointer; transition: border-color .15s; text-decoration: none; display: block; }
  .ap-work:hover { border-color: rgba(200,160,96,.5); }
  .ap-work-img { width: 100%; aspect-ratio: 1; object-fit: cover; display: block; background: var(--surface); }
  .ap-work-img-placeholder { width: 100%; aspect-ratio: 1; background: var(--surface); display: flex; align-items: center; justify-content: center; color: var(--text3); font-size: 24px; }
  .ap-work-info { padding: 10px; }
  .ap-work-title { font-family: var(--playfair); font-size: 12px; font-style: italic; color: var(--text); line-height: 1.3; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ap-work-meta { font-family: var(--prata); font-size: 10px; color: var(--text3); }

  /* FACTS ROW */
  .ap-facts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 48px; }
  @media (max-width: 600px) { .ap-facts { grid-template-columns: 1fr; } }
  .ap-fact { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
  .ap-fact-label { font-family: var(--prata); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; }
  .ap-fact-val { font-family: var(--prata); font-size: 13px; color: var(--text2); line-height: 1.6; }

  /* INFLUENCED BY */
  .ap-influenced { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 48px; }
  .ap-influenced-name { font-family: var(--prata); font-size: 11px; color: var(--text2); padding: 6px 12px; border: 1px solid var(--border); border-radius: var(--radius); }
</style>

<div class="ap-body">
  <!-- HERO -->
  <div class="ap-hero">
    <div class="ap-hero-inner">
      <!-- PORTRAIT -->
      <div class="ap-portrait">
        {portrait
          ? <img src={portrait} alt={displayName} />
          : <div class="ap-portrait-placeholder">{(artist.last_name || displayName).charAt(0)}</div>
        }
        {signature && (
          <div class="ap-sig">
            <div class="ap-sig-label">Signature</div>
            <img src={signature} alt={`${displayName} signature`} />
          </div>
        )}
      </div>

      <!-- META -->
      <div class="ap-meta">
        <div class="ap-eyebrow">Artist</div>
        <h1 class="ap-name">{displayName}</h1>
        <div class="ap-dates">
          {[artist.nationality, dateRange, placeLine].filter(Boolean).join(' · ')}
        </div>
        {bio && <p class="ap-bio">{bio}</p>}
        <div class="ap-tags">
          {movements.map(m => <span class="ap-tag ap-tag-gold">{m}</span>)}
          {occupations.slice(0, 3).map(o => <span class="ap-tag">{o}</span>)}
        </div>
        <div class="ap-links">
          
          
          <a class="ap-link" href="/categories/collections">Collections</a>
          <span style="color:var(--text3);margin:0 6px">/</span>
          <span style="color:var(--text2);font-family:var(--prata);font-size:11px">{displayName}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="ap-content">

    <!-- FACTS -->
    {(birthDate || birthPlace || artist.constituent_type) && (
      <div class="ap-facts">
        {(birthDate || deathDate) && (
          <div class="ap-fact">
            <div class="ap-fact-label">Dates</div>
            <div class="ap-fact-val">{birthDate || '?'} – {deathDate || 'present'}</div>
          </div>
        )}
        {birthPlace && (
          <div class="ap-fact">
            <div class="ap-fact-label">Born</div>
            <div class="ap-fact-val">{birthPlace}</div>
          </div>
        )}
        {deathPlace && (
          <div class="ap-fact">
            <div class="ap-fact-label">Died</div>
            <div class="ap-fact-val">{deathPlace}</div>
          </div>
        )}
        {artist.constituent_type && artist.constituent_type !== 'individual' && (
          <div class="ap-fact">
            <div class="ap-fact-label">Type</div>
            <div class="ap-fact-val">{artist.constituent_type}</div>
          </div>
        )}
      </div>
    )}

    <!-- INFLUENCED BY -->
    {influencedBy.length > 0 && (
      <div style="margin-bottom:48px">
        <div class="ap-section-label">Influenced by</div>
        <div class="ap-influenced">
          {influencedBy.map(name => <span class="ap-influenced-name">{name}</span>)}
        </div>
      </div>
    )}

    <!-- WORKS IN COLLECTION -->
    {works && works.length > 0 && (
      <div>
        <div class="ap-section-label">Works in collection ({works.length})</div>
        <div class="ap-grid">
          {works.map(w => (
            <a class="ap-work" href={`/collection/${w.accession_num.replace(/\./g, '-')}?from=${canonicalSlug}`}>
              {w.nga_thumb_url
                ? <img class="ap-work-img" src={w.nga_thumb_url} alt={w.title} loading="lazy" />
                : <div class="ap-work-img-placeholder">◻</div>
              }
              <div class="ap-work-info">
                <div class="ap-work-title">{w.title}</div>
                <div class="ap-work-meta">{[w.display_date, w.classification].filter(Boolean).join(' · ')}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>
</div>
</PublicShell>
