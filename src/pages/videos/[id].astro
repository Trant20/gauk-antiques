---
import PublicShell from '../../layouts/PublicShell.astro'
import { supabase } from '../../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
const { id } = Astro.params

if (!id) return Astro.redirect('/videos')

// Load the video
const { data: video } = await supabase
  .from('external_articles')
  .select('id, title, url, video_id, thumbnail_url, published_at, source_name, categories, publisher_id, summary')
  .eq('id', id)
  .eq('content_type', 'video')
  .single()

if (!video || !video.video_id) return Astro.redirect('/videos')

// Derive primary category before parallel queries
const primaryCategory = video.categories?.[0] || null

// Run all independent queries in parallel
const [
  { data: channel },
  { data: channelVideos },
  { data: relatedVideos },
] = await Promise.all([
  video.publisher_id
    ? supabase.from('publishers').select('id, name, slug, logo_url, description, site_url').eq('id', video.publisher_id).single()
    : Promise.resolve({ data: null }),
  video.publisher_id
    ? supabase.from('external_articles').select('id, title, video_id, thumbnail_url, source_name, published_at').eq('site_id', SITE_ID).eq('content_type', 'video').eq('publisher_id', video.publisher_id).neq('id', id).order('published_at', { ascending: false }).limit(6)
    : Promise.resolve({ data: [] }),
  primaryCategory
    ? supabase.from('external_articles').select('id, title, video_id, thumbnail_url, source_name, published_at').eq('site_id', SITE_ID).eq('content_type', 'video').contains('categories', [primaryCategory]).neq('id', id).neq('publisher_id', video.publisher_id || '').order('published_at', { ascending: false }).limit(6)
    : Promise.resolve({ data: [] }),
])

function slugify(s: string): string {
  return s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}

function decodeHtml(str: string): string {
  if (!str) return ''
  return str
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&apos;/g, "'")
    .replace(/&#x27;/g, "'")
    .replace(/&ndash;/g, '–')
    .replace(/&mdash;/g, '—')
    .replace(/&hellip;/g, '…')
    .replace(/&#\d+;/g, (match) => {
      const num = parseInt(match.slice(2, -1))
      return String.fromCharCode(num)
    })
}

const videoTitle = decodeHtml(video.title)

const R2 = 'https://pub-c3f96dd742f540188b92599aeed807c7.r2.dev'

// Run category-dependent queries in parallel
const [
  { data: catArticles },
  { data: catIdentifications },
] = await Promise.all([
  primaryCategory
    ? supabase.from('articles').select('id, title, slug, excerpt, image_url, category').eq('site_id', SITE_ID).eq('category', primaryCategory).eq('published', true).order('published_at', { ascending: false }).limit(4)
    : Promise.resolve({ data: [] }),
  primaryCategory
    ? supabase.from('identifications').select('id, image_key, result_json, created_at').eq('site_id', SITE_ID).eq('category', primaryCategory).not('image_key', 'is', null).order('created_at', { ascending: false }).limit(4)
    : Promise.resolve({ data: [] }),
])

const pubDate = video.published_at
  ? new Date(video.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null
---
<PublicShell
  title={`${videoTitle} — GAUK Antiques`}
  description={video.summary || `${videoTitle} — watch on GAUK Antiques.`}
  ogImage={video.thumbnail_url || ''}
>
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": videoTitle,
  "description": video.summary || video.title,
  "thumbnailUrl": video.thumbnail_url || '',
  "uploadDate": video.published_at || '',
  "embedUrl": `https://www.youtube.com/embed/${video.video_id}`,
  "url": `https://gaukantiques.com/videos/${id}`,
  "publisher": { "@type": "Organization", "name": "GAUK Antiques", "url": "https://gaukantiques.com" }
})} />

<style is:global>
  .vid-pg { background: #EFE7D9; min-height: 100vh; padding-top: 64px; }

  /* LAYOUT */
  .vid-pg-inner { max-width: 1200px; margin: 0 auto; padding: 40px 32px 80px; display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start; }
  @media (max-width: 960px) { .vid-pg-inner { grid-template-columns: 1fr; gap: 32px; } }
  @media (max-width: 767px) { .vid-pg-inner { padding: 24px 16px 80px; } }

  /* EMBED */
  .vid-embed-wrap { position: relative; aspect-ratio: 16/9; background: #1C1810; }
  .vid-embed-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }

  /* TITLE + META */
  .vid-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(20px,3vw,28px); font-weight: 400; font-style: italic; color: #1C1810; line-height: 1.3; margin: 20px 0 12px; }
  .vid-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid #C4B49E; margin-bottom: 20px; }
  .vid-date { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; letter-spacing: 1px; }
  .vid-cats { display: flex; gap: 6px; flex-wrap: wrap; }
  .vid-cat-tag { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #7A5C20; text-decoration: none; border: 1px solid #C4B49E; padding: 4px 10px; transition: border-color .15s, color .15s; }
  .vid-cat-tag:hover { border-color: #7A5C20; color: #1C1810; }

  /* EXCERPT */
  .vid-excerpt { font-family: 'Prata', Georgia, serif; font-size: 15px; color: #5C5040; line-height: 1.9; margin-bottom: 24px; }

  /* CHANNEL CARD */
  .vid-channel { background: #E6DCCB; border: 1px solid #C4B49E; padding: 20px; margin-bottom: 32px; }
  .vid-channel-inner { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
  .vid-channel-logo { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; background: #C4B49E; flex-shrink: 0; }
  .vid-channel-logo-placeholder { width: 48px; height: 48px; border-radius: 50%; background: #7A5C20; display: flex; align-items: center; justify-content: center; font-family: 'Playfair Display', serif; font-size: 20px; font-style: italic; color: #EFE7D9; flex-shrink: 0; }
  .vid-channel-name { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 18px; font-style: italic; color: #1C1810; margin-bottom: 2px; }
  .vid-channel-desc { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #8A7A66; line-height: 1.6; margin-bottom: 14px; }
  .vid-channel-follow { display: block; width: 100%; padding: 11px; background: #1C1810; border: none; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #EFE7D9; text-align: center; text-decoration: none; cursor: pointer; transition: background .2s; box-sizing: border-box; }
  .vid-channel-follow:hover { background: #2C2418; }
  .vid-channel-follow.following { background: transparent; color: #C8A060; border: 1px solid #C8A060; padding: 10px; }
  .vid-channel-follow.loading { opacity: 0.6; cursor: default; }
  .vid-channel-follow-signin { display: block; width: 100%; padding: 11px; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: rgba(239,231,217,.5); text-align: center; text-decoration: none; border: 1px solid rgba(239,231,217,.2); box-sizing: border-box; }

  /* SIDE RAIL VIDEO LIST */
  .vid-rail-section { margin-bottom: 32px; }
  .vid-rail-cap { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #5C5040; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
  .vid-rail-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .vid-rail-list { display: flex; flex-direction: column; gap: 1px; background: #C4B49E; }
  .vid-rail-item { background: #EFE7D9; display: flex; gap: 12px; padding: 10px; text-decoration: none; transition: background .15s; cursor: pointer; }
  .vid-rail-item:hover { background: #E6DCCB; }
  .vid-rail-thumb { width: 100px; aspect-ratio: 16/9; object-fit: cover; background: #E6DCCB; flex-shrink: 0; position: relative; overflow: hidden; }
  .vid-rail-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vid-rail-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.25); }
  .vid-rail-play-icon { width: 28px; height: 28px; background: rgba(255,255,255,.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .vid-rail-source { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: #8A7A66; margin-bottom: 3px; }
  .vid-rail-title { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #1C1810; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  /* BREADCRUMB */
  .vid-breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .vid-bc-link { font-family: 'Prata', Georgia, serif; font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; color: #7A5C20; text-decoration: none; }
  .vid-bc-link:hover { color: #1C1810; }
  .vid-bc-sep { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #C4B49E; }
  .vid-bc-cur { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #8A7A66; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }


  /* CONTENT SECTIONS */
  .vid-cs { padding: 48px 0; border-top: 1px solid #C4B49E; }
  .vid-cs-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .vid-cs-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .vid-cs-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(20px,3vw,28px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 24px; }

  /* ARTICLES */
  .vid-story-stack { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #C4B49E; }
  @media (max-width: 600px) { .vid-story-stack { grid-template-columns: 1fr; } }
  .vid-story-card { background: #EFE7D9; padding: 20px; display: flex; gap: 14px; text-decoration: none; color: #1C1810; transition: background .15s; }
  .vid-story-card:hover { background: #E6DCCB; }
  .vid-story-thumb { width: 72px; height: 72px; object-fit: cover; flex-shrink: 0; background: #E6DCCB; }
  .vid-story-cat { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #7A5C20; margin-bottom: 5px; }
  .vid-story-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 16px; font-style: italic; color: #1C1810; line-height: 1.3; }

  /* RECENT IDS */
  .vid-id-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 600px) { .vid-id-strip { grid-template-columns: repeat(2, 1fr); } }
  .vid-id-card { background: #EFE7D9; }
  .vid-id-img { width: 100%; aspect-ratio: 1/1; overflow: hidden; position: relative; background: #E6DCCB; }
  .vid-id-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; }
  .vid-id-body { padding: 10px; border-top: 1px solid #C4B49E; }
  .vid-id-maker { font-family: 'Prata', Georgia, serif; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: #7A5C20; margin-bottom: 2px; }
  .vid-id-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 12px; font-style: italic; color: #1C1810; margin-bottom: 3px; line-height: 1.3; }
  .vid-id-value { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 12px; color: #7A5C20; }

  /* IDENTIFY INTERRUPT */
  .vid-interrupt { background: #1C1810; padding: 56px 32px; text-align: center; margin-top: 48px; }
  .vid-interrupt-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #C8A060; margin-bottom: 14px; }
  .vid-interrupt-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(24px,4vw,40px); font-style: italic; color: #EFE7D9; margin-bottom: 12px; }
  .vid-interrupt-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: rgba(239,231,217,.6); line-height: 1.8; margin-bottom: 28px; max-width: 440px; margin-left: auto; margin-right: auto; }
  .vid-interrupt-btn { display: inline-block; background: #B8860B; color: #fff; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; padding: 16px 40px; text-decoration: none; transition: background .2s; }
  .vid-interrupt-btn:hover { background: #9A7009; }
  @media (max-width: 767px) { .vid-interrupt { padding: 40px 16px; } }

  /* MODAL for rail clicks */
  .yt-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; padding: 20px; }
  .yt-modal-overlay.open { display: flex; }
  .yt-modal { position: relative; width: 100%; max-width: 960px; aspect-ratio: 16/9; background: #000; }
  .yt-modal iframe { width: 100%; height: 100%; border: none; }
  .yt-modal-close { position: absolute; top: -44px; right: 0; background: none; border: none; color: #fff; font-size: 28px; cursor: pointer; line-height: 1; padding: 4px 8px; opacity: .7; transition: opacity .2s; }
  .yt-modal-close:hover { opacity: 1; }
</style>

<div class="vid-pg">
  <div class="vid-pg-inner">

    <!-- LEFT COLUMN -->
    <div>
      <!-- BREADCRUMB -->
      <nav class="vid-breadcrumb">
        <a href="/videos" class="vid-bc-link">Videos</a>
        {primaryCategory && <>
          <span class="vid-bc-sep">›</span>
          <a href={`/videos?category=${slugify(primaryCategory)}`} class="vid-bc-link">{primaryCategory}</a>
        </>}
        <span class="vid-bc-sep">›</span>
        <span class="vid-bc-cur">{videoTitle}</span>
      </nav>

      <!-- EMBED -->
      <div class="vid-embed-wrap">
        <iframe
          src={`https://www.youtube.com/embed/${video.video_id}?rel=0&modestbranding=1`}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>

      <!-- TITLE -->
      <h1 class="vid-title">{videoTitle}</h1>

      <!-- META -->
      <div class="vid-meta">
        {pubDate && <span class="vid-date">{pubDate}</span>}
        {video.categories && video.categories.length > 0 && (
          <div class="vid-cats">
            {video.categories.map((cat: string) => (
              <a href={`/videos?category=${slugify(cat)}`} class="vid-cat-tag">{cat}</a>
            ))}
          </div>
        )}
      </div>

      <!-- EXCERPT -->
      {video.summary && <p class="vid-excerpt">{video.summary}</p>}


  <!-- ESSENTIAL READING -->
  {catArticles && catArticles.length > 0 && (
    <div class="vid-cs">
      <div class="vid-cs-cap">From the archive</div>
      <div class="vid-cs-title">Essential reading</div>
      <div class="vid-story-stack">
        {catArticles.map(a => (
          <a href={`/learn/${a.slug}`} class="vid-story-card">
            {a.image_url
              ? <img class="vid-story-thumb" src={a.image_url} alt={a.title} loading="lazy" />
              : <div class="vid-story-thumb"></div>
            }
            <div>
              <div class="vid-story-cat">{a.category}</div>
              <div class="vid-story-title">{a.title}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- RECENTLY IDENTIFIED -->
  {catIdentifications && catIdentifications.length > 0 && (
    <div class="vid-cs">
      <div class="vid-cs-cap">Community</div>
      <div class="vid-cs-title">Recently identified</div>
      <div class="vid-id-strip">
        {catIdentifications.map(item => {
          const r = item.result_json || {}
          return (
            <div class="vid-id-card">
              <div class="vid-id-img">
                {item.image_key && <img src={`${R2}/${item.image_key}`} alt={r.subcategory || ''} loading="lazy" />}
              </div>
              <div class="vid-id-body">
                {r.maker && <div class="vid-id-maker">{r.maker}</div>}
                <div class="vid-id-title">{r.subcategory || 'Antique Item'}</div>
                <div class="vid-id-value">£{(r.value_range_low || 0).toLocaleString()} – £{(r.value_range_high || 0).toLocaleString()}</div>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  )}

    </div>

    <!-- RIGHT RAIL -->
    <div>
      <!-- CHANNEL CARD -->
      {channel && (
        <div class="vid-channel">
          <div class="vid-channel-inner">
            {channel.logo_url
              ? <img class="vid-channel-logo" src={channel.logo_url} alt={channel.name} />
              : <div class="vid-channel-logo-placeholder">{channel.name.charAt(0)}</div>
            }
            <div>
              <div class="vid-channel-name">{channel.name}</div>
            </div>
          </div>
          {channel.description && <p class="vid-channel-desc">{channel.description}</p>}
          <a href={`/channels/${channel.slug}`} class="vid-channel-follow" style="margin-bottom:8px;">Visit Channel →</a>
          <button class="vid-channel-follow loading" id="vid-follow-btn" data-publisher-id={channel.id}>Follow Channel</button>
          <a href="/auth/signin" class="vid-channel-follow-signin" id="vid-follow-signin" style="display:none">Sign in to Follow</a>
        </div>
      )}

      <!-- MORE FROM CHANNEL -->
      {channelVideos && channelVideos.length > 0 && (
        <div class="vid-rail-section">
          <div class="vid-rail-cap">More from {channel?.name || video.source_name}</div>
          <div class="vid-rail-list">
            {channelVideos.map(v => (
              <a href={`/videos/${v.id}`} class="vid-rail-item">
                <div class="vid-rail-thumb">
                  {v.thumbnail_url
                    ? <img src={v.thumbnail_url} alt={v.title.replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&')} loading="lazy" />
                    : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
                  }
                  <div class="vid-rail-play">
                    <div class="vid-rail-play-icon">
                      <svg width="10" height="10" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                    </div>
                  </div>
                </div>
                <div>
                  {v.source_name && <div class="vid-rail-source">{v.source_name}</div>}
                  <div class="vid-rail-title" set:html={v.title.replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')}></div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- RELATED VIDEOS -->
      {relatedVideos && relatedVideos.length > 0 && (
        <div class="vid-rail-section">
          <div class="vid-rail-cap">Related {primaryCategory} videos</div>
          <div class="vid-rail-list">
            {relatedVideos.map(v => (
              <a href={`/videos/${v.id}`} class="vid-rail-item">
                <div class="vid-rail-thumb">
                  {v.thumbnail_url
                    ? <img src={v.thumbnail_url} alt={v.title.replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&')} loading="lazy" />
                    : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
                  }
                  <div class="vid-rail-play">
                    <div class="vid-rail-play-icon">
                      <svg width="10" height="10" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                    </div>
                  </div>
                </div>
                <div>
                  {v.source_name && <div class="vid-rail-source">{v.source_name}</div>}
                  <div class="vid-rail-title" set:html={v.title.replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')}></div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

  </div>
</div>


<!-- IDENTIFY INTERRUPT -->
<div class="vid-interrupt">
  <div class="vid-interrupt-eyebrow">Free Identification</div>
  <div class="vid-interrupt-title">{primaryCategory ? `What is your ${primaryCategory.toLowerCase()} worth?` : 'What is your antique worth?'}</div>
  <div class="vid-interrupt-sub">Upload a photograph and our AI identifies maker, period, condition and estimated value in seconds.</div>
  <a href="/" class="vid-interrupt-btn">Identify Your Piece Free</a>
</div>

<!-- MODAL (unused on this page but kept for consistency) -->
<div class="yt-modal-overlay" id="yt-modal-overlay">
  <div class="yt-modal" id="yt-modal">
    <button class="yt-modal-close" id="yt-modal-close">&#x2715;</button>
    <iframe id="yt-modal-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
  </div>
</div>

<script>
  import { supabase } from '../../lib/supabase-browser'

  const btn = document.getElementById('vid-follow-btn') as HTMLButtonElement
  const signinLink = document.getElementById('vid-follow-signin') as HTMLAnchorElement
  const publisherId = btn?.dataset.publisherId

  async function initFollow() {
    const { data: { session } } = await supabase.auth.getSession()
    if (!session) {
      btn.style.display = 'none'
      signinLink.style.display = 'block'
      return
    }
    btn.classList.remove('loading')
    const res = await fetch(`/api/follow?publisher_id=${publisherId}`, {
      headers: { Authorization: `Bearer ${session.access_token}` }
    })
    const json = await res.json()
    setFollowState(json.following)
  }

  function setFollowState(following: boolean) {
    if (following) {
      btn.textContent = 'Following ✓'
      btn.classList.add('following')
    } else {
      btn.textContent = 'Follow Channel'
      btn.classList.remove('following')
    }
  }

  btn?.addEventListener('click', async () => {
    const { data: { session } } = await supabase.auth.getSession()
    if (!session) { window.location.href = '/auth/signin'; return }
    btn.classList.add('loading')
    const isFollowing = btn.classList.contains('following')
    const res = await fetch('/api/follow', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session.access_token}` },
      body: JSON.stringify({ publisher_id: publisherId, action: isFollowing ? 'unfollow' : 'follow' })
    })
    const json = await res.json()
    btn.classList.remove('loading')
    setFollowState(json.following)
  })

  initFollow()
</script>

<script>
  const overlay = document.getElementById('yt-modal-overlay') as HTMLElement
  const iframe = document.getElementById('yt-modal-iframe') as HTMLIFrameElement
  const closeBtn = document.getElementById('yt-modal-close') as HTMLButtonElement

  function closeModal() {
    overlay.classList.remove('open')
    iframe.src = ''
    document.body.style.overflow = ''
  }

  closeBtn.addEventListener('click', closeModal)
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal() })
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal() })
</script>
</PublicShell>
