---
import PublicShell from '../../layouts/PublicShell.astro'
import { supabase } from '../../lib/supabase'

const { slug } = Astro.params
if (!slug) return Astro.redirect('/categories/collections')

const { data: obj } = await supabase
  .from('gauk_objects')
  .select('gauk_id,title,slug,display_date,date_from,date_to,medium,dimensions,classification,image_url,thumb_url,provenance,credit_line,attribution,external_ids,properties,sources')
  .eq('slug', slug)
  .single()

if (!obj) return Astro.redirect('/categories/collections', 302)

// Artist via relations
const { data: rels } = await supabase
  .from('gauk_entity_relations')
  .select('to_gauk_id')
  .eq('from_gauk_id', obj.gauk_id)
  .eq('relation_type', 'made_by')
  .limit(3)

const artistIds = (rels || []).map(r => r.to_gauk_id)
const { data: artists } = artistIds.length
  ? await supabase
      .from('gauk_artists')
      .select('gauk_id,preferred_name,nationality,birth_year,death_year,portrait_url,slug,external_ids')
      .in('gauk_id', artistIds)
  : { data: [] }

const primaryArtist = artists?.[0] || null
const heroImage  = obj.image_url || null
const thumbImage = obj.thumb_url || null
const accession  = obj.external_ids?.nga_accession || null
const wikidata_id = obj.external_ids?.wikidata || null
const attribution_source = obj.properties?.attribution_source || null
const attribution_url    = obj.properties?.attribution_url || null

const pageTitle = `${obj.title}${obj.attribution ? ' — ' + obj.attribution : ''}`
const pageDesc  = [obj.medium, obj.display_date, obj.classification].filter(Boolean).join(', ')

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtwork',
  name: obj.title,
  ...(obj.attribution && { creator: { '@type': 'Person', name: obj.attribution } }),
  ...(obj.medium && { artMedium: obj.medium }),
  ...(obj.classification && { artform: obj.classification }),
  ...(obj.display_date && { dateCreated: obj.display_date }),
  ...(thumbImage && { image: thumbImage }),
  ...(obj.credit_line && { creditText: obj.credit_line }),
  ...(wikidata_id && { sameAs: `https://www.wikidata.org/wiki/${wikidata_id}` }),
}
---
<PublicShell title={pageTitle} description={pageDesc}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

<style is:global>
  :root {
    --pc: #1C1810; --card: rgba(239,231,217,.04); --border: rgba(200,160,96,.2);
    --surface: rgba(239,231,217,.03); --text: #EFE7D9; --text2: rgba(239,231,217,.7);
    --text3: rgba(239,231,217,.4); --t1: #C8A060; --tglow: rgba(200,160,96,.08);
    --radius: 4px; --prata: 'Prata', Georgia, serif; --playfair: 'Playfair Display', Didot, Georgia, serif;
  }
  .op-body { background: var(--pc); min-height: 100vh; }
  .op-hero { background: var(--pc); border-bottom: 1px solid var(--border); }
  .op-hero-inner { max-width: 1100px; margin: 0 auto; padding: 80px 40px 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  @media (max-width: 767px) { .op-hero-inner { grid-template-columns: 1fr; padding: 80px 16px 32px; gap: 24px; } }
  .op-image-wrap { position: relative; }
  .op-image { width: 100%; max-height: 520px; object-fit: contain; border-radius: var(--radius); border: 1px solid var(--border); display: block; background: var(--surface); cursor: zoom-in; }
  .op-image-placeholder { width: 100%; aspect-ratio: 4/5; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; color: var(--text3); font-size: 48px; }
  .op-meta { padding-top: 8px; }
  .op-eyebrow { font-family: var(--prata); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--t1); margin-bottom: 12px; }
  .op-title { font-family: var(--playfair); font-size: clamp(24px,4vw,40px); font-weight: 400; font-style: italic; color: var(--text); line-height: 1.2; margin-bottom: 8px; }
  .op-date { font-family: var(--prata); font-size: 12px; color: var(--text3); margin-bottom: 20px; letter-spacing: 0.05em; }
  .op-field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
  .op-field-label { font-family: var(--prata); font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
  .op-field-val { font-family: var(--prata); font-size: 12px; color: var(--text2); line-height: 1.5; }
  .op-links { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-top: 20px; }
  .op-link { font-family: var(--prata); font-size: 11px; letter-spacing: 0.08em; color: var(--t1); text-decoration: none; }
  .op-link:hover { text-decoration: underline; }
  .op-artist-card { display: flex; gap: 12px; align-items: center; padding: 12px; background: var(--tglow); border: 1px solid rgba(200,160,96,.3); border-radius: var(--radius); margin-bottom: 20px; text-decoration: none; transition: border-color .15s; }
  .op-artist-card:hover { border-color: var(--t1); }
  .op-artist-avatar { width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0; overflow: hidden; background: var(--surface); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-family: var(--playfair); font-style: italic; font-size: 18px; color: var(--t1); }
  .op-artist-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .op-artist-name { font-family: var(--playfair); font-size: 14px; font-style: italic; color: var(--text); }
  .op-artist-meta { font-family: var(--prata); font-size: 10px; color: var(--text3); margin-top: 2px; }
  .op-content { max-width: 1100px; margin: 0 auto; padding: 48px 40px; }
  @media (max-width: 767px) { .op-content { padding: 32px 16px; } }
  .op-section-label { font-family: var(--prata); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--t1); margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
  .op-section { margin-bottom: 40px; }
  .op-text-block { font-family: var(--prata); font-size: 12px; color: var(--text2); line-height: 1.7; padding: 12px 14px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 8px; }
  .op-attribution { font-family: var(--prata); font-size: 11px; color: var(--text3); margin-top: 32px; padding-top: 16px; border-top: 1px solid var(--border); }
</style>

<div class="op-body">
  <div class="op-hero">
    <div class="op-hero-inner">
      <div class="op-image-wrap">
        {heroImage
          ? <img id="op-hero-img" class="op-image" src={heroImage} alt={obj.title} />
          : <div class="op-image-placeholder">◻</div>}
      </div>
      <div class="op-meta">
        <div class="op-eyebrow">{obj.classification || 'Work'}</div>
        <h1 class="op-title">{obj.title}</h1>
        {primaryArtist ? (
          <a class="op-artist-card" href={`/artists/${primaryArtist.slug}`}>
            <div class="op-artist-avatar">
              {primaryArtist.portrait_url
                ? <img src={primaryArtist.portrait_url} alt={primaryArtist.preferred_name} />
                : (primaryArtist.preferred_name || '?').charAt(0)}
            </div>
            <div>
              <div class="op-artist-name">{primaryArtist.preferred_name}</div>
              <div class="op-artist-meta">{[primaryArtist.nationality, [primaryArtist.birth_year, primaryArtist.death_year].filter(Boolean).join('–')].filter(Boolean).join(' · ')}</div>
            </div>
          </a>
        ) : obj.attribution ? (
          <div style="font-family:'Playfair Display',Georgia,serif;font-size:14px;font-style:italic;color:var(--t1);margin-bottom:16px">{obj.attribution}</div>
        ) : null}
        {obj.display_date && <div class="op-date">{obj.display_date}</div>}
        <div class="op-field-grid">
          {obj.medium && <div><div class="op-field-label">Medium</div><div class="op-field-val">{obj.medium}</div></div>}
          {obj.dimensions && <div><div class="op-field-label">Dimensions</div><div class="op-field-val">{obj.dimensions}</div></div>}
          {accession && <div><div class="op-field-label">Accession</div><div class="op-field-val">{accession}</div></div>}
          {obj.classification && <div><div class="op-field-label">Classification</div><div class="op-field-val">{obj.classification}</div></div>}
        </div>
        {obj.credit_line && <div style="margin-bottom:16px"><div class="op-field-label">Credit</div><div class="op-field-val">{obj.credit_line}</div></div>}
        <div class="op-links">
          <a class="op-link" href="/categories/collections">← Collections</a>
          {wikidata_id && <a class="op-link" href={`https://www.wikidata.org/wiki/${wikidata_id}`} target="_blank" rel="noopener">Wikidata →</a>}
        </div>
      </div>
    </div>
  </div>

  <div class="op-content">
    {obj.provenance && (
      <div class="op-section">
        <div class="op-section-label">Provenance</div>
        {obj.provenance.split(";").map(s => s.trim()).filter(Boolean).map(s => (
          <div class="op-text-block">{s};</div>
        ))}
      </div>
    )}
    {attribution_source && (
      <div class="op-attribution">
        {attribution_url
          ? <a href={attribution_url} target="_blank" rel="noopener" style="color:var(--text3);text-decoration:none">{attribution_source}</a>
          : attribution_source}
      </div>
    )}
  </div>
</div>

<script is:inline>
(function(){
  const img = document.getElementById('op-hero-img')
  if (!img) return
  let zoomed = false
  img.addEventListener('click', () => {
    zoomed = !zoomed
    img.style.transform = zoomed ? 'scale(1.8)' : ''
    img.style.cursor = zoomed ? 'zoom-out' : 'zoom-in'
    img.style.zIndex = zoomed ? '10' : ''
    img.style.position = zoomed ? 'relative' : ''
  })
})()
</script>
</PublicShell>
