---
import PublicShell from '../../layouts/PublicShell.astro'
import   {(() => {
    const raw = article.gallery ? (typeof article.gallery === 'string' ? JSON.parse(article.gallery) : article.gallery) : []
    const items = raw.map((i) => typeof i === 'string' ? {url: i, caption: ''} : {url: i.url || '', caption: i.caption || ''}).filter((i) => i.url)
    if (!items.length) return null
    if (items.length === 1) return (
      <div class="art-gallery-single" id="art-gallery" data-items={JSON.stringify(items)}>
        <img src={items[0].url} alt={items[0].caption || article.title} data-idx="0" class="gallery-trigger" style="cursor:pointer" />
      </div>
    )
    return (
      <div class="art-gallery" id="art-gallery" data-items={JSON.stringify(items)}>
        {items.map((item, i) => (
          <div class="art-gallery-item">
            <img src={item.url} alt={item.caption || article.title} loading="lazy" data-idx={String(i)} class="gallery-trigger" />
            {item.caption && <div class="art-gallery-caption">{item.caption}</div>}
          </div>
        ))}
      </div>
    )
  })()}

  <!-- LIGHTBOX -->
  <div class="lb" id="lb" role="dialog" aria-modal="true">
    <button class="lb-close" id="lb-close" aria-label="Close">&times;</button>
    <div class="lb-main">
      <button class="lb-prev" id="lb-prev" aria-label="Previous">&#8249;</button>
      <div class="lb-img-wrap" id="lb-img-wrap">
        <img id="lb-img" src="" alt="" />
      </div>
      <button class="lb-next" id="lb-next" aria-label="Next">&#8250;</button>
    </div>
    <div class="lb-caption" id="lb-caption"></div>
    <div class="lb-counter" id="lb-counter"></div>
    <div class="lb-thumbs" id="lb-thumbs"></div>
  </div>

  <script is:inline>
    (function() {
      var _items = [];
      var _idx = 0;

      function lbRender() {
        var item = _items[_idx];
        var img = document.getElementById('lb-img');
        img.src = item.url;
        img.alt = item.caption || '';
        img.classList.remove('zoomed');
        document.getElementById('lb-caption').textContent = item.caption || '';
        document.getElementById('lb-counter').textContent = (_idx + 1) + ' / ' + _items.length;
        var thumbsEl = document.getElementById('lb-thumbs');
        thumbsEl.innerHTML = '';
        _items.forEach(function(t, i) {
          var th = document.createElement('img');
          th.className = 'lb-thumb' + (i === _idx ? ' active' : '');
          th.src = t.url;
          th.alt = '';
          th.setAttribute('data-thumb-idx', String(i));
          thumbsEl.appendChild(th);
        });
      }

      function lbOpen(i, items) {
        _items = items;
        _idx = i;
        lbRender();
        document.getElementById('lb').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function lbClose() {
        document.getElementById('lb').classList.remove('open');
        document.body.style.overflow = '';
      }

      function lbNav(dir) {
        _idx = (_idx + dir + _items.length) % _items.length;
        lbRender();
      }

      // Gallery click — open lightbox
      document.addEventListener('click', function(e) {
        // Gallery image trigger
        var trigger = e.target.closest('.gallery-trigger');
        if (trigger) {
          var gallery = document.getElementById('art-gallery');
          if (!gallery) return;
          var items = JSON.parse(gallery.getAttribute('data-items') || '[]');
          var idx = parseInt(trigger.getAttribute('data-idx') || '0', 10);
          lbOpen(idx, items);
          return;
        }
        // Lightbox close button
        if (e.target.id === 'lb-close' || e.target === document.getElementById('lb')) { lbClose(); return; }
        // Lightbox prev/next
        if (e.target.id === 'lb-prev') { lbNav(-1); return; }
        if (e.target.id === 'lb-next') { lbNav(1); return; }
        // Zoom on main image
        if (e.target.id === 'lb-img') { e.target.classList.toggle('zoomed'); return; }
        // Thumbnail click
        var thumb = e.target.closest('[data-thumb-idx]');
        if (thumb) {
          _idx = parseInt(thumb.getAttribute('data-thumb-idx'), 10);
          lbRender();
          return;
        }
      });

      // Keyboard
      document.addEventListener('keydown', function(e) {
        var lb = document.getElementById('lb');
        if (!lb || !lb.classList.contains('open')) return;
        if (e.key === 'ArrowRight') lbNav(1);
        if (e.key === 'ArrowLeft') lbNav(-1);
        if (e.key === 'Escape') lbClose();
      });

      // Touch swipe
      var _tx = 0;
      document.addEventListener('touchstart', function(e) {
        if (document.getElementById('lb').classList.contains('open')) _tx = e.touches[0].clientX;
      }, {passive: true});
      document.addEventListener('touchend', function(e) {
        if (!document.getElementById('lb').classList.contains('open')) return;
        var diff = _tx - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) lbNav(diff > 0 ? 1 : -1);
      });
    })();
  </script>

  <div class="art-body" set:html={
    article.body.includes('<p>') || article.body.includes('<strong>') || article.body.includes('<ul>')
      ? article.body
      : article.body.split('\n\n').filter((p: string) => p.trim()).map((p: string) => `<p>${p.trim()}</p>`).join('')
  } />

  <!-- IDENTIFY CTA -->
  <div class="art-cta">
    <div class="art-cta-eye">Free Identification</div>
    <div class="art-cta-title">Have a piece to identify?</div>
    <div class="art-cta-sub">Upload a photograph — our AI identifies maker, period, condition and estimated value in seconds.</div>
    <a href="/" class="art-cta-btn">Identify Free →</a>
  </div>

  <!-- RELATED -->
  {related && related.length > 0 && (
    <div>
      <div class="art-related-title">More from {article.category}</div>
      <div class="art-related-grid">
        {related.map(r => (
          <a href={`/learn/${r.slug}`} class="art-related-card">
            {r.image_url
              ? <img class="art-related-img" src={r.image_url} alt={r.title} loading="lazy" />
              : <div class="art-related-img-placeholder"></div>
            }
            <div class="art-related-body">
              <div class="art-related-cat">{r.category}</div>
              <div class="art-related-t">{r.title}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</div>
</PublicShell>
