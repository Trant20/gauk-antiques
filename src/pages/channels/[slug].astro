---
import PublicShell from '../../layouts/PublicShell.astro'
import { supabase } from '../../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
const { slug } = Astro.params

if (!slug) return Astro.redirect('/videos')

const { data: channel } = await supabase
  .from('publishers')
  .select('id, name, slug, logo_url, description, site_url, has_youtube, default_category')
  .eq('slug', slug)
  .eq('has_youtube', true)
  .single()

if (!channel) return Astro.redirect('/videos')

// Channel videos
const { data: videos, count } = await supabase
  .from('external_articles')
  .select('id, title, video_id, thumbnail_url, published_at, source_name, categories', { count: 'exact' })
  .eq('site_id', SITE_ID)
  .eq('content_type', 'video')
  .eq('publisher_id', channel.id)
  .eq('is_public', true)
  .order('published_at', { ascending: false })
  .limit(48)

// Hero image from default_category
let channelHeroImage = ''
if (channel.default_category) {
  const catSlug = channel.default_category
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
  const { data: heroSetting } = await supabase
    .from('site_settings')
    .select('value')
    .eq('site_id', SITE_ID)
    .eq('key', `category_hero_${catSlug}`)
    .single()
  channelHeroImage = heroSetting?.value || ''
}

const pageTitle = `${channel.name} — GAUK Antiques`
const pageDescription = channel.description
  ? channel.description.slice(0, 160)
  : `Watch ${channel.name} videos on GAUK Antiques — curated antiques guides and expert content.`
---
<PublicShell title={pageTitle} description={pageDescription} ogImage={channelHeroImage || channel.logo_url || ''}>
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": channel.name,
  "description": pageDescription,
  "url": `https://gaukantiques.com/channels/${slug}`,
  "mainEntity": {
    "@type": "Organization",
    "name": channel.name,
    "logo": channel.logo_url || ''
  }
})} />

<style>
  .ch-page { background: #EFE7D9; min-height: 100vh; }

  /* HERO */
  .ch-hero { position: relative; padding: 100px 32px 56px; background: #1C1810; overflow: hidden; }
  .ch-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .ch-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.97) 0%, rgba(13,8,4,.65) 60%, rgba(13,8,4,.4) 100%); }
  .ch-hero-inner { position: relative; z-index: 2; max-width: 900px; margin: 0 auto; }
  .ch-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #C8A060; margin-bottom: 10px; }
  .ch-name { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(28px,5vw,48px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.2; margin-bottom: 12px; }
  .ch-count { font-family: 'Prata', Georgia, serif; font-size: 12px; color: rgba(239,231,217,.5); letter-spacing: 1px; margin-bottom: 16px; }
  .ch-desc { font-family: 'Prata', Georgia, serif; font-size: 14px; color: rgba(239,231,217,.55); line-height: 1.8; max-width: 600px; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 20px; }
  .ch-follow { display: inline-block; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; padding: 12px 28px; background: #C4B49E; color: #8A7A66; cursor: default; }
  @media (max-width: 767px) { .ch-hero { padding: 80px 16px 40px; } }

  /* BREADCRUMB */
  .ch-breadcrumb { max-width: 1100px; margin: 0 auto; padding: 20px 32px; display: flex; align-items: center; gap: 8px; }
  .ch-bc-link { font-family: 'Prata', Georgia, serif; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: #7A5C20; text-decoration: none; }
  .ch-bc-link:hover { color: #1C1810; }
  .ch-bc-sep { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #C4B49E; }
  .ch-bc-cur { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #8A7A66; }
  @media (max-width: 767px) { .ch-breadcrumb { padding: 16px; } }

  /* VIDEO GRID */
  .ch-videos { max-width: 1100px; margin: 0 auto; padding: 0 32px 80px; }
  .ch-section-cap { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #5C5040; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; }
  .ch-section-cap::after { content: ''; flex: 1; height: 1px; background: #C4B49E; }
  .ch-section-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(20px,3vw,28px); font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 24px; }
  .video-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 900px) { .video-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .video-grid { grid-template-columns: repeat(2, 1fr); } }
  .video-card { background: #EFE7D9; text-decoration: none; display: block; cursor: pointer; transition: background .15s; }
  .video-card:hover { background: #E6DCCB; }
  .video-thumb-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; background: #E6DCCB; }
  .video-thumb-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.25); transition: background .2s; }
  .video-card:hover .video-play { background: rgba(0,0,0,0.4); }
  .video-play-icon { width: 44px; height: 44px; background: rgba(255,255,255,.92); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .video-body { padding: 12px; }
  .video-title { font-family: 'Prata', Georgia, serif; font-size: 13px; color: #1C1810; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  @media (max-width: 767px) { .ch-videos { padding: 0 16px 80px; } }

  /* EMPTY */
  .ch-empty { padding: 64px 32px; text-align: center; }
  .ch-empty-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 24px; font-style: italic; color: #1C1810; margin-bottom: 10px; }
  .ch-empty-sub { font-family: 'Prata', Georgia, serif; font-size: 14px; color: #8A7A66; line-height: 1.8; }
</style>

<div class="ch-page">

  <!-- HERO -->
  <div class="ch-hero">
    {channelHeroImage && <div class="ch-hero-bg" style={`background-image:url('${channelHeroImage}')`}></div>}
    <div class="ch-hero-overlay"></div>
    <div class="ch-hero-inner">
      <div class="ch-eyebrow">Channel</div>
      <h1 class="ch-name">{channel.name}</h1>
      {count && <div class="ch-count">{count} video{count !== 1 ? 's' : ''}</div>}
      {channel.description && <p class="ch-desc">{channel.description}</p>}
      <span class="ch-follow">Follow — Coming Soon</span>
    </div>
  </div>

  <!-- BREADCRUMB -->
  <nav class="ch-breadcrumb">
    <a href="/videos" class="ch-bc-link">Videos</a>
    <span class="ch-bc-sep">›</span>
    <span class="ch-bc-cur">{channel.name}</span>
  </nav>

  <!-- VIDEO GRID -->
  <div class="ch-videos">
    {videos && videos.length > 0 ? (
      <>
        <div class="ch-section-cap">Videos</div>
        <div class="ch-section-title">All videos from {channel.name}</div>
        <div class="video-grid">
          {videos.map(v => (
            <a href={`/videos/${v.id}`} class="video-card">
              <div class="video-thumb-wrap">
                {v.thumbnail_url
                  ? <img src={v.thumbnail_url} alt="" loading="lazy" />
                  : <div style="width:100%;height:100%;background:#E6DCCB;"></div>
                }
                <div class="video-play">
                  <div class="video-play-icon">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="#1C1810"><polygon points="4,2 14,8 4,14"/></svg>
                  </div>
                </div>
              </div>
              <div class="video-body">
                <div class="video-title" set:html={v.title.replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&').replace(/&ndash;/g, '–').replace(/&mdash;/g, '—')}></div>
              </div>
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="ch-empty">
        <div class="ch-empty-title">No videos yet</div>
        <div class="ch-empty-sub">Videos from this channel are being added — check back soon.</div>
      </div>
    )}
  </div>

</div>
</PublicShell>
