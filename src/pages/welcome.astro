---
import PublicShell from '../layouts/PublicShell.astro'
import { supabase } from '../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

const { data: plan } = await supabase
  .from('plans')
  .select('credits')
  .eq('site_id', SITE_ID)
  .eq('plan_type', 'free')
  .eq('active', true)
  .single()

const freeCredits = plan?.credits || 5
---
<PublicShell title="Welcome — GAUK Antiques">
<style>
  body { background: #EFE7D9; color: #1C1810; }
  .welcome-wrap {
    min-height: 100vh; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 40px 24px 80px; text-align: center;
  }
  .welcome-icon { width: 64px; height: 64px; border: 1px solid #C4B49E; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 28px; }
  .welcome-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #7A5C20; margin-bottom: 12px; }
  .welcome-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(28px, 6vw, 40px); font-weight: 400; font-style: italic; color: #1C1810; line-height: 1.2; margin-bottom: 20px; }
  .welcome-credits-badge {
    display: inline-block; background: #E6DCCB; border: 1px solid #C4B49E;
    padding: 16px 32px; margin: 0 auto 24px;
  }
  .welcome-credits-number { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 48px; font-weight: 400; color: #7A5C20; line-height: 1; }
  .welcome-credits-label { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; margin-top: 4px; }
  .welcome-body { font-family: 'Prata', Georgia, serif; font-size: 16px; color: #5C5040; line-height: 1.9; max-width: 340px; margin: 0 auto 12px; }
  .welcome-hint { font-family: 'Prata', Georgia, serif; font-size: 14px; color: #8A7A66; margin-bottom: 36px; }
  .welcome-divider { width: 60px; height: 1px; background: #C4B49E; margin: 24px auto; }
  .welcome-btn { display: inline-block; padding: 16px 48px; background: #1C1810; border: none; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #EFE7D9; text-decoration: none; cursor: pointer; transition: opacity .2s; }
  .welcome-btn:hover { opacity: .85; }
  .welcome-sub-link { display: block; margin-top: 16px; font-family: 'Prata', Georgia, serif; font-size: 14px; color: #8A7A66; text-decoration: none; }
  .welcome-sub-link:hover { color: #7A5C20; }
</style>
<div class="welcome-wrap">
  <div class="welcome-icon">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7A5C20" stroke-width="1">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    </svg>
  </div>
  <div class="welcome-eyebrow">Welcome Aboard</div>
  <div class="welcome-title">Your account is ready</div>
  <div class="welcome-credits-badge">
    <div class="welcome-credits-number">{freeCredits}</div>
    <div class="welcome-credits-label">Free Credits — On Us</div>
  </div>
  <a href="/library" class="welcome-btn">Go to My Collection</a>
  <a href="/" class="welcome-sub-link">Identify a new piece</a>
  <div class="welcome-divider"></div>
  <div class="welcome-body">Each credit unlocks one full valuation report — expert notes, market history, comparable sales, and your options.</div>
  <div class="welcome-hint">When you need more, top up any time. Credits never expire.</div>
</div>
</PublicShell>
