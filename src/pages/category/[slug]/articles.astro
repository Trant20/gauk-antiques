---
import PublicShell from '../../../layouts/PublicShell.astro'
import { supabase } from '../../../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
const { slug } = Astro.params
if (!slug) return Astro.redirect('/articles')

const { data: catSetting } = await supabase
  .from('site_settings').select('value')
  .eq('site_id', SITE_ID).eq('key', 'categories').single()

const validCategories = catSetting?.value ? JSON.parse(catSetting.value) : []
function slugify(s) {
  return s.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
}
const dbCategory = validCategories.find(c => slugify(c) === slug)
if (!dbCategory) return Astro.redirect('/articles')

const { data: allSettings } = await supabase
  .from('site_settings').select('key,value')
  .eq('site_id', SITE_ID)
  .in('key', [`category_hero_${slug}`, `category_title_${slug}`, `category_subtitle_${slug}`])

const settingsMap = {}
allSettings?.forEach(s => { settingsMap[s.key] = s.value })
const heroImage = settingsMap[`category_hero_${slug}`] || ''
const heroTitle = settingsMap[`category_title_${slug}`] || `The World of ${dbCategory}`
const heroSubtitle = settingsMap[`category_subtitle_${slug}`] || `Explore ${dbCategory} articles.`

const { data: initialArticles, count } = await supabase
  .from('articles')
  .select('id, title, slug, excerpt, image_url, category, published_at', { count: 'exact' })
  .eq('site_id', SITE_ID)
  .eq('category', dbCategory)
  .eq('published', true)
  .order('published_at', { ascending: false })
  .range(0, 11)
---
<PublicShell title={`${dbCategory} Articles — GAUK Antiques`} description={heroSubtitle} ogImage={heroImage}>
<style is:global>
  .cat-art-hero { position: relative; min-height: 40vh; display: flex; align-items: flex-end; overflow: hidden; background: #1C1810; }
  .cat-art-hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
  .cat-art-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,8,4,.97) 0%, rgba(13,8,4,.4) 60%, rgba(13,8,4,.1) 100%); }
  .cat-art-hero-content { position: relative; z-index: 2; width: 100%; max-width: 1100px; margin: 0 auto; padding: 48px 40px; }
  @media (max-width: 767px) { .cat-art-hero-content { padding: 80px 16px 32px; } }
  .cat-art-hero-back { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(239,231,217,.5); text-decoration: none; margin-bottom: 16px; display: inline-block; }
  .cat-art-hero-back:hover { color: #C8A060; }
  .cat-art-hero-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: #C8A060; margin-bottom: 12px; }
  .cat-art-hero-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: clamp(28px,5vw,56px); font-weight: 400; font-style: italic; color: #EFE7D9; line-height: 1.1; margin-bottom: 10px; }
  .cat-art-hero-sub { font-family: 'Prata', Georgia, serif; font-size: 15px; color: rgba(239,231,217,.6); line-height: 1.8; max-width: 560px; }
  .cat-art-body { background: #EFE7D9; min-height: 60vh; }
  .cat-art-inner { max-width: 1100px; margin: 0 auto; padding: 56px 40px; }
  @media (max-width: 767px) { .cat-art-inner { padding: 40px 16px; } }
  .cat-art-count { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; margin-bottom: 32px; }
  .cat-art-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: #C4B49E; }
  @media (max-width: 768px) { .cat-art-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .cat-art-grid { grid-template-columns: 1fr; } }
  .cat-art-card { background: #EFE7D9; text-decoration: none; color: #1C1810; transition: background .15s; display: flex; flex-direction: column; }
  .cat-art-card:hover { background: #E6DCCB; }
  .cat-art-card-img { width: 100%; height: 200px; object-fit: cover; display: block; background: #E6DCCB; }
  .cat-art-card-body { padding: 20px; flex: 1; }
  .cat-art-card-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 17px; font-style: italic; color: #1C1810; line-height: 1.3; margin-bottom: 10px; }
  .cat-art-card-excerpt { font-family: 'Prata', Georgia, serif; font-size: 12px; color: #8A7A66; line-height: 1.7; margin-bottom: 12px; }
  .cat-art-card-date { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: #C4B49E; }
  .cat-art-loading { text-align: center; padding: 32px; font-family: 'Prata', Georgia, serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: #8A7A66; display: none; }
  .cat-art-end { text-align: center; padding: 32px; font-family: 'Prata', Georgia, serif; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: #C4B49E; display: none; }
  .cat-art-sentinel { height: 1px; }
  .cat-art-breadcrumb { background: #EFE7D9; border-bottom: 1px solid #C4B49E; }
  .cat-art-breadcrumb-inner { max-width: 1100px; margin: 0 auto; padding: 12px 40px; display: flex; align-items: center; gap: 8px; }
  @media (max-width: 767px) { .cat-art-breadcrumb-inner { padding: 12px 16px; } }
  .cat-art-breadcrumb-link { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #7A5C20; text-decoration: none; letter-spacing: 1px; }
  .cat-art-breadcrumb-link:hover { color: #1C1810; }
  .cat-art-breadcrumb-sep { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #C4B49E; }
  .cat-art-breadcrumb-current { font-family: 'Prata', Georgia, serif; font-size: 11px; color: #8A7A66; letter-spacing: 1px; }
</style>

<div class="cat-art-hero">
  {heroImage && <div class="cat-art-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="cat-art-hero-overlay"></div>
  <div class="cat-art-hero-content">
    <div class="cat-art-hero-eyebrow">Articles</div>
    <h1 class="cat-art-hero-title">{heroTitle}</h1>
    <p class="cat-art-hero-sub">{heroSubtitle}</p>
  </div>
</div>

<div class="cat-art-breadcrumb">
  <div class="cat-art-breadcrumb-inner">
    <a href="/articles" class="cat-art-breadcrumb-link">Articles</a>
    <span class="cat-art-breadcrumb-sep">›</span>
    <a href={`/categories/${slug}`} class="cat-art-breadcrumb-link">{dbCategory}</a>
    <span class="cat-art-breadcrumb-sep">›</span>
    <span class="cat-art-breadcrumb-current">All articles</span>
  </div>
</div>

<div class="cat-art-body">
  <div class="cat-art-inner">
    <div class="cat-art-count">{count?.toLocaleString()} articles</div>
    <div class="cat-art-grid" id="art-grid">
      {initialArticles?.map(a => (
        <a href={`/learn/${a.slug}`} class="cat-art-card">
          {a.image_url
            ? <img class="cat-art-card-img" src={a.image_url} alt={a.title} loading="lazy" />
            : <div class="cat-art-card-img"></div>
          }
          <div class="cat-art-card-body">
            <div class="cat-art-card-title">{a.title}</div>
            {a.excerpt && <div class="cat-art-card-excerpt">{a.excerpt.slice(0,120)}...</div>}
            {a.published_at && new Date(a.published_at).getFullYear() >= 2024 && <div class="cat-art-card-date">{new Date(a.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</div>}
          </div>
        </a>
      ))}
    </div>
    <div class="cat-art-loading" id="art-loading">Loading more</div>
    <div class="cat-art-end" id="art-end">All articles loaded</div>
    <div class="cat-art-sentinel" id="art-sentinel"></div>
  </div>
</div>

<script define:vars={{ dbCategory, SITE_ID, initialCount: count }}>
const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY
const BATCH = 12
let offset = BATCH
let loading = false
let done = offset >= initialCount

function makeCard(a) {
  const card = document.createElement('a')
  card.href = `/learn/${a.slug}`
  card.className = 'cat-art-card'
  const date = a.published_at ? new Date(a.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) : ''
  card.innerHTML = `
    ${a.image_url ? `<img class="cat-art-card-img" src="${a.image_url}" alt="" loading="lazy"/>` : '<div class="cat-art-card-img"></div>'}
    <div class="cat-art-card-body">
      <div class="cat-art-card-title">${a.title}</div>
      ${a.excerpt ? `<div class="cat-art-card-excerpt">${a.excerpt.slice(0,120)}...</div>` : ''}
      ${date ? `<div class="cat-art-card-date">${date}</div>` : ''}
    </div>`
  return card
}

async function loadMore() {
  if (loading || done) return
  loading = true
  document.getElementById('art-loading').style.display = 'block'
  const p = new URLSearchParams({
    select: 'id,title,slug,excerpt,image_url,published_at',
    site_id: `eq.${SITE_ID}`,
    category: `eq.${dbCategory}`,
    published: 'eq.true',
    order: 'published_at.desc',
    limit: String(BATCH),
    offset: String(offset),
  })
  const res = await fetch(`${SUPA_URL}/rest/v1/articles?${p}`, {
    headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` }
  })
  const data = await res.json()
  const grid = document.getElementById('art-grid')
  data.forEach(a => grid.appendChild(makeCard(a)))
  offset += BATCH
  if (data.length < BATCH) {
    done = true
    document.getElementById('art-loading').style.display = 'none'
    document.getElementById('art-end').style.display = 'block'
  } else {
    document.getElementById('art-loading').style.display = 'none'
  }
  loading = false
}

const observer = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) loadMore()
}, { rootMargin: '200px' })
observer.observe(document.getElementById('art-sentinel'))
</script>
</PublicShell>
