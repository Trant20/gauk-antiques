---
import PublicShell from '../../layouts/PublicShell.astro'
---
<PublicShell title="Update Password — GAUK Antiques">
<style>
  body { background: #EFE7D9; color: #1C1810; }
  .auth-wrap { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px 80px; }
  .auth-logo { font-family: 'Prata', Georgia, serif; font-size: 12px; letter-spacing: 4px; text-transform: uppercase; color: #1C1810; margin-bottom: 40px; }
  .auth-logo span { color: #7A5C20; }
  .auth-card { width: 100%; max-width: 400px; }
  .auth-eyebrow { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: #7A5C20; margin-bottom: 10px; }
  .auth-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 28px; font-weight: 400; font-style: italic; color: #1C1810; margin-bottom: 8px; }
  .auth-sub { font-family: 'Prata', Georgia, serif; font-size: 16px; color: #8A7A66; margin-bottom: 32px; line-height: 1.7; padding-bottom: 24px; border-bottom: 1px solid #C4B49E; }
  .auth-field { margin-bottom: 20px; }
  .auth-label { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; display: block; margin-bottom: 8px; }
  .auth-input { width: 100%; padding: 13px 16px; background: #E6DCCB; border: 1px solid #C4B49E; font-family: 'Prata', Georgia, serif; font-size: 16px; color: #1C1810; outline: none; box-sizing: border-box; transition: border-color .2s; }
  .auth-input:focus { border-color: #7A5C20; }
  .auth-btn { width: 100%; padding: 16px; background: #1C1810; border: none; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: #EFE7D9; cursor: pointer; margin-top: 8px; transition: opacity .2s; }
  .auth-btn:hover { opacity: .85; }
  .auth-btn:disabled { opacity: .5; cursor: default; }
  .auth-error { font-family: 'Prata', Georgia, serif; font-size: 14px; color: #C46028; background: #F5EDE3; border: 1px solid #E8C8A8; padding: 12px 16px; margin-bottom: 20px; display: none; }
  .auth-footer { font-family: 'Prata', Georgia, serif; font-size: 14px; color: #8A7A66; text-align: center; margin-top: 24px; }
  .auth-footer a { color: #7A5C20; text-decoration: none; }
</style>
<div class="auth-wrap">
  <div class="auth-logo">GAUK <span>Antiques</span></div>
  <div class="auth-card">
    <div class="auth-eyebrow">Account Recovery</div>
    <div class="auth-title">Set a new password</div>
    <div class="auth-sub">Choose a strong password for your account.</div>
    <div class="auth-error" id="auth-error"></div>
    <div class="auth-field">
      <label class="auth-label" for="password">New password</label>
      <input class="auth-input" type="password" id="password" placeholder="Minimum 8 characters" autocomplete="new-password" />
    </div>
    <div class="auth-field">
      <label class="auth-label" for="password-confirm">Confirm password</label>
      <input class="auth-input" type="password" id="password-confirm" placeholder="Repeat your password" autocomplete="new-password" />
    </div>
    <button class="auth-btn" id="update-btn">Update Password</button>
    <div class="auth-footer"><a href="/auth/signin">Back to sign in</a></div>
  </div>
</div>
</PublicShell>

<script>
  import { supabase } from '../../lib/supabase-browser'

  const btn = document.getElementById('update-btn') as HTMLButtonElement
  const errorEl = document.getElementById('auth-error')!

  btn.addEventListener('click', async () => {
    const password = (document.getElementById('password') as HTMLInputElement).value
    const confirm = (document.getElementById('password-confirm') as HTMLInputElement).value
    if (!password || !confirm) { showError('Please fill in all fields'); return }
    if (password.length < 8) { showError('Password must be at least 8 characters'); return }
    if (!/[0-9!@#$%^&*()_+\-=\[\]{};:'",.<>?\/\\|`~]/.test(password)) { showError('Password must contain at least one number or special character'); return }
    if (password !== confirm) { showError('Passwords do not match'); return }

    btn.setAttribute('disabled', 'true')
    btn.textContent = 'Updating...'
    errorEl.style.display = 'none'

    const { error } = await supabase.auth.updateUser({ password })
    if (error) {
      showError(error.message)
      btn.removeAttribute('disabled')
      btn.textContent = 'Update Password'
      return
    }

    window.location.href = '/library'
  })

  function showError(msg: string) {
    errorEl.textContent = msg
    errorEl.style.display = 'block'
  }
</script>
