---
import AuthShell from '../../layouts/AuthShell.astro'
import { ANTIQUES_SITE_ID } from '../../lib/constants'
---
<AuthShell title="Create Account — GAUK Antiques">
<div class="auth-wrap">
  <div class="auth-logo">GAUK <span>Antiques</span></div>
  <div class="auth-card">
    <div class="auth-eyebrow">New Account</div>
    <div class="auth-title">Create your account</div>
    <div class="auth-sub">Save identifications, build your collection and unlock full valuations.</div>
    <div class="auth-error" id="auth-error"></div>
    <div class="auth-field">
      <label class="auth-label" for="email">Email address</label>
      <input class="auth-input" type="email" id="email" placeholder="you@example.com" autocomplete="email" />
    </div>
    <div class="auth-field">
      <label class="auth-label" for="password">Password</label>
      <input class="auth-input" type="password" id="password" placeholder="Minimum 8 characters" autocomplete="new-password" />
    </div>
    <button class="auth-btn" id="signup-btn">Create Account</button>
    <div class="auth-footer">Already have an account? <a href="/auth/signin">Sign in</a></div>
  </div>
</div>
</AuthShell>

<script>
  import { supabase } from '../../lib/supabase-browser'
  
  const btn = document.getElementById('signup-btn')
  const errorEl = document.getElementById('auth-error')

  btn?.addEventListener('click', async () => {
    const email = (document.getElementById('email') as HTMLInputElement).value.trim()
    const password = (document.getElementById('password') as HTMLInputElement).value
    if (!email || !password) { showError('Please fill in all fields'); return }
    if (password.length < 8) { showError('Password must be at least 8 characters'); return }
    if (!/[0-9!@#$%^&*()_+\-=\[\]{};:\'",.<>?\/\\|`~]/.test(password)) { showError('Password must contain at least one number or special character'); return }
    btn.setAttribute('disabled', 'true')
    btn.textContent = 'Creating account...'
    errorEl!.style.display = 'none'

    const { data, error } = await supabase.auth.signUp({ email, password })
    if (error) { showError(error.message); btn.removeAttribute('disabled'); btn.textContent = 'Create Account'; return }

    // Store pending claim server-side so it survives cross-browser confirmation
    const pendingId = localStorage.getItem('pending_identification_id')
    if (pendingId && data.user?.email) {
      await fetch('/api/pending-claim', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: data.user.email, identification_id: pendingId })
      })
    }

    // Show confirm email message — credits and claim handled in /auth/callback after confirmation
    btn.setAttribute('disabled', 'true')
    btn.textContent = 'Account created'
    document.getElementById('auth-error')!.style.display = 'none'
    const card = document.querySelector('.auth-card')!
    card.innerHTML = `
      <div style="text-align:center;">
        <div class="auth-confirm-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7A5C20" stroke-width="1.2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div class="auth-eyebrow">Almost there</div>
        <div class="auth-title">Check your email</div>
        <div class="auth-confirm-email">${email.replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;')}</div>
        <div class="auth-confirm-hint">We've sent a confirmation link to the address above.<br>Click it to activate your account and claim your free credits.</div>
        <div class="auth-confirm-divider"></div>
        <div class="auth-footer">Wrong address? <a href="/auth/signup">Start over</a></div>
      </div>
    `
  })

  function showError(msg: string) {
    errorEl!.textContent = msg
    errorEl!.style.display = 'block'
  }
</script>
