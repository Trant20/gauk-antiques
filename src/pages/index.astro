        <div class="result-id-key">Origin</div>
        <div class="result-id-val" id="result-origin"></div>
      </div>
      <div class="result-id-row">
        <div class="result-id-key">Condition</div>
        <div class="result-id-val" id="result-condition"></div>
      </div>
    </div>
    <div class="result-value-block">
      <div class="result-value-label">Estimated Value</div>
      <div class="result-value" id="result-value"></div>
    </div>
    <div class="result-blur-gate">
      <div class="result-blur-content" id="blur-content">
        <div class="result-notes-preview">
          <div class="result-notes-label">Appraiser Notes</div>
          <div class="result-notes-text" id="result-notes"></div>
        </div>
      </div>
      <div class="result-blur-overlay" id="blur-overlay">
        <div class="result-gate-headline">Your valuation is ready</div>
        <div class="result-gate-sub">Create a free account to unlock the full report.</div>
        <a href="/auth/signup" class="result-gate-register">Register Free</a>
        <div class="result-gate-or">or</div>
        <a href="#" class="result-gate-pay">Full Certificate — £29.99</a>
      </div>
    </div>
    <div class="result-view-report" id="result-view-report" style="display:none; padding: 16px 20px;">
      <a id="view-report-link" href="#" style="display:block;width:100%;padding:16px;background:#1C1810;font-family:Prata,Georgia,serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#EFE7D9;text-align:center;text-decoration:none;">View Full Report</a>
    </div>
    <div class="result-footer-bar">
      <span class="result-footer-brand">GAUK Antiques</span>
      <span class="result-footer-ref" id="result-ref"></span>
    </div>
    <div class="save-note" id="save-note">Saved to your library</div>
  </div>
  </div>

  <section class="how-section">
    <div class="how-heading">How It Works</div>
    <div class="how-grid">
      <div class="how-item">
        <div class="how-number">I</div>
        <div class="how-title">Photograph</div>
        <div class="how-body">Upload a clear image of your piece from any angle</div>
      </div>
      <div class="how-item">
        <div class="how-number">II</div>
        <div class="how-title">Identify</div>
        <div class="how-body">Our AI analyses maker, period, condition and provenance</div>
