    .result-title {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 22px; font-weight: 400; color: var(--text); margin-bottom: 14px; line-height: 1.3;
    }
    .typed-cursor {
      display: inline-block; width: 2px; height: 1em;
