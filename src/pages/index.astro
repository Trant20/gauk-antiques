---import Layout from '../layouts/Layout.astro'import { createClient } from '@supabase/supabase-js'const supabase = createClient(  import.meta.env.PUBLIC_SUPABASE_URL,  import.meta.env.PUBLIC_SUPABASE_ANON_KEY)const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'const { data: settings } = await supabase  .from('site_settings')  .select('key, value')  .eq('site_id', SITE_ID)const cfg: Record<string, string> = {}settings?.forEach(r => { cfg[r.key] = r.value })const { data: heroImages } = await supabase  .from('hero_images')  .select('image_url')  .eq('site_id', SITE_ID)  .eq('active', true)  .order('sort_order', { ascending: true })const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000)const imagePool = heroImages && heroImages.length > 0 ? heroImages : [{ image_url: '' }]const heroImage = imagePool[dayOfYear % imagePool.length].image_urlconst heroOverlay = parseFloat(cfg.hero_overlay || '62') / 100const heroHeadline = cfg.hero_headline || 'What is it worth?'const heroSubtext = cfg.hero_subtext || 'Upload a photograph. Our AI identifies your antique and returns a professional valuation in seconds.'const words = heroHeadline.split(' ')const lastWord = words.slice(-1)[0]const firstWords = words.slice(0, -1).join(' ')---<Layout title="GAUK Antiques — AI Antique Identification & Valuation">  <style>    .site-header {      position: fixed; top: 0; left: 0; right: 0; z-index: 100;      display: flex; align-items: center; justify-content: space-between;      padding: 20px 40px;      background: linear-gradient(to bottom, rgba(13,11,9,.85), transparent);    }    .site-logo {      font-family: 'Prata', Georgia, serif;      font-size: 13px; letter-spacing: 4px; text-transform: uppercase;      color: var(--text);    }    .site-logo span { color: var(--goldHi); }    .header-actions { display: flex; align-items: center; gap: 24px; }    .header-link {      font-family: 'Prata', Georgia, serif;      font-size: 11px; letter-spacing: 2px; text-transform: uppercase;      color: var(--textDim); text-decoration: none; transition: color .2s;    }    .header-link:hover { color: var(--text); }    .theme-toggle {      background: none; border: 1px solid var(--border); cursor: pointer;      width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;      color: var(--textDim); transition: border-color .2s, color .2s;    }    .theme-toggle:hover { border-color: var(--borderHi); color: var(--text); }    /* ─── HERO ─── */    .hero {      position: relative; width: 100%; min-height: 100vh;      display: flex; flex-direction: column;      align-items: center; justify-content: center;      overflow: hidden; padding: 60px 24px 24px;    }    .hero-bg {      position: absolute; inset: 0;      background-size: cover; background-position: center;    }    .hero-overlay {      position: absolute; inset: 0;    }    .hero-content {      position: relative; z-index: 2;      width: 100%; max-width: 520px;      display: flex; flex-direction: column; align-items: center; gap: 0;    }    .hero-headline {      text-align: center; margin-bottom: 12px;    }    .hero-eyebrow {      font-family: 'Prata', Georgia, serif;      font-size: 9px; letter-spacing: 5px; text-transform: uppercase;      color: var(--gold); margin-bottom: 16px;    }    .hero-h1 {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: clamp(36px, 6vw, 64px); font-weight: 400; line-height: 1.1;      color: var(--text);    }    .hero-h1 em { font-style: italic; color: var(--goldHi); }    /* ─── UPLOAD PANEL ─── */    .upload-panel {      width: 100%;      background: rgba(13,11,9,.82);      backdrop-filter: blur(16px);      border: 1px solid var(--border);      padding: 16px;    }    .upload-zone-wrap { position: relative; margin-bottom: 16px; }    .corner {      position: absolute; width: 18px; height: 18px; z-index: 2;      transition: border-color .25s;    }    .corner.tl { top:0; left:0; border-top: 1px solid var(--borderHi); border-left: 1px solid var(--borderHi); }    .corner.tr { top:0; right:0; border-top: 1px solid var(--borderHi); border-right: 1px solid var(--borderHi); }    .corner.bl { bottom:0; left:0; border-bottom: 1px solid var(--borderHi); border-left: 1px solid var(--borderHi); }    .corner.br { bottom:0; right:0; border-bottom: 1px solid var(--borderHi); border-right: 1px solid var(--borderHi); }    .corner.active { border-color: var(--goldHi) !important; }    @keyframes scanLine { 0% { top: 0%; } 100% { top: 100%; } }    .scan-overlay {      position: absolute; inset: 0; z-index: 10; pointer-events: none;      display: none; overflow: hidden;    }    .scan-overlay.active { display: block; }    .scan-line {      position: absolute; left: 0; right: 0; height: 2px;      background: linear-gradient(to right, transparent, var(--goldHi), transparent);      box-shadow: 0 0 12px 2px rgba(196,168,112,0.6);      animation: scanLine 1.8s ease-in-out infinite;    }    .scan-corners::before, .scan-corners::after {      content: ""; position: absolute;      width: 24px; height: 24px;      border-color: var(--goldHi); border-style: solid;    }    .scan-corners::before { top: 8px; left: 8px; border-width: 1px 0 0 1px; }    .scan-corners::after  { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }    .upload-zone {      width: 100%; aspect-ratio: 1/1;      background: rgba(255,255,255,.03);      display: flex; flex-direction: column;      align-items: center; justify-content: center;      cursor: pointer; overflow: hidden;      margin: 2px; position: relative; transition: background .2s;    }    .upload-zone:hover { background: rgba(255,255,255,.05); }    .upload-zone img { width: 100%; height: 100%; object-fit: contain; position: absolute; inset: 0; background: var(--surface); }    .upload-placeholder { text-align: center; padding: 24px; }    .upload-icon {      width: 44px; height: 44px; border-radius: 50%;      border: 1px solid var(--border);      display: flex; align-items: center; justify-content: center;      margin: 0 auto 16px; opacity: .5;    }    .upload-prompt {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: 16px; font-weight: 400; color: var(--textDim); margin-bottom: 6px;    }    .upload-hint {      font-family: 'Prata', Georgia, serif;      font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--textMute);    }    .upload-actions { display: flex; flex-direction: column; gap: 8px; }    .btn-primary {      width: 100%; padding: 15px; background: var(--text); border: none;      font-family: 'Prata', Georgia, serif; font-size: 11px;      letter-spacing: 3px; text-transform: uppercase;      color: var(--bg); cursor: pointer; transition: opacity .2s;    }    .btn-primary:hover { opacity: .9; }    .btn-primary:disabled { opacity: .4; cursor: default; }    .btn-ghost {      width: 100%; padding: 15px; background: transparent; border: 1px solid var(--border);      font-family: 'Prata', Georgia, serif; font-size: 11px;      letter-spacing: 2px; text-transform: uppercase;      color: var(--textDim); cursor: pointer; transition: border-color .25s, color .25s;    }    .btn-ghost:hover { border-color: var(--borderHi); color: var(--text); }    .status-text {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;      color: var(--gold); text-align: center; min-height: 18px; margin-top: 12px;    }    /* ─── RESULT CARD ─── */    .result-section {      position: relative; z-index: 2;      width: 100%; max-width: 520px;      margin-top: 2px;      display: none;    }    .result-section.visible { display: block; }    .result-eyebrow {      display: flex; align-items: center; justify-content: space-between;      padding: 16px 20px 0;    }    .result-category {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--gold);    }    .result-confidence {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;      padding: 4px 10px; border: 1px solid var(--border); color: var(--textMute);    }    .result-title {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: clamp(22px, 5vw, 32px); font-weight: 400; line-height: 1.2;      color: var(--text); padding: 12px 20px 0;    }    .result-desc {      padding: 16px 20px 20px;      font-family: 'Prata', Georgia, serif;      font-size: 16px; line-height: 1.9; color: var(--textDim);      border-bottom: 1px solid var(--border);      min-height: 60px;    }    .typed-cursor {      display: inline-block; width: 2px; height: 1em;      background: var(--goldHi); margin-left: 2px;      vertical-align: text-bottom;      animation: blink .7s step-end infinite;    }    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }    .id-table { padding: 0 20px; border-bottom: 1px solid var(--border); }    .id-row {      display: flex; gap: 16px; align-items: flex-start;      padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,.06);    }    .id-row:last-child { border-bottom: none; }    .id-key {      width: 90px; flex-shrink: 0;      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;      color: var(--textMute); padding-top: 2px;    }    .id-val {      font-family: 'Prata', Georgia, serif;      font-size: 16px; color: var(--text); line-height: 1.5; flex: 1;    }    .value-section {      background: var(--surface);      border-top: 1px solid var(--border);      border-bottom: 1px solid var(--border);      padding: 28px 20px; text-align: center;    }    .value-label {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;      color: var(--textMute); margin-bottom: 12px;    }    .value-number {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: clamp(32px, 7vw, 48px); font-weight: 400; line-height: 1;      color: var(--goldHi); letter-spacing: -1px;    }    .blur-gate { position: relative; }    .blur-content { filter: blur(6px); pointer-events: none; user-select: none; }    .blur-overlay {      position: absolute; inset: 0;      display: flex; flex-direction: column;      align-items: center; justify-content: center;      padding: 24px; gap: 10px;      background: linear-gradient(to bottom, transparent 0%, rgba(13,11,9,.75) 25%, rgba(13,11,9,.97) 100%);    }    .blur-headline {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: 20px; font-weight: 400; color: var(--text);      text-align: center; line-height: 1.3; margin-bottom: 4px;    }    .blur-sub {      font-family: 'Prata', Georgia, serif;      font-size: 13px; color: var(--textDim);      text-align: center; line-height: 1.7; margin-bottom: 6px;    }    .btn-register {      width: 100%; max-width: 300px; padding: 15px;      background: var(--text); border: none;      font-family: 'Prata', Georgia, serif;      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;      color: var(--bg); cursor: pointer; text-decoration: none;      display: block; text-align: center;    }    .btn-pay {      width: 100%; max-width: 300px; padding: 14px;      background: transparent; border: 1px solid var(--goldLo);      font-family: 'Prata', Georgia, serif;      font-size: 11px; letter-spacing: 3px; text-transform: uppercase;      color: var(--goldHi); cursor: pointer; text-decoration: none;      display: block; text-align: center;    }    .blur-divider {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--textMute);    }    .result-footer {      display: flex; justify-content: space-between; align-items: center;      padding: 16px 20px;      border-top: 1px solid var(--border);    }    .result-footer-brand {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: 13px; font-style: italic; color: var(--gold);    }    .result-footer-ref {      font-family: 'Prata', Georgia, serif;      font-size: 10px; letter-spacing: 2px; color: var(--textMute);    }    .save-note {      display: none; padding: 10px 20px;      font-family: 'Prata', Georgia, serif;      font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold);    }    .save-note.visible { display: block; }    /* ─── HOW ─── */    .how-section {      padding: 64px 24px 100px; max-width: 520px; margin: 0 auto;      border-top: 1px solid var(--border);    }    .how-heading {      font-family: 'Prata', Georgia, serif;      font-size: 9px; letter-spacing: 4px; text-transform: uppercase;      color: var(--textMute); margin-bottom: 32px; text-align: center;    }    .how-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; text-align: center; }    .how-item { padding: 0 12px; }    .how-item:not(:last-child) { border-right: 1px solid var(--border); }    .how-number {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: 26px; color: var(--goldLo); margin-bottom: 10px;    }    .how-title {      font-family: 'Playfair Display', Didot, Georgia, serif;      font-size: 13px; color: var(--text); margin-bottom: 6px;    }    .how-body {      font-family: 'Prata', Georgia, serif;      font-size: 10px; line-height: 1.7; color: var(--textMute);    }    /* ─── BOTTOM NAV ─── */    .bottom-nav {      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;      background: rgba(13,11,9,.93); backdrop-filter: blur(20px);      border-top: 1px solid var(--border); display: flex;    }    .nav-tab {      flex: 1; padding: 12px 0 10px; background: none; border: none; cursor: pointer;      display: flex; flex-direction: column; align-items: center; gap: 5px;      color: var(--textMute); text-decoration: none;      font-family: 'Prata', Georgia, serif;      font-size: 9px; letter-spacing: 2px; text-transform: uppercase; transition: color .2s;    }    .nav-tab.active, .nav-tab:hover { color: var(--goldHi); }    @media (min-width: 768px) { .bottom-nav { display: none; } }    @media (max-width: 767px) { .site-header .header-actions { display: none; } }  </style>  <header class="site-header a0">    <div class="site-logo">GAUK <span>Antiques</span></div>    <div class="header-actions">      <a href="/library" class="header-link">My Library</a>      <a href="/auth/signin" class="header-link" id="signin-link">Sign In</a>      <button class="theme-toggle" id="theme-btn" title="Toggle theme">        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">          <circle cx="12" cy="12" r="5"/>          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>        </svg>      </button>    </div>  </header>  <section class="hero">    <div class="hero-bg" style={`background-image: url('${heroImage}')`}></div>    <div class="hero-overlay" style={`background: rgba(13,11,9,${heroOverlay})`}></div>    <div class="hero-content">      <div class="hero-headline a0">        <div class="hero-eyebrow">AI Antique Identification</div>        <h1 class="hero-h1">{firstWords} <em>{lastWord}</em></h1>      </div>      <div class="upload-panel a1">        <div class="upload-zone-wrap">          <div class="corner tl"></div>          <div class="corner tr"></div>          <div class="corner bl"></div>          <div class="corner br"></div>          <div class="upload-zone" id="upload-zone">            <input type="file" id="file-input" accept="image/*" style="display:none" />            <img id="preview-img" style="display:none" alt="Preview" />            <div class="scan-overlay scan-corners" id="scan-overlay">              <div class="scan-line"></div>            </div>            <div class="upload-placeholder" id="upload-placeholder">              <div class="upload-icon">                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">                  <rect x="3" y="3" width="18" height="18" rx="0"/>                  <circle cx="8.5" cy="8.5" r="1.5"/>                  <polyline points="21 15 16 10 5 21"/>                </svg>              </div>              <div class="upload-prompt">Place your item here</div>              <div class="upload-hint">Tap to photograph or upload</div>            </div>          </div>        </div>        <div class="upload-actions">          <button class="btn-primary" id="identify-btn" disabled>Identify This Item</button>          <button class="btn-ghost" id="camera-btn">Use Camera</button>        </div>        <div class="status-text" id="status"></div>      </div>      <div class="result-section" id="result-section">        <div class="result-eyebrow">          <span class="result-category" id="result-category"></span>          <span class="result-confidence" id="result-confidence"></span>        </div>        <div class="result-title" id="result-title"></div>        <div class="result-desc">          <span id="typed-text"></span><span class="typed-cursor" id="typed-cursor"></span>        </div>        <div class="id-table">          <div class="id-row" id="row-maker" style="display:none">            <div class="id-key">Maker</div>            <div class="id-val" id="result-maker"></div>          </div>          <div class="id-row" id="row-period" style="display:none">            <div class="id-key">Period</div>            <div class="id-val" id="result-period"></div>          </div>          <div class="id-row" id="row-origin" style="display:none">            <div class="id-key">Origin</div>            <div class="id-val" id="result-origin"></div>          </div>          <div class="id-row">            <div class="id-key">Condition</div>            <div class="id-val" id="result-condition"></div>          </div>        </div>        <div class="blur-gate">          <div class="blur-content" id="blur-content">            <div class="value-section">              <div class="value-label">Estimated Value</div>              <div class="value-number" id="result-value"></div>            </div>            <div style="height:120px;background:var(--surface);opacity:.5;"></div>          </div>          <div class="blur-overlay" id="blur-overlay">            <div class="blur-headline">Your valuation is ready</div>            <div class="blur-sub">Create a free account to unlock the full report including value range, condition notes and appraiser commentary.</div>            <a href="/auth/signup" class="btn-register">Register Free</a>            <div class="blur-divider">or</div>            <a href="#" class="btn-pay">Full Certificate — £29.99</a>          </div>        </div>        <div class="result-footer" id="result-footer" style="display:none">          <div class="result-footer-brand">GAUK Antiques</div>          <div class="result-footer-ref" id="result-ref"></div>        </div>        <div class="save-note" id="save-note">Saved to your library</div>      </div>    </div>  </section>  <div class="result-outer" id="result-outer" style="display:none">
