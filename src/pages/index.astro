      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      color: var(--gold); text-align: center; min-height: 18px; margin-top: 12px;
    }

    /* ─── RESULT ─── */
    /* ─── PARCHMENT RESULT CARD ─── */
