</Layout>

<script>
  import { createClient } from '@supabase/supabase-js'
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )


  const { data: { session } } = await supabase.auth.getSession()
  if (session) {
    const signinLink = document.getElementById('signin-link')
    if (signinLink) {
      signinLink.textContent = session.user.email?.split('@')[0] || 'Account'
      signinLink.setAttribute('href', '/library')
    }
    const accountTab = document.getElementById('account-tab')
    if (accountTab) accountTab.setAttribute('href', '/library')
  }

  const zone = document.getElementById('upload-zone') as HTMLElement
  const fileInput = document.getElementById('file-input') as HTMLInputElement
  const previewImg = document.getElementById('preview-img') as HTMLImageElement
  const placeholder = document.getElementById('upload-placeholder') as HTMLElement
  const identifyBtn = document.getElementById('identify-btn') as HTMLButtonElement
  const cameraBtn = document.getElementById('camera-btn') as HTMLButtonElement
  const corners = document.querySelectorAll('.corner')
  const status = document.getElementById('status') as HTMLElement
  const scanOverlay = document.getElementById('scan-overlay') as HTMLElement

  let selectedFile: File | null = null

  zone.addEventListener('click', () => fileInput.click())
  cameraBtn.addEventListener('click', () => {
    fileInput.setAttribute('capture', 'environment')
    fileInput.click()
  })
  zone.addEventListener('dragover', e => { e.preventDefault(); corners.forEach(c => c.classList.add('active')) })
  zone.addEventListener('dragleave', () => corners.forEach(c => c.classList.remove('active')))
  zone.addEventListener('drop', e => {
    e.preventDefault()
    corners.forEach(c => c.classList.remove('active'))
    const file = (e as DragEvent).dataTransfer?.files?.[0]
    if (file) setFile(file)
  })
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]) })

  function setFile(file: File) {
    selectedFile = file
    previewImg.src = URL.createObjectURL(file)
    previewImg.style.display = 'block'
    placeholder.style.display = 'none'
    identifyBtn.removeAttribute('disabled')
    const ro = document.getElementById('result-outer') as HTMLElement; if (ro) ro.style.display = 'none'
    corners.forEach(c => c.classList.add('active'))
  }

  identifyBtn.addEventListener('click', async () => {
    if (!selectedFile) return
    identifyBtn.setAttribute('disabled', 'true')
    status.textContent = 'Uploading...'
    scanOverlay.classList.add('active')
    try {
      const formData = new FormData()
      formData.append('file', selectedFile)
      const uploadRes = await fetch('/api/upload-url', { method: 'POST', body: formData })
      const uploadData = await uploadRes.json()
      if (uploadData.error) throw new Error(uploadData.error)
      status.textContent = 'Examining the object...'
      const user_id = session?.user?.id || null
      const identifyRes = await fetch('/api/identify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: uploadData.key, user_id })
      })
      const identifyData = await identifyRes.json()
      if (identifyData.error) throw new Error(identifyData.error)
      const r = identifyData.result
      status.textContent = ''
      scanOverlay.classList.remove('active')

      document.getElementById('result-category')!.textContent = r.category
      document.getElementById('result-confidence')!.textContent = r.confidence
      document.getElementById('result-title')!.textContent = r.subcategory
      document.getElementById('result-condition')!.textContent = r.condition

      const notesEl = document.getElementById('result-notes') as HTMLElement
      const notes = [r.condition_notes, r.confidence_notes].filter(Boolean).join(' ')
      if (notesEl && notes) notesEl.textContent = notes

      const typedText = document.getElementById('typed-text') as HTMLElement
      const typedCursor = document.getElementById('typed-cursor') as HTMLElement
      if (typedText && typedCursor) {
        const desc = r.description || ''
        let ti = 0
        typedText.textContent = ''
        typedCursor.style.display = 'inline-block'
        function typeChar() {
          if (ti < desc.length) {
            typedText.textContent += desc[ti]; ti++
            setTimeout(typeChar, 22)
          } else {
            typedCursor.style.display = 'none'
          }
        }
        setTimeout(typeChar, 400)
      }
      document.getElementById('result-value')!.textContent =
        '£' + (r.value_range_low || 0).toLocaleString() + ' – £' + (r.value_range_high || 0).toLocaleString()

      if (r.maker) {
        document.getElementById('result-maker')!.textContent = r.maker
        document.getElementById('row-maker')!.style.display = 'flex'
      }
      if (r.period) {
        const period = r.period + (r.circa ? ' — ' + r.circa : '')
        document.getElementById('result-period')!.textContent = period
        document.getElementById('row-period')!.style.display = 'flex'
      }
      if (r.country_of_origin) {
        document.getElementById('result-origin')!.textContent = r.country_of_origin
        document.getElementById('row-origin')!.style.display = 'flex'
      }
      if (identifyData.id) {
        const ref = document.getElementById('result-ref') as HTMLElement
        if (ref) ref.textContent = 'REF ' + identifyData.id.slice(0,8).toUpperCase()
        const viewReport = document.getElementById('result-view-report') as HTMLElement
        const viewLink = document.getElementById('view-report-link') as HTMLAnchorElement
        if (viewReport) viewReport.style.display = 'block'
        if (viewLink) viewLink.href = '/valuation/' + identifyData.id
      }

      const outer = document.getElementById('result-outer') as HTMLElement
      outer.style.display = 'block'
      outer.scrollIntoView({ behavior: 'smooth', block: 'start' })

      if (session) {
        const bc = document.getElementById('blur-content') as HTMLElement
        const bo = document.getElementById('blur-overlay') as HTMLElement
        if (bc) bc.style.filter = 'none'
        if (bo) bo.style.display = 'none'
      }

      if (user_id && identifyData.id) {
              if (saveNote) saveNote.classList.add('visible')
      }
    } catch (err: any) {
      status.textContent = err.message
      scanOverlay.classList.remove('active')
    } finally {
      identifyBtn.removeAttribute('disabled')
    }
  })
</script>
