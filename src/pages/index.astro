      background: rgba(13,11,9,.82);
      backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      padding: 16px;
    }
    .upload-zone-wrap { position: relative; margin-bottom: 16px; }
    .corner {
      position: absolute; width: 18px; height: 18px; z-index: 2;
      transition: border-color .25s;
    }
    .corner.tl { top:0; left:0; border-top: 1px solid var(--borderHi); border-left: 1px solid var(--borderHi); }
    .corner.tr { top:0; right:0; border-top: 1px solid var(--borderHi); border-right: 1px solid var(--borderHi); }
    .corner.bl { bottom:0; left:0; border-bottom: 1px solid var(--borderHi); border-left: 1px solid var(--borderHi); }
    .corner.br { bottom:0; right:0; border-bottom: 1px solid var(--borderHi); border-right: 1px solid var(--borderHi); }
    .corner.active { border-color: var(--goldHi) !important; }
    @keyframes scanLine { 0% { top: 0%; } 100% { top: 100%; } }
    .scan-overlay {
      position: absolute; inset: 0; z-index: 10; pointer-events: none;
      display: none; overflow: hidden;
    }
    .scan-overlay.active { display: block; }
    .scan-line {
      position: absolute; left: 0; right: 0; height: 2px;
      background: linear-gradient(to right, transparent, var(--goldHi), transparent);
      box-shadow: 0 0 12px 2px rgba(196,168,112,0.6);
      animation: scanLine 1.8s ease-in-out infinite;
    }
    .scan-corners::before, .scan-corners::after {
      content: ""; position: absolute;
      width: 24px; height: 24px;
      border-color: var(--goldHi); border-style: solid;
    }
    .scan-corners::before { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
    .scan-corners::after  { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }
    .upload-zone {
      width: 100%; aspect-ratio: 1/1;
      background: rgba(255,255,255,.03);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      cursor: pointer; overflow: hidden;
      margin: 2px; position: relative; transition: background .2s;
    }
    .upload-zone:hover { background: rgba(255,255,255,.05); }
    .upload-zone img { width: 100%; height: 100%; object-fit: contain; position: absolute; inset: 0; background: var(--surface); }
    .upload-placeholder { text-align: center; padding: 24px; }
    .upload-icon {
      width: 44px; height: 44px; border-radius: 50%;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 16px; opacity: .5;
    }
    .upload-prompt {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 18px; font-weight: 400; color: var(--text); margin-bottom: 8px;
    }
    .upload-hint {
      font-family: 'Prata', Georgia, serif;
      font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--textDim);
    }
    .upload-actions { display: flex; flex-direction: column; gap: 8px; }
    .upload-dual { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 0; }
    .upload-slot { position: relative; cursor: pointer; }
    .upload-slot-zone {
      width: 100%; aspect-ratio: 1/1; background: rgba(255,255,255,.03);
      border: 1px solid var(--border);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
