---
import PublicShell from '../layouts/PublicShell.astro'
import { supabase } from '../lib/supabase'

const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

const { data: settings } = await supabase
  .from('site_settings')
  .select('key, value')
  .eq('site_id', SITE_ID)

const cfg: Record<string, string> = {}
settings?.forEach(r => { cfg[r.key] = r.value })

const { data: heroImages } = await supabase
  .from('hero_images')
  .select('image_url')
  .eq('site_id', SITE_ID)
  .eq('active', true)
  .order('sort_order', { ascending: true })

const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000)
const imagePool = heroImages && heroImages.length > 0 ? heroImages : [{ image_url: '' }]
const heroImage = imagePool[dayOfYear % imagePool.length].image_url
const heroOverlay = parseFloat(cfg.hero_overlay || '62') / 100
const heroHeadline = cfg.hero_headline || 'What is it worth?'
const heroSubtext = cfg.hero_subtext || 'Upload a photograph. Our AI identifies your antique and returns a professional valuation in seconds.'
const words = heroHeadline.split(' ')
const lastWord = words.slice(-1)[0]
const firstWords = words.slice(0, -1).join(' ')
---
<PublicShell title="GAUK Antiques — AI Antique Identification & Valuation">
  <style>


    /* ─── HERO ─── */
    .hero {
      position: relative; width: 100%; min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      overflow-x: hidden; padding: 60px 16px 24px;
      box-sizing: border-box;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
    }
    .hero-overlay {
      position: absolute; inset: 0;
    }
    .hero-content {
      position: relative; z-index: 2;
      width: 100%; max-width: 520px;
      margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 0;
      box-sizing: border-box;
    }
    @media (min-width: 768px) {
