  <section class="how-section">    <div class="how-heading">How It Works</div>    <div class="how-grid">      <div class="how-item">        <div class="how-number">I</div>        <div class="how-title">Photograph</div>        <div class="how-body">Upload a clear image of your piece from any angle</div>      </div>      <div class="how-item">        <div class="how-number">II</div>        <div class="how-title">Identify</div>        <div class="how-body">Our AI analyses maker, period, condition and provenance</div>      </div>      <div class="how-item">        <div class="how-number">III</div>        <div class="how-title">Value</div>        <div class="how-body">Receive a professional valuation with market estimate</div>      </div>    </div>  </section>  <nav class="bottom-nav">    <a href="/" class="nav-tab active">      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">        <rect x="3" y="3" width="18" height="18" rx="0"/>        <circle cx="8.5" cy="8.5" r="1.5"/>        <polyline points="21 15 16 10 5 21"/>      </svg>      Identify    </a>    <a href="/library" class="nav-tab">      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>      </svg>      Library    </a>    <a href="/auth/signin" class="nav-tab" id="account-tab">      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>        <circle cx="12" cy="7" r="4"/>      </svg>      Account    </a>  </nav></Layout><script>  import { createClient } from '@supabase/supabase-js'  const supabase = createClient(    import.meta.env.PUBLIC_SUPABASE_URL,    import.meta.env.PUBLIC_SUPABASE_ANON_KEY  )  const themeBtn = document.getElementById('theme-btn')  themeBtn?.addEventListener('click', () => {    const current = document.documentElement.getAttribute('data-theme')    const next = current === 'light' ? 'dark' : 'light'    document.documentElement.setAttribute('data-theme', next)    localStorage.setItem('theme', next)  })  const { data: { session } } = await supabase.auth.getSession()  if (session) {    const signinLink = document.getElementById('signin-link')    if (signinLink) {      signinLink.textContent = session.user.email?.split('@')[0] || 'Account'      signinLink.setAttribute('href', '/library')    }    const accountTab = document.getElementById('account-tab')    if (accountTab) accountTab.setAttribute('href', '/library')  }  const zone = document.getElementById('upload-zone') as HTMLElement  const fileInput = document.getElementById('file-input') as HTMLInputElement  const previewImg = document.getElementById('preview-img') as HTMLImageElement  const placeholder = document.getElementById('upload-placeholder') as HTMLElement  const identifyBtn = document.getElementById('identify-btn') as HTMLButtonElement  const cameraBtn = document.getElementById('camera-btn') as HTMLButtonElement  const corners = document.querySelectorAll('.corner')  const status = document.getElementById('status') as HTMLElement  const resultSection = document.getElementById('result-section') as HTMLElement  const saveNote = document.getElementById('save-note') as HTMLElement  const scanOverlay = document.getElementById('scan-overlay') as HTMLElement  let selectedFile: File | null = null  zone.addEventListener('click', () => fileInput.click())  cameraBtn.addEventListener('click', () => {    fileInput.setAttribute('capture', 'environment')    fileInput.click()  })  zone.addEventListener('dragover', e => { e.preventDefault(); corners.forEach(c => c.classList.add('active')) })  zone.addEventListener('dragleave', () => corners.forEach(c => c.classList.remove('active')))  zone.addEventListener('drop', e => {    e.preventDefault()    corners.forEach(c => c.classList.remove('active'))    const file = (e as DragEvent).dataTransfer?.files?.[0]    if (file) setFile(file)  })  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]) })  function setFile(file: File) {    selectedFile = file    previewImg.src = URL.createObjectURL(file)    previewImg.style.display = 'block'    placeholder.style.display = 'none'    identifyBtn.removeAttribute('disabled')    resultSection.classList.remove('visible')    corners.forEach(c => c.classList.add('active'))  }  identifyBtn.addEventListener('click', async () => {    if (!selectedFile) return    identifyBtn.setAttribute('disabled', 'true')    status.textContent = 'Uploading...'    scanOverlay.classList.add('active')    try {      const formData = new FormData()      formData.append('file', selectedFile)      const uploadRes = await fetch('/api/upload-url', { method: 'POST', body: formData })      const uploadData = await uploadRes.json()      if (uploadData.error) throw new Error(uploadData.error)      status.textContent = 'Examining the object...'      const user_id = session?.user?.id || null      const identifyRes = await fetch('/api/identify', {        method: 'POST',        headers: { 'Content-Type': 'application/json' },        body: JSON.stringify({ key: uploadData.key, user_id })      })      const identifyData = await identifyRes.json()      if (identifyData.error) throw new Error(identifyData.error)      const r = identifyData.result      status.textContent = ''      scanOverlay.classList.remove('active')      document.getElementById('result-category')!.textContent = r.category      document.getElementById('result-confidence')!.textContent = r.confidence      document.getElementById('result-title')!.textContent = r.subcategory      document.getElementById('result-condition')!.textContent = r.condition      document.getElementById('result-value')!.textContent =        '£' + (r.value_range_low || 0).toLocaleString() + ' – £' + (r.value_range_high || 0).toLocaleString()      if (r.maker) {        document.getElementById('result-maker')!.textContent = r.maker        document.getElementById('row-maker')!.style.display = 'flex'      }      if (r.period) {        document.getElementById('result-period')!.textContent = r.period + (r.circa ? ' — ' + r.circa : '')        document.getElementById('row-period')!.style.display = 'flex'      }      if (r.country_of_origin) {        document.getElementById('result-origin')!.textContent = r.country_of_origin        document.getElementById('row-origin')!.style.display = 'flex'      }      if (identifyData.id) {        const footer = document.getElementById('result-footer') as HTMLElement        const ref = document.getElementById('result-ref') as HTMLElement        footer.style.display = 'flex'        ref.textContent = 'REF ' + identifyData.id.slice(0,8).toUpperCase()      }      resultSection.classList.add('visible')
      const resultOuter = document.getElementById('result-outer') as HTMLElement
      if (resultOuter) resultOuter.style.display = 'block'      const typedText = document.getElementById('typed-text') as HTMLElement      const typedCursor = document.getElementById('typed-cursor') as HTMLElement      const desc = r.description || ''      let i = 0      typedText.textContent = ''      typedCursor.style.display = 'inline-block'      function type() {        if (i < desc.length) {          typedText.textContent += desc[i]; i++          setTimeout(type, 22)        } else {          typedCursor.style.display = 'none'        }      }      setTimeout(type, 300)      if (session) {        const blurContent = document.getElementById('blur-content') as HTMLElement        const blurOverlay = document.getElementById('blur-overlay') as HTMLElement        if (blurContent) blurContent.style.filter = 'none'        if (blurOverlay) blurOverlay.style.display = 'none'      }      if (user_id && identifyData.id) saveNote.classList.add('visible')    } catch (err: any) {      status.textContent = err.message      scanOverlay.classList.remove('active')    } finally {      identifyBtn.removeAttribute('disabled')    }  })</script>