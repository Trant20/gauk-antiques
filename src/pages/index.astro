---
import { ANTIQUES_SITE_ID } from '../lib/constants'
import PublicShell from '../layouts/PublicShell.astro'
import { supabase } from '../lib/supabase'
import AIHeroWidget from '../components/AIHeroWidget.astro'
import IdentificationResult from '../components/IdentificationResult.astro'


const { data: settings } = await supabase
  .from('site_settings')
  .select('key, value')
  .eq('site_id', ANTIQUES_SITE_ID)

const cfg: Record<string, string> = {}
settings?.forEach(r => { cfg[r.key] = r.value })

const { data: heroImages } = await supabase
  .from('hero_images')
  .select('image_url')
  .eq('site_id', ANTIQUES_SITE_ID)
  .eq('active', true)
  .order('sort_order', { ascending: true })

const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000)
const imagePool = heroImages && heroImages.length > 0 ? heroImages : [{ image_url: '' }]
const heroImage = imagePool[dayOfYear % imagePool.length].image_url
const heroOverlay = parseFloat(cfg.hero_overlay || '62') / 100
const heroHeadline = cfg.hero_headline || 'What is it worth?'
const heroSubtext = cfg.hero_subtext || 'Upload a photograph. Our AI identifies your antique and returns a professional valuation in seconds.'
const words = heroHeadline.split(' ')
const lastWord = words.slice(-1)[0]
const firstWords = words.slice(0, -1).join(' ')
---
<PublicShell title="GAUK Antiques — AI Antique Identification & Valuation" description="Upload a photograph and our AI identifies your antique in seconds — maker, period, condition and estimated market value. Free to try, no account required.">
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "GAUK Antiques — AI Antique Identification & Valuation",
  "description": "Upload a photograph and our AI identifies your antique in seconds — maker, period, condition and estimated market value.",
  "url": "https://gaukantiques.com",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "GBP",
    "description": "Free identification — no account required"
  },
  "publisher": { "@type": "Organization", "name": "GAUK Antiques", "url": "https://gaukantiques.com" }
})} />

  <style>


    /* ─── HERO ─── */
    .hero {
      position: relative; width: 100%; min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: flex-start;
      overflow-x: hidden; padding: 60px 16px 24px;
      box-sizing: border-box;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
    }
    .hero-overlay {
      position: absolute; inset: 0;
    }
    .hero-content {
      position: relative; z-index: 2;
      width: 100%; max-width: 520px;
      margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 0;
      box-sizing: border-box;
    }
    @media (min-width: 768px) {
      .hero-content { max-width: 740px; }
    }
    .hero-headline {
      text-align: center; margin-bottom: 12px;
    }
    .hero-eyebrow {
      font-family: 'Prata', Georgia, serif;
      font-size: 9px; letter-spacing: 5px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 16px;
    }
    .hero-h1 {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: clamp(36px, 6vw, 64px); font-weight: 400; line-height: 1.1;
      color: var(--text);
    }
    .hero-h1 em { font-style: italic; color: var(--goldHi); }

    /* ─── RESULT ─── */
    /* ─── PARCHMENT RESULT CARD ─── */
    .result-section {
      background: #EFE7D9;
      color: #1C1810;
      max-width: 520px;
      margin: 0 auto;
    }
    .result-badges {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 20px 0;
    }
    .result-category {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
      color: #7A5C20;
    }
    .result-confidence {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
      padding: 4px 10px; border: 1px solid #C4B49E; color: #8A7A66;
    }
    .result-title {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: clamp(22px, 5vw, 32px); font-weight: 400; line-height: 1.2;
      color: #1C1810 !important; padding: 12px 20px 0; margin: 0;
    }
    .typed-cursor {
      display: inline-block; width: 2px; height: 1em;
      background: #7A5C20; margin-left: 2px;
      vertical-align: text-bottom;
      animation: blink .7s step-end infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
    .result-desc {
      font-family: 'Prata', Georgia, serif;
      font-size: 16px; line-height: 1.9; color: #5C5040;
      padding: 14px 20px; border-bottom: 1px solid #C4B49E; margin: 0;
    }
    #typed-text { font-size: 16px; }
    .result-id-table { padding: 0 20px; border-bottom: 1px solid #C4B49E; }
    .result-id-row {
      display: flex; gap: 16px; align-items: flex-start;
      padding: 12px 0; border-bottom: 1px solid rgba(196,180,158,.3);
    }
    .result-id-row:last-child { border-bottom: none; }
    .result-id-key {
      width: 90px; flex-shrink: 0;
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
      color: #8A7A66; padding-top: 2px;
    }
    .result-id-val {
      font-family: 'Prata', Georgia, serif;
      font-size: 16px; color: #1C1810; line-height: 1.5; flex: 1;
    }
    .result-value-block {
      background: #E6DCCB;
      border-bottom: 1px solid #C4B49E;
      padding: 28px 20px; text-align: center;
    }
    .result-value-label {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 4px; text-transform: uppercase;
      color: #8A7A66; margin-bottom: 10px;
    }
    .result-value {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: clamp(32px, 7vw, 48px); font-weight: 400; line-height: 1;
      color: #7A5C20; letter-spacing: -1px;
    }
    .result-blur-gate { position: relative; }
    .result-blur-content { filter: blur(5px); pointer-events: none; user-select: none; }
    .result-notes-preview { padding: 24px 20px; background: #EAE1D2; }
    .result-notes-label { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; margin-bottom: 10px; }
    .result-notes-text { font-family: 'Prata', Georgia, serif; font-size: 15px; line-height: 1.9; color: #5C5040; }
    .result-gate-cta { padding: 20px 20px 0; border-top: 1px solid #C4B49E; }
    .result-gate-cta-text { font-family: 'Prata', Georgia, serif; font-size: 16px; line-height: 1.8; color: #5C5040; margin-bottom: 14px; min-height: 24px; }
    .result-gate-cta-cursor { display: inline-block; width: 2px; height: 1em; background: #7A5C20; margin-left: 2px; vertical-align: text-bottom; animation: blink .7s step-end infinite; }
    .result-gate-register {
      display: block; width: 100%; padding: 15px;
      background: #B8860B; border: none;
      font-family: 'Prata', Georgia, serif; font-size: 11px;
      letter-spacing: 3px; text-transform: uppercase;
      color: #fff; text-decoration: none; text-align: center;
      transition: background .2s; margin-bottom: 20px;
    }
    .result-gate-register:hover { background: #9A7009; }
    .result-footer-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 20px; border-top: 1px solid #C4B49E;
      background: #EFE7D9;
    }
    .result-footer-brand {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 13px; font-style: italic; color: #7A5C20;
    }
    .result-footer-ref {
      font-family: 'Prata', Georgia, serif;
      font-size: 10px; letter-spacing: 2px; color: #8A7A66;
    }
    .save-note {
      display: none; padding: 10px 20px;
      font-family: 'Prata', Georgia, serif;
      font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
      color: #7A5C20; background: #EFE7D9;
    }
    .save-note.visible { display: block; }

    .result-eyebrow {
      font-family: 'Prata', Georgia, serif;
      font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--gold); margin-bottom: 12px;
      display: flex; align-items: center; justify-content: space-between;
    }



    /* ─── HOW ─── */
    .how-section { overflow-x: hidden;
      padding: 64px 24px 100px; max-width: 520px; margin: 0 auto;
      border-top: 1px solid var(--border);
    }
    .how-heading {
      font-family: 'Prata', Georgia, serif;
      font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
      color: var(--textMute); margin-bottom: 32px; text-align: center;
    }
    .how-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; text-align: center; width: 100%; }
    @media (max-width: 480px) { .how-grid { grid-template-columns: 1fr; } .how-item:not(:last-child) { border-right: none; border-bottom: 1px solid var(--border); padding-bottom: 24px; margin-bottom: 24px; } }
    .how-item { padding: 0 12px; }
    .how-item:not(:last-child) { border-right: 1px solid var(--border); }
    .how-number {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 36px; color: var(--goldLo); margin-bottom: 12px;
    }
    .how-title {
      font-family: 'Playfair Display', Didot, Georgia, serif;
      font-size: 18px; color: var(--text); margin-bottom: 8px;
    }
    .how-body {
      font-family: 'Prata', Georgia, serif;
      font-size: 18px; line-height: 1.8; color: var(--textMute);
    }
  </style>


  <section class="hero">
    <div class="hero-bg" style={`background-image: url('${heroImage}')`}></div>
    <div class="hero-overlay" style={`background: rgba(13,11,9,${heroOverlay})`}></div>
    <div class="hero-content">
      <div class="hero-headline a0">

        <h1 class="hero-h1">{firstWords} <em>{lastWord}</em></h1>
      </div>
      <AIHeroWidget context="general" category="Antiques" />
    </div>
  </section>

  <IdentificationResult />

  <section class="how-section">
    <div class="how-heading">How It Works</div>
    <div class="how-grid">
      <div class="how-item">
        <div class="how-number">I</div>
        <div class="how-title">Photograph</div>
        <div class="how-body">Upload a clear image of your piece from any angle</div>
      </div>
      <div class="how-item">
        <div class="how-number">II</div>
        <div class="how-title">Identify</div>
        <div class="how-body">Our AI analyses maker, period, condition and provenance</div>
      </div>
      <div class="how-item">
        <div class="how-number">III</div>
        <div class="how-title">Value</div>
        <div class="how-body">Receive a professional valuation with market estimate</div>
      </div>
    </div>
  </section>
</PublicShell>

<script>
  import { supabase } from '../lib/supabase-browser'
  import { wireIdentificationResult } from '../lib/identification-handler'

  const { data: { session } } = await supabase.auth.getSession()
  if (session) {
    window.__gauk_user_id = session.user.id
  }

  wireIdentificationResult('', session)
</script>
