---
interface Props {
  context?: string
  category?: string
}
const { context = 'general', category = 'Antiques' } = Astro.props
---

<div class="ai-widget" id="ai-widget">
  <!-- TAB SWITCHER -->
  <div class="widget-tabs">
    <button class="widget-tab active" id="tab-identify" data-tab="identify">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="0"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      Identify
    </button>
    <button class="widget-tab" id="tab-ask" data-tab="ask">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      Ask
    </button>
  </div>

  <!-- IDENTIFY TAB -->
  <div class="widget-panel" id="panel-identify">
    <div class="upload-dual">
      <div class="upload-slot" id="slot-primary">
        <div class="upload-slot-zone" id="zone-primary">
          <input type="file" id="file-input" accept="image/*" style="display:none" />
          <img id="preview-img" alt="Front" />
          <div class="scan-overlay scan-corners" id="scan-overlay">
            <div class="scan-line"></div>
          </div>
          <div class="upload-slot-placeholder" id="placeholder-primary">
            <div class="upload-slot-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="0"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
            <div class="upload-slot-hint"><span class="slot-required">Front</span> · Required</div>
          </div>
        </div>
        <div class="upload-slot-label">Front / Main View</div>
      </div>
      <div class="upload-slot" id="slot-secondary">
        <div class="upload-slot-zone" id="zone-secondary">
          <input type="file" id="file-input-secondary" accept="image/*" style="display:none" />
          <img id="preview-img-secondary" alt="Back" />
          <div class="upload-slot-placeholder" id="placeholder-secondary">
            <div class="upload-slot-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="12" cy="12" r="9"/>
                <line x1="12" y1="8" x2="12" y2="16"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
              </svg>
            </div>
            <div class="upload-slot-hint"><span class="slot-optional">Mark</span> · Optional</div>
          </div>
        </div>
        <div class="upload-slot-label">Signature · Mark · Hallmark</div>
      </div>
    </div>
    <div class="upload-actions">
      <button class="btn-primary" id="identify-btn" disabled>Identify This Item</button>
      <button class="btn-ghost" id="camera-btn">Use Camera — Front</button>
    </div>
    <div class="status-text" id="status"></div>
  </div>

  <!-- ASK TAB -->
  <div class="widget-panel" id="panel-ask" style="display:none">
    <div class="ask-thread" id="ask-thread">
      <div class="ask-empty">
        <div class="ask-empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <div class="ask-empty-title">Ask our {category} expert</div>
        <div class="ask-empty-sub">Cleaning, identification, valuation, history — ask anything.</div>
        <div class="ask-suggestions" id="ask-suggestions">
          <button class="ask-suggestion" data-q="How do I clean and care for my piece?">How do I clean and care for my piece?</button>
          <button class="ask-suggestion" data-q="How can I tell if it is genuine?">How can I tell if it is genuine?</button>
          <button class="ask-suggestion" data-q="Where is the best place to sell it?">Where is the best place to sell it?</button>
        </div>
      </div>
    </div>
    <div class="ask-input-wrap">
      <textarea class="ask-input" id="ask-input" placeholder={`Ask anything about ${category.toLowerCase()}...`} rows="2"></textarea>
      <button class="ask-send" id="ask-send">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
    <div class="ask-guest-note" id="ask-guest-note" style="display:none">
      <span id="ask-questions-left"></span> questions remaining — <a href="/auth/signup" class="ask-gate-link">register free for unlimited access</a>
    </div>
  </div>
</div>

<!-- ASK MOBILE MODAL -->
<div class="ask-modal-overlay" id="ask-modal-overlay" style="display:none">
  <div class="ask-modal">
    <div class="ask-modal-header">
      <div class="ask-modal-title">Ask our {category} expert</div>
      <button class="ask-modal-close" id="ask-modal-close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="ask-thread ask-modal-thread" id="ask-modal-thread">
      <div class="ask-empty">
        <div class="ask-empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <div class="ask-empty-title">Ask our {category} expert</div>
        <div class="ask-empty-sub">Cleaning, identification, valuation, history — ask anything.</div>
        <div class="ask-suggestions" id="ask-modal-suggestions">
          <button class="ask-suggestion" data-q="How do I clean and care for my piece?">How do I clean and care for my piece?</button>
          <button class="ask-suggestion" data-q="How can I tell if it is genuine?">How can I tell if it is genuine?</button>
          <button class="ask-suggestion" data-q="Where is the best place to sell it?">Where is the best place to sell it?</button>
        </div>
      </div>
    </div>
    <div class="ask-input-wrap ask-modal-input-wrap">
      <textarea class="ask-input" id="ask-modal-input" placeholder={`Ask anything about ${category.toLowerCase()}...`} rows="2"></textarea>
      <button class="ask-send" id="ask-modal-send">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  .ai-widget {
    width: 100%;
    background: rgba(13,11,9,.82);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
  }

  /* TABS */
  .widget-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
  }
  .widget-tab {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px 16px;
    background: transparent; border: none;
    font-family: 'Prata', Georgia, serif; font-size: 10px;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--textDim); cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color .2s, border-color .2s;
  }
  .widget-tab:hover { color: var(--text); }
  .widget-tab.active { color: var(--goldHi); border-bottom-color: var(--goldHi); }

  /* PANELS */
  .widget-panel { padding: 16px; }

  /* UPLOAD */
  .upload-dual { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .upload-slot { position: relative; cursor: pointer; }
  .upload-slot-zone {
    width: 100%; aspect-ratio: 1/1; background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    overflow: hidden; transition: background .2s, border-color .2s; position: relative;
  }
  .upload-slot-zone:hover { background: rgba(255,255,255,.05); border-color: var(--borderHi); }
  .upload-slot-zone.has-image { border-color: var(--borderHi); }
  .upload-slot img { width: 100%; height: 100%; object-fit: contain; position: absolute; inset: 0; background: var(--surface); display: none; }
  .upload-slot img.visible { display: block; }
  .upload-slot-label { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--textDim); margin-top: 8px; text-align: center; }
  .upload-slot-placeholder { text-align: center; padding: 12px; }
  .upload-slot-icon { opacity: .7; margin: 0 auto 10px; display: flex; align-items: center; justify-content: center; }
  .upload-slot-hint { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--textDim); }
  .slot-required { color: var(--goldHi); font-size: 13px; }
  .slot-optional { color: var(--text); font-size: 13px; }

  /* SCAN */
  @keyframes scanLine { 0% { top: 0%; } 100% { top: 100%; } }
  .scan-overlay { position: absolute; inset: 0; z-index: 10; pointer-events: none; display: none; overflow: hidden; }
  .scan-overlay.active { display: block; }
  .scan-line { position: absolute; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent, var(--goldHi), transparent); box-shadow: 0 0 12px 2px rgba(196,168,112,0.6); animation: scanLine 1.8s ease-in-out infinite; }
  .scan-corners::before, .scan-corners::after { content: ''; position: absolute; width: 24px; height: 24px; border-color: var(--goldHi); border-style: solid; }
  .scan-corners::before { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
  .scan-corners::after { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }

  /* BUTTONS */
  .upload-actions { display: flex; flex-direction: column; gap: 8px; }
  .btn-primary { width: 100%; padding: 15px; background: var(--text); border: none; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--bg); cursor: pointer; transition: opacity .2s; }
  .btn-primary:hover { opacity: .9; }
  .btn-primary:disabled { opacity: .4; cursor: default; }
  .btn-ghost { width: 100%; padding: 15px; background: transparent; border: 1px solid var(--border); font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--textDim); cursor: pointer; transition: border-color .25s, color .25s; }
  .btn-ghost:hover { border-color: var(--borderHi); color: var(--text); }
  .status-text { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); text-align: center; min-height: 18px; margin-top: 12px; }

  /* ASK THREAD */
  .ask-thread { min-height: 200px; max-height: 320px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; margin-bottom: 12px; }
  .ask-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 8px; text-align: center; flex: 1; min-height: 200px; }
  .ask-empty-icon { opacity: .3; margin-bottom: 12px; color: var(--goldHi); }
  .ask-empty-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 16px; font-style: italic; color: var(--text); margin-bottom: 6px; }
  .ask-empty-sub { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 1px; color: var(--textDim); line-height: 1.6; margin-bottom: 16px; }
  .ask-suggestions { display: flex; flex-direction: column; gap: 6px; width: 100%; }
  .ask-suggestion { background: rgba(255,255,255,.04); border: 1px solid var(--border); padding: 8px 12px; font-family: 'Prata', Georgia, serif; font-size: 11px; color: var(--textDim); cursor: pointer; text-align: left; transition: border-color .2s, color .2s; }
  .ask-suggestion:hover { border-color: var(--borderHi); color: var(--text); }

  /* ASK MESSAGES */
  .ask-msg { display: flex; flex-direction: column; gap: 4px; }
  .ask-msg-user { align-items: flex-end; }
  .ask-msg-ai { align-items: flex-start; }
  .ask-bubble { max-width: 85%; padding: 10px 14px; font-family: 'Prata', Georgia, serif; font-size: 13px; line-height: 1.7; }
  .ask-bubble-user { background: var(--goldHi); color: #1C1810; }
  .ask-bubble-ai { background: rgba(255,255,255,.06); border: 1px solid var(--border); color: var(--text); }
  .ask-source { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); opacity: .7; padding: 0 2px; }
  .ask-typing { display: flex; gap: 4px; align-items: center; padding: 10px 14px; background: rgba(255,255,255,.06); border: 1px solid var(--border); width: fit-content; }
  .ask-typing-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); opacity: .4; animation: typingPulse 1.2s ease-in-out infinite; }
  .ask-typing-dot:nth-child(2) { animation-delay: .2s; }
  .ask-typing-dot:nth-child(3) { animation-delay: .4s; }
  @keyframes typingPulse { 0%,100%{opacity:.4} 50%{opacity:1} }

  /* ASK INPUT */
  .ask-input-wrap { display: flex; gap: 8px; align-items: flex-end; }
  .ask-input { flex: 1; background: rgba(255,255,255,.04); border: 1px solid var(--border); padding: 10px 14px; font-family: 'Prata', Georgia, serif; font-size: 13px; color: var(--text); outline: none; resize: none; line-height: 1.5; transition: border-color .2s; }
  .ask-input:focus { border-color: var(--borderHi); }
  .ask-input::placeholder { color: var(--textDim); }
  .ask-send { width: 44px; height: 44px; background: var(--goldHi); border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #1C1810; flex-shrink: 0; transition: opacity .2s; }
  .ask-send:hover { opacity: .85; }
  .ask-send:disabled { opacity: .4; cursor: default; }
  .ask-guest-note { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 1px; color: var(--textDim); text-align: center; margin-top: 8px; }
  .ask-gate-link { color: var(--goldHi); text-decoration: none; }
  .ask-gate-link:hover { text-decoration: underline; }

  /* MOBILE MODAL */
  .ask-modal-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(13,11,9,.96); display: flex; flex-direction: column; }
  .ask-modal { display: flex; flex-direction: column; height: 100%; padding: env(safe-area-inset-top, 20px) 0 env(safe-area-inset-bottom, 0); }
  .ask-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .ask-modal-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 18px; font-style: italic; color: var(--text); }
  .ask-modal-close { background: none; border: none; color: var(--textDim); cursor: pointer; padding: 4px; display: flex; align-items: center; }
  .ask-modal-thread { flex: 1; max-height: none; padding: 16px 20px; overflow-y: auto; }
  .ask-modal-input-wrap { padding: 12px 20px; border-top: 1px solid var(--border); flex-shrink: 0; }

  @media (min-width: 768px) {
    .ask-modal-overlay { display: none !important; }
  }
</style>

<script define:vars={{ context }}>
  const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'
  const GUEST_LIMIT = 3
  const isMobile = () => window.innerWidth < 768

  // ── STATE ──
  let selectedFile = null
  let selectedFileSecondary = null
  let askHistory = []
  let guestQuestions = parseInt(sessionStorage.getItem('ask_guest_count') || '0')
  let activeThread = 'desktop' // 'desktop' | 'mobile'

  // ── TABS ──
  const tabIdentify = document.getElementById('tab-identify')
  const tabAsk = document.getElementById('tab-ask')
  const panelIdentify = document.getElementById('panel-identify')
  const panelAsk = document.getElementById('panel-ask')
  const modalOverlay = document.getElementById('ask-modal-overlay')
  const modalClose = document.getElementById('ask-modal-close')

  tabIdentify.addEventListener('click', () => {
    tabIdentify.classList.add('active')
    tabAsk.classList.remove('active')
    panelIdentify.style.display = 'block'
    panelAsk.style.display = 'none'
    if (modalOverlay) modalOverlay.style.display = 'none'
    document.body.style.overflow = ''
  })

  tabAsk.addEventListener('click', () => {
    tabAsk.classList.add('active')
    tabIdentify.classList.remove('active')
    panelAsk.style.display = 'block'
    panelIdentify.style.display = 'none'
    if (isMobile()) {
      modalOverlay.style.display = 'flex'
      document.body.style.overflow = 'hidden'
      activeThread = 'mobile'
    } else {
      activeThread = 'desktop'
    }
  })

  modalClose.addEventListener('click', () => {
    modalOverlay.style.display = 'none'
    document.body.style.overflow = ''
    tabIdentify.click()
  })

  // ── UPLOAD ──
  const zonePrimary = document.getElementById('zone-primary')
  const zoneSecondary = document.getElementById('zone-secondary')
  const fileInput = document.getElementById('file-input')
  const fileInputSecondary = document.getElementById('file-input-secondary')
  const previewImg = document.getElementById('preview-img')
  const previewImgSecondary = document.getElementById('preview-img-secondary')
  const placeholderPrimary = document.getElementById('placeholder-primary')
  const placeholderSecondary = document.getElementById('placeholder-secondary')
  const identifyBtn = document.getElementById('identify-btn')
  const cameraBtn = document.getElementById('camera-btn')
  const status = document.getElementById('status')
  const scanOverlay = document.getElementById('scan-overlay')

  zonePrimary.addEventListener('click', () => fileInput.click())
  zoneSecondary.addEventListener('click', () => fileInputSecondary.click())
  cameraBtn.addEventListener('click', () => { fileInput.setAttribute('capture', 'environment'); fileInput.click() })

  zonePrimary.addEventListener('dragover', e => { e.preventDefault(); zonePrimary.style.borderColor = 'var(--goldHi)' })
  zonePrimary.addEventListener('dragleave', () => { zonePrimary.style.borderColor = '' })
  zonePrimary.addEventListener('drop', e => { e.preventDefault(); zonePrimary.style.borderColor = ''; const f = e.dataTransfer?.files?.[0]; if (f) setFile(f) })
  zoneSecondary.addEventListener('dragover', e => { e.preventDefault(); zoneSecondary.style.borderColor = 'var(--goldHi)' })
  zoneSecondary.addEventListener('dragleave', () => { zoneSecondary.style.borderColor = '' })
  zoneSecondary.addEventListener('drop', e => { e.preventDefault(); zoneSecondary.style.borderColor = ''; const f = e.dataTransfer?.files?.[0]; if (f) setFileSecondary(f) })

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]) })
  fileInputSecondary.addEventListener('change', () => { if (fileInputSecondary.files?.[0]) setFileSecondary(fileInputSecondary.files[0]) })

  function setFile(file) {
    selectedFile = file
    previewImg.src = URL.createObjectURL(file)
    previewImg.classList.add('visible')
    placeholderPrimary.style.display = 'none'
    zonePrimary.classList.add('has-image')
    identifyBtn.removeAttribute('disabled')
    document.dispatchEvent(new CustomEvent('widget-reset-result'))
  }

  function setFileSecondary(file) {
    selectedFileSecondary = file
    previewImgSecondary.src = URL.createObjectURL(file)
    previewImgSecondary.classList.add('visible')
    placeholderSecondary.style.display = 'none'
    zoneSecondary.classList.add('has-image')
  }

  identifyBtn.addEventListener('click', async () => {
    if (!selectedFile) return
    identifyBtn.setAttribute('disabled', 'true')
    status.textContent = 'Uploading...'
    scanOverlay.classList.add('active')
    try {
      const formData = new FormData()
      formData.append('file', selectedFile)
      const uploadRes = await fetch('/api/upload-url', { method: 'POST', body: formData })
      const uploadData = await uploadRes.json()
      if (uploadData.error) throw new Error(uploadData.error)

      let secondaryKey = null
      if (selectedFileSecondary) {
        const secFormData = new FormData()
        secFormData.append('file', selectedFileSecondary)
        const secRes = await fetch('/api/upload-url', { method: 'POST', body: secFormData })
        const secData = await secRes.json()
        if (!secData.error) secondaryKey = secData.key
      }

      status.textContent = 'Examining the object...'
      const identifyRes = await fetch('/api/identify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: uploadData.key, secondary_key: secondaryKey, context, user_id: window.__gauk_user_id || null })
      })
      const identifyData = await identifyRes.json()
      if (identifyData.error) throw new Error(identifyData.error)

      status.textContent = ''
      scanOverlay.classList.remove('active')
      document.dispatchEvent(new CustomEvent('identification-complete', { detail: identifyData }))
    } catch (err) {
      status.textContent = err.message
      scanOverlay.classList.remove('active')
    } finally {
      identifyBtn.removeAttribute('disabled')
    }
  })

  // ── ASK ──
  function getThread() {
    return activeThread === 'mobile'
      ? document.getElementById('ask-modal-thread')
      : document.getElementById('ask-thread')
  }

  function getInput() {
    return activeThread === 'mobile'
      ? document.getElementById('ask-modal-input')
      : document.getElementById('ask-input')
  }

  function appendMessage(role, text, sources) {
    const thread = getThread()
    const empty = thread.querySelector('.ask-empty')
    if (empty) empty.remove()

    const msg = document.createElement('div')
    msg.className = `ask-msg ask-msg-${role}`
    const bubble = document.createElement('div')
    bubble.className = `ask-bubble ask-bubble-${role}`
    bubble.textContent = text
    msg.appendChild(bubble)
    if (sources && sources.length > 0) {
      const src = document.createElement('div')
      src.className = 'ask-source'
      src.textContent = 'From the GAUK spine: ' + sources.join(', ')
      msg.appendChild(src)
    }
    thread.appendChild(msg)
    thread.scrollTop = thread.scrollHeight
  }

  function showTyping() {
    const thread = getThread()
    const el = document.createElement('div')
    el.className = 'ask-typing'
    el.id = 'ask-typing-indicator'
    el.innerHTML = '<div class="ask-typing-dot"></div><div class="ask-typing-dot"></div><div class="ask-typing-dot"></div>'
    thread.appendChild(el)
    thread.scrollTop = thread.scrollHeight
  }

  function hideTyping() {
    document.getElementById('ask-typing-indicator')?.remove()
  }

  async function sendQuestion(question) {
    if (!question.trim()) return
    appendMessage('user', question, null)
    askHistory.push({ role: 'user', content: question })
    showTyping()

    try {
      const res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: question,
          history: askHistory,
          context,
          user_id: window.__gauk_user_id || null,
          site_id: SITE_ID
        })
      })
      const data = await res.json()
      hideTyping()
      if (data.error) throw new Error(data.error)
      appendMessage('ai', data.answer, data.sources)
      askHistory.push({ role: 'assistant', content: data.answer })

      if (!window.__gauk_user_id) {
        guestQuestions++
        sessionStorage.setItem('ask_guest_count', guestQuestions)
        updateGuestNote()
      }
    } catch (err) {
      hideTyping()
      appendMessage('ai', 'Something went wrong — please try again.', null)
    }
  }

  function updateGuestNote() {
    const note = document.getElementById('ask-guest-note')
    const left = document.getElementById('ask-questions-left')
    if (!window.__gauk_user_id && note) {
      const remaining = Math.max(0, GUEST_LIMIT - guestQuestions)
      note.style.display = 'block'
      left.textContent = remaining + (remaining === 1 ? ' question' : ' questions') + ' remaining'
    }
  }

  function setupSend(inputId, sendId) {
    const input = document.getElementById(inputId)
    const send = document.getElementById(sendId)
    if (!input || !send) return
    send.addEventListener('click', () => {
      const q = input.value.trim()
      if (!q) return
      if (!window.__gauk_user_id && guestQuestions >= GUEST_LIMIT) {
        appendMessage('ai', 'You have used your free questions. Register free to continue asking.', null)
        return
      }
      input.value = ''
      input.style.height = 'auto'
      sendQuestion(q)
    })
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send.click() }
    })
    input.addEventListener('input', () => {
      input.style.height = 'auto'
      input.style.height = input.scrollHeight + 'px'
    })
  }

  setupSend('ask-input', 'ask-send')
  setupSend('ask-modal-input', 'ask-modal-send')

  // Suggestion chips
  document.querySelectorAll('.ask-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-q')
      if (isMobile()) {
        activeThread = 'mobile'
        const input = document.getElementById('ask-modal-input')
        if (input) { input.value = q; document.getElementById('ask-modal-send').click() }
      } else {
        activeThread = 'desktop'
        const input = document.getElementById('ask-input')
        if (input) { input.value = q; document.getElementById('ask-send').click() }
      }
    })
  })

  updateGuestNote()
</script>
