---
interface Props {
  context?: string
  category?: string
}
const { context = 'general', category = 'Antiques' } = Astro.props
---

<div class="ai-widget" id="ai-widget">
  <!-- TAB SWITCHER -->
  <div class="widget-tabs">
    <button class="widget-tab active" id="tab-identify">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="0"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      Identify
    </button>
    <button class="widget-tab" id="tab-ask">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Ask
    </button>
  </div>

  <!-- IDENTIFY PANEL -->
  <div class="widget-panel" id="panel-identify">
    <div class="upload-dual">
      <div class="upload-slot">
        <div class="upload-slot-zone" id="zone-primary">
          <input type="file" id="file-input" accept="image/*" style="display:none" />
          <img id="preview-img" alt="Front" />
          <div class="scan-overlay scan-corners" id="scan-overlay"><div class="scan-line"></div></div>
          <div class="upload-slot-placeholder" id="placeholder-primary">
            <div class="upload-slot-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="0"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <div class="upload-slot-hint"><span class="slot-required">Front</span> · Required</div>
          </div>
        </div>
        <div class="upload-slot-label">Front / Main View</div>
      </div>
      <div class="upload-slot">
        <div class="upload-slot-zone" id="zone-secondary">
          <input type="file" id="file-input-secondary" accept="image/*" style="display:none" />
          <img id="preview-img-secondary" alt="Back" />
          <div class="upload-slot-placeholder" id="placeholder-secondary">
            <div class="upload-slot-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
            <div class="upload-slot-hint"><span class="slot-optional">Mark</span> · Optional</div>
          </div>
        </div>
        <div class="upload-slot-label">Signature · Mark · Hallmark</div>
      </div>
    </div>
    <div class="upload-actions">
      <button class="btn-primary" id="identify-btn" disabled>Identify This Item</button>
      <button class="btn-ghost" id="camera-btn">Use Camera — Front</button>
    </div>
    <div class="status-text" id="status"></div>
  </div>

  <!-- ASK PANEL (desktop) -->
  <div class="widget-panel ask-panel" id="panel-ask" style="display:none">
    <div class="ask-thread" id="ask-thread">
      <div class="ask-empty" id="ask-empty">
        <div class="ask-empty-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="ask-empty-title">Ask our {category} expert</div>
        <div class="ask-empty-sub">Cleaning, identification, valuation, history — ask anything.</div>
        <div class="ask-suggestions">
          <button class="ask-suggestion" data-q="How do I clean and care for my piece?">How do I clean and care for my piece?</button>
          <button class="ask-suggestion" data-q="How can I tell if it is genuine?">How can I tell if it is genuine?</button>
          <button class="ask-suggestion" data-q="Where is the best place to sell it?">Where is the best place to sell it?</button>
        </div>
      </div>
    </div>
    <div class="ask-composer">
      <textarea class="ask-input" id="ask-input" placeholder={`Ask anything about ${category.toLowerCase()}...`} rows="1"></textarea>
      <button class="ask-send" id="ask-send" aria-label="Send">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- ASK MOBILE MODAL -->
<div class="ask-modal" id="ask-modal" style="display:none" aria-modal="true" role="dialog">
  <div class="ask-modal-header">
    <div class="ask-modal-title">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Ask our {category} expert
    </div>
    <button class="ask-modal-close" id="ask-modal-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="ask-thread ask-modal-thread" id="ask-modal-thread">
    <div class="ask-empty" id="ask-modal-empty">
      <div class="ask-empty-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <div class="ask-empty-title">Ask our {category} expert</div>
      <div class="ask-empty-sub">Cleaning, identification, valuation, history — ask anything.</div>
      <div class="ask-suggestions">
        <button class="ask-suggestion" data-q="How do I clean and care for my piece?">How do I clean and care for my piece?</button>
        <button class="ask-suggestion" data-q="How can I tell if it is genuine?">How can I tell if it is genuine?</button>
        <button class="ask-suggestion" data-q="Where is the best place to sell it?">Where is the best place to sell it?</button>
      </div>
    </div>
  </div>
  <div class="ask-modal-composer">
    <textarea class="ask-input" id="ask-modal-input" placeholder={`Ask anything about ${category.toLowerCase()}...`} rows="1"></textarea>
    <button class="ask-send" id="ask-modal-send" aria-label="Send">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<style>
  .ai-widget { width: 100%; background: rgba(13,11,9,.82); backdrop-filter: blur(16px); border: 1px solid var(--border); }

  /* TABS */
  .widget-tabs { display: flex; border-bottom: 1px solid var(--border); }
  .widget-tab { flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 13px 16px; background: transparent; border: none; font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--textDim); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .2s, border-color .2s; }
  .widget-tab:hover { color: var(--text); }
  .widget-tab.active { color: var(--goldHi); border-bottom-color: var(--goldHi); }

  /* PANELS */
  .widget-panel { padding: 16px; }
  .ask-panel { padding: 12px; display: flex; flex-direction: column; gap: 10px; }

  /* UPLOAD */
  .upload-dual { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .upload-slot { position: relative; cursor: pointer; }
  .upload-slot-zone { width: 100%; aspect-ratio: 1/1; background: rgba(255,255,255,.03); border: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; transition: background .2s, border-color .2s; position: relative; }
  .upload-slot-zone:hover { background: rgba(255,255,255,.05); border-color: var(--borderHi); }
  .upload-slot-zone.has-image { border-color: var(--borderHi); }
  .upload-slot img { width: 100%; height: 100%; object-fit: contain; position: absolute; inset: 0; background: var(--surface); display: none; }
  .upload-slot img.visible { display: block; }
  .upload-slot-label { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--textDim); margin-top: 8px; text-align: center; }
  .upload-slot-placeholder { text-align: center; padding: 12px; }
  .upload-slot-icon { opacity: .7; margin: 0 auto 10px; display: flex; align-items: center; justify-content: center; }
  .upload-slot-hint { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--textDim); }
  .slot-required { color: var(--goldHi); font-size: 13px; }
  .slot-optional { color: var(--text); font-size: 13px; }
  @keyframes scanLine { 0% { top: 0%; } 100% { top: 100%; } }
  .scan-overlay { position: absolute; inset: 0; z-index: 10; pointer-events: none; display: none; overflow: hidden; }
  .scan-overlay.active { display: block; }
  .scan-line { position: absolute; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent, var(--goldHi), transparent); box-shadow: 0 0 12px 2px rgba(196,168,112,0.6); animation: scanLine 1.8s ease-in-out infinite; }
  .scan-corners::before, .scan-corners::after { content: ''; position: absolute; width: 24px; height: 24px; border-color: var(--goldHi); border-style: solid; }
  .scan-corners::before { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
  .scan-corners::after { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }
  .upload-actions { display: flex; flex-direction: column; gap: 8px; }
  .btn-primary { width: 100%; padding: 15px; background: var(--text); border: none; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--bg); cursor: pointer; transition: opacity .2s; }
  .btn-primary:hover { opacity: .9; }
  .btn-primary:disabled { opacity: .4; cursor: default; }
  .btn-ghost { width: 100%; padding: 15px; background: transparent; border: 1px solid var(--border); font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--textDim); cursor: pointer; transition: border-color .25s, color .25s; }
  .btn-ghost:hover { border-color: var(--borderHi); color: var(--text); }
  .status-text { font-family: 'Prata', Georgia, serif; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); text-align: center; min-height: 18px; margin-top: 12px; }

  /* ASK THREAD */
  .ask-thread { min-height: 220px; max-height: 340px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth; }
  .ask-thread::-webkit-scrollbar { width: 3px; }
  .ask-thread::-webkit-scrollbar-track { background: transparent; }
  .ask-thread::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* EMPTY STATE */
  .ask-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 16px 8px; text-align: center; min-height: 220px; }
  .ask-empty-icon { color: var(--goldHi); opacity: .3; margin-bottom: 14px; }
  .ask-empty-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 17px; font-style: italic; color: var(--text); margin-bottom: 6px; }
  .ask-empty-sub { font-family: 'Prata', Georgia, serif; font-size: 14px; color: var(--textDim); line-height: 1.7; margin-bottom: 18px; }
  .ask-suggestions { display: flex; flex-direction: column; gap: 6px; width: 100%; }
  .ask-suggestion { background: rgba(255,255,255,.04); border: 1px solid var(--border); padding: 10px 14px; font-family: 'Prata', Georgia, serif; font-size: 14px; color: var(--textDim); cursor: pointer; text-align: left; transition: border-color .2s, color .2s; line-height: 1.5; }
  .ask-suggestion:hover { border-color: var(--goldHi); color: var(--text); }

  /* MESSAGES */
  .ask-msg { display: flex; flex-direction: column; gap: 6px; animation: msgIn .2s ease; }
  @keyframes msgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .ask-msg-user { align-items: flex-end; }
  .ask-msg-ai { align-items: flex-start; }
  .ask-bubble { max-width: 88%; padding: 11px 15px; font-family: 'Prata', Georgia, serif; font-size: 14px; line-height: 1.75; }
  .ask-bubble-user { background: rgba(200,160,96,.15); border: 1px solid rgba(200,160,96,.25); color: var(--text); }
  .ask-bubble-ai { background: rgba(255,255,255,.04); border: 1px solid var(--border); color: var(--goldHi); }
  .ask-bubble-gate { background: rgba(200,160,96,.08); border: 1px solid rgba(200,160,96,.3); color: var(--goldHi); }

  /* MARKDOWN */
  .ask-md-p { margin: 0 0 10px; }
  .ask-md-p:last-child { margin-bottom: 0; }
  .ask-md-h2 { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 15px; font-style: italic; color: var(--goldHi); margin: 12px 0 6px; }
  .ask-md-h3 { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin: 10px 0 6px; }
  .ask-md-li { display: flex; gap: 8px; align-items: baseline; margin-bottom: 6px; }
  .ask-md-dot { color: var(--goldHi); font-size: 8px; flex-shrink: 0; margin-top: 2px; }

  /* SOURCES */
  .ask-sources { display: flex; flex-wrap: wrap; gap: 5px; padding: 0 2px; }
  .ask-source-tag { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); border: 1px solid rgba(200,160,96,.3); padding: 2px 8px; opacity: .8; }

  /* TYPING */
  .ask-typing { display: flex; gap: 5px; align-items: center; padding: 12px 15px; background: rgba(255,255,255,.04); border: 1px solid var(--border); width: fit-content; }
  .ask-typing span { width: 5px; height: 5px; border-radius: 50%; background: var(--goldHi); opacity: .3; animation: typingPulse 1.2s ease-in-out infinite; }
  .ask-typing span:nth-child(2) { animation-delay: .2s; }
  .ask-typing span:nth-child(3) { animation-delay: .4s; }
  @keyframes typingPulse { 0%,100%{opacity:.3} 50%{opacity:1} }

  /* GATE */
  .ask-gate-btn { display: inline-block; margin-top: 12px; font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--goldHi); text-decoration: none; border-bottom: 1px solid rgba(200,160,96,.4); padding-bottom: 2px; transition: border-color .2s; }
  .ask-gate-btn:hover { border-color: var(--goldHi); }

  /* COMPOSER */
  .ask-composer { display: flex; gap: 8px; align-items: flex-end; }
  .ask-input { flex: 1; background: rgba(255,255,255,.05); border: 1px solid var(--border); padding: 10px 14px; font-family: 'Prata', Georgia, serif; font-size: 14px; color: var(--text); outline: none; resize: none; line-height: 1.6; min-height: 42px; max-height: 140px; overflow-y: auto; transition: border-color .2s; box-sizing: border-box; }
  .ask-input:focus { border-color: var(--borderHi); }
  .ask-input::placeholder { color: var(--textDim); }
  .ask-send { width: 42px; height: 42px; background: var(--goldHi); border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #1C1810; flex-shrink: 0; transition: opacity .2s; }
  .ask-send:hover { opacity: .85; }
  .ask-send:disabled { opacity: .35; cursor: default; }

  /* MOBILE MODAL */
  .ask-modal { position: fixed; inset: 0; z-index: 9999; background: rgba(13,11,9,.97); display: flex; flex-direction: column; }
  .ask-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--border); flex-shrink: 0; padding-top: max(16px, env(safe-area-inset-top)); }
  .ask-modal-title { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 17px; font-style: italic; color: var(--text); display: flex; align-items: center; gap: 8px; }
  .ask-modal-close { background: none; border: 1px solid var(--border); color: var(--textDim); cursor: pointer; padding: 8px; display: flex; align-items: center; justify-content: center; transition: border-color .2s, color .2s; }
  .ask-modal-close:hover { border-color: var(--goldHi); color: var(--goldHi); }
  .ask-modal-thread { flex: 1; overflow-y: auto; padding: 16px 20px; display: flex; flex-direction: column; gap: 14px; scroll-behavior: smooth; }
  .ask-modal-composer { display: flex; gap: 8px; align-items: flex-end; padding: 12px 20px; border-top: 1px solid var(--border); flex-shrink: 0; padding-bottom: max(12px, env(safe-area-inset-bottom)); background: rgba(13,11,9,.97); }
  .ask-modal-composer .ask-input { flex: 1; }

  @media (min-width: 768px) { .ask-modal { display: none !important; } }
</style>

<script define:vars={{ context }}>
  import { sendToAsk, buildUserBubble, buildAIBubble, buildTyping, buildGuestGate, getGuestCount, incrementGuestCount } from './AskChat'

  const GUEST_LIMIT = 3
  const isMobile = () => window.innerWidth < 768

  let askHistory = []
  let isSending = false

  // ── TABS ──
  const tabIdentify = document.getElementById('tab-identify')
  const tabAsk = document.getElementById('tab-ask')
  const panelIdentify = document.getElementById('panel-identify')
  const panelAsk = document.getElementById('panel-ask')
  const modal = document.getElementById('ask-modal')
  const modalClose = document.getElementById('ask-modal-close')

  tabIdentify.addEventListener('click', () => {
    tabIdentify.classList.add('active')
    tabAsk.classList.remove('active')
    panelIdentify.style.display = 'block'
    panelAsk.style.display = 'none'
    if (modal) { modal.style.display = 'none'; document.body.style.overflow = '' }
  })

  tabAsk.addEventListener('click', () => {
    tabAsk.classList.add('active')
    tabIdentify.classList.remove('active')
    panelIdentify.style.display = 'none'
    panelAsk.style.display = 'flex'
    if (isMobile()) {
      document.body.appendChild(modal)
      modal.style.display = 'flex'
      document.body.style.overflow = 'hidden'
      setTimeout(() => document.getElementById('ask-modal-input')?.focus(), 100)
    } else {
      setTimeout(() => document.getElementById('ask-input')?.focus(), 100)
    }
  })

  modalClose.addEventListener('click', () => {
    modal.style.display = 'none'
    document.body.style.overflow = ''
    tabIdentify.click()
  })

  // ── UPLOAD ──
  const zonePrimary = document.getElementById('zone-primary')
  const zoneSecondary = document.getElementById('zone-secondary')
  const fileInput = document.getElementById('file-input')
  const fileInputSecondary = document.getElementById('file-input-secondary')
  const previewImg = document.getElementById('preview-img')
  const previewImgSecondary = document.getElementById('preview-img-secondary')
  const placeholderPrimary = document.getElementById('placeholder-primary')
  const placeholderSecondary = document.getElementById('placeholder-secondary')
  const identifyBtn = document.getElementById('identify-btn')
  const cameraBtn = document.getElementById('camera-btn')
  const status = document.getElementById('status')
  const scanOverlay = document.getElementById('scan-overlay')

  let selectedFile = null
  let selectedFileSecondary = null

  zonePrimary.addEventListener('click', () => fileInput.click())
  zoneSecondary.addEventListener('click', () => fileInputSecondary.click())
  cameraBtn.addEventListener('click', () => { fileInput.setAttribute('capture', 'environment'); fileInput.click() })

  zonePrimary.addEventListener('dragover', e => { e.preventDefault(); zonePrimary.style.borderColor = 'var(--goldHi)' })
  zonePrimary.addEventListener('dragleave', () => { zonePrimary.style.borderColor = '' })
  zonePrimary.addEventListener('drop', e => { e.preventDefault(); zonePrimary.style.borderColor = ''; const f = e.dataTransfer?.files?.[0]; if (f) setFile(f) })
  zoneSecondary.addEventListener('dragover', e => { e.preventDefault(); zoneSecondary.style.borderColor = 'var(--goldHi)' })
  zoneSecondary.addEventListener('dragleave', () => { zoneSecondary.style.borderColor = '' })
  zoneSecondary.addEventListener('drop', e => { e.preventDefault(); zoneSecondary.style.borderColor = ''; const f = e.dataTransfer?.files?.[0]; if (f) setFileSecondary(f) })

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) setFile(fileInput.files[0]) })
  fileInputSecondary.addEventListener('change', () => { if (fileInputSecondary.files?.[0]) setFileSecondary(fileInputSecondary.files[0]) })

  function setFile(file) {
    selectedFile = file
    previewImg.src = URL.createObjectURL(file)
    previewImg.classList.add('visible')
    placeholderPrimary.style.display = 'none'
    zonePrimary.classList.add('has-image')
    identifyBtn.removeAttribute('disabled')
    document.dispatchEvent(new CustomEvent('widget-reset-result'))
  }

  function setFileSecondary(file) {
    selectedFileSecondary = file
    previewImgSecondary.src = URL.createObjectURL(file)
    previewImgSecondary.classList.add('visible')
    placeholderSecondary.style.display = 'none'
    zoneSecondary.classList.add('has-image')
  }

  identifyBtn.addEventListener('click', async () => {
    if (!selectedFile) return
    identifyBtn.setAttribute('disabled', 'true')
    status.textContent = 'Uploading...'
    scanOverlay.classList.add('active')
    try {
      const formData = new FormData()
      formData.append('file', selectedFile)
      const uploadRes = await fetch('/api/upload-url', { method: 'POST', body: formData })
      const uploadData = await uploadRes.json()
      if (uploadData.error) throw new Error(uploadData.error)
      let secondaryKey = null
      if (selectedFileSecondary) {
        const secFormData = new FormData()
        secFormData.append('file', selectedFileSecondary)
        const secRes = await fetch('/api/upload-url', { method: 'POST', body: secFormData })
        const secData = await secRes.json()
        if (!secData.error) secondaryKey = secData.key
      }
      status.textContent = 'Examining the object...'
      const identifyRes = await fetch('/api/identify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: uploadData.key, secondary_key: secondaryKey, context, user_id: window.__gauk_user_id || null })
      })
      const identifyData = await identifyRes.json()
      if (identifyData.error) throw new Error(identifyData.error)
      status.textContent = ''
      scanOverlay.classList.remove('active')
      document.dispatchEvent(new CustomEvent('identification-complete', { detail: identifyData }))
    } catch (err) {
      status.textContent = err.message
      scanOverlay.classList.remove('active')
    } finally {
      identifyBtn.removeAttribute('disabled')
    }
  })

  // ── ASK ──
  function getActiveThread() {
    return isMobile()
      ? document.getElementById('ask-modal-thread')
      : document.getElementById('ask-thread')
  }

  function scrollThread() {
    const t = getActiveThread()
    if (t) t.scrollTop = t.scrollHeight
  }

  function clearEmpty() {
    document.getElementById('ask-empty')?.remove()
    document.getElementById('ask-modal-empty')?.remove()
  }

  async function handleSend(question) {
    if (!question.trim() || isSending) return
    const userId = window.__gauk_user_id || null
    const guestCount = getGuestCount()

    if (!userId && guestCount >= GUEST_LIMIT) {
      clearEmpty()
      const thread = getActiveThread()
      thread.appendChild(buildUserBubble(question))
      thread.appendChild(buildGuestGate())
      scrollThread()
      return
    }

    isSending = true
    clearEmpty()
    const thread = getActiveThread()
    thread.appendChild(buildUserBubble(question))
    const typing = buildTyping()
    thread.appendChild(typing)
    scrollThread()

    try {
      const data = await sendToAsk(question, askHistory, context, userId, null)
      typing.remove()
      askHistory.push({ role: 'user', content: question })
      askHistory.push({ role: 'assistant', content: data.answer })
      thread.appendChild(buildAIBubble(data.answer, data.sources))
      if (!userId) incrementGuestCount()
    } catch (err) {
      typing.remove()
      thread.appendChild(buildAIBubble('Something went wrong — please try again.', []))
    } finally {
      isSending = false
      scrollThread()
    }
  }

  function setupComposer(inputId, sendId) {
    const input = document.getElementById(inputId)
    const send = document.getElementById(sendId)
    if (!input || !send) return
    input.addEventListener('input', () => {
      input.style.height = 'auto'
      input.style.height = Math.min(input.scrollHeight, 140) + 'px'
    })
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); fire(input, send) }
    })
    send.addEventListener('click', () => fire(input, send))
  }

  function fire(input, send) {
    const q = input.value.trim()
    if (!q) return
    input.value = ''
    input.style.height = 'auto'
    handleSend(q)
  }

  setupComposer('ask-input', 'ask-send')
  setupComposer('ask-modal-input', 'ask-modal-send')

  document.querySelectorAll('.ask-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-q')
      const inputId = isMobile() ? 'ask-modal-input' : 'ask-input'
      const sendId = isMobile() ? 'ask-modal-send' : 'ask-send'
      const input = document.getElementById(inputId)
      if (input) { input.value = q; fire(input, document.getElementById(sendId)) }
    })
  })
</script>
