---
---
<div class="max-w-lg mx-auto p-8">
  <h2 class="text-xl font-bold mb-6">Identify an Antique</h2>

  <div id="drop-zone" class="border-2 border-dashed border-neutral-600 rounded-xl p-12 text-center cursor-pointer hover:border-amber-500 transition-colors">
    <input type="file" id="file-input" accept="image/*" class="hidden" />
    <p class="text-neutral-400 mb-4">Drop an image here or</p>
    <div class="flex gap-3 justify-center">
      <button id="browse-btn" class="px-4 py-2 bg-amber-600 hover:bg-amber-500 rounded-lg text-sm font-medium transition-colors">
        Browse Files
      </button>
      <button id="camera-btn" class="px-4 py-2 bg-neutral-700 hover:bg-neutral-600 rounded-lg text-sm font-medium transition-colors">
        Use Camera
      </button>
    </div>
  </div>

  <div id="preview" class="hidden mt-6">
    <img id="preview-img" src="" alt="Preview" class="w-full rounded-xl object-cover max-h-80" />
    <button id="identify-btn" class="mt-4 w-full py-3 bg-amber-600 hover:bg-amber-500 rounded-xl font-semibold transition-colors">
      Identify This Item
    </button>
  </div>

  <div id="status" class="mt-4 text-sm text-neutral-400"></div>

  <div id="result" class="hidden mt-8 p-6 bg-neutral-900 rounded-xl border border-neutral-700">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h3 id="result-category" class="text-amber-500 text-sm font-medium uppercase tracking-wider"></h3>
        <h2 id="result-subcategory" class="text-xl font-bold mt-1"></h2>
      </div>
      <span id="result-confidence" class="text-xs px-2 py-1 rounded-full bg-neutral-800 text-neutral-400"></span>
    </div>
    <p id="result-description" class="text-neutral-300 text-sm leading-relaxed mb-4"></p>
    <div class="grid grid-cols-2 gap-4 text-sm mb-4">
      <div>
        <span class="text-neutral-500">Period</span>
        <p id="result-period" class="text-neutral-200 font-medium"></p>
      </div>
      <div>
        <span class="text-neutral-500">Origin</span>
        <p id="result-origin" class="text-neutral-200 font-medium"></p>
      </div>
      <div>
        <span class="text-neutral-500">Maker</span>
        <p id="result-maker" class="text-neutral-200 font-medium"></p>
      </div>
      <div>
        <span class="text-neutral-500">Condition</span>
        <p id="result-condition" class="text-neutral-200 font-medium"></p>
      </div>
    </div>
    <div class="border-t border-neutral-700 pt-4">
      <span class="text-neutral-500 text-sm">Estimated Value</span>
      <p id="result-value" class="text-2xl font-bold text-amber-500 mt-1"></p>
    </div>
    <div id="save-note" class="hidden mt-3 text-xs text-green-400">Saved to your library</div>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js'

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )

  const fileInput = document.getElementById('file-input') as HTMLInputElement
  const browseBtn = document.getElementById('browse-btn')
  const cameraBtn = document.getElementById('camera-btn')
  const dropZone = document.getElementById('drop-zone')
  const preview = document.getElementById('preview')
  const previewImg = document.getElementById('preview-img') as HTMLImageElement
  const identifyBtn = document.getElementById('identify-btn')
  const status = document.getElementById('status')
  const result = document.getElementById('result')
  const saveNote = document.getElementById('save-note')

  let selectedFile: File | null = null

  browseBtn?.addEventListener('click', () => {
    fileInput.removeAttribute('capture')
    fileInput.click()
  })

  cameraBtn?.addEventListener('click', () => {
    fileInput.setAttribute('capture', 'environment')
    fileInput.click()
  })

  fileInput?.addEventListener('change', () => {
    const file = fileInput.files?.[0]
    if (file) handleFile(file)
  })

  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault()
    dropZone.classList.add('border-amber-500')
  })

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-amber-500')
  })

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault()
    dropZone.classList.remove('border-amber-500')
    const file = e.dataTransfer?.files?.[0]
    if (file) handleFile(file)
  })

  function handleFile(file: File) {
    selectedFile = file
    result?.classList.add('hidden')
    const reader = new FileReader()
    reader.onload = (e) => {
      if (previewImg && e.target?.result) {
        previewImg.src = e.target.result as string
        preview?.classList.remove('hidden')
      }
    }
    reader.readAsDataURL(file)
  }

  identifyBtn?.addEventListener('click', async () => {
    if (!selectedFile) return

    status!.textContent = 'Uploading image...'
    identifyBtn.setAttribute('disabled', 'true')
    result?.classList.add('hidden')

    try {
      const formData = new FormData()
      formData.append('file', selectedFile)

      const uploadRes = await fetch('/api/upload-url', {
        method: 'POST',
        body: formData
      })

      const uploadData = await uploadRes.json()
      if (uploadData.error) throw new Error(uploadData.error)

      status!.textContent = 'Identifying with Claude Vision...'

      const { data: { session } } = await supabase.auth.getSession()
      const user_id = session?.user?.id || null

      const identifyRes = await fetch('/api/identify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: uploadData.key, user_id })
      })

      const identifyData = await identifyRes.json()
      if (identifyData.error) throw new Error(identifyData.error)

      const r = identifyData.result
      status!.textContent = ''

      document.getElementById('result-category')!.textContent = r.category
      document.getElementById('result-subcategory')!.textContent = r.subcategory
      document.getElementById('result-description')!.textContent = r.description
      document.getElementById('result-period')!.textContent = r.period || 'Unknown'
      document.getElementById('result-origin')!.textContent = r.country_of_origin || 'Unknown'
      document.getElementById('result-maker')!.textContent = r.maker || 'Unknown'
      document.getElementById('result-condition')!.textContent = r.condition
      document.getElementById('result-confidence')!.textContent = r.confidence + ' confidence'
      document.getElementById('result-value')!.textContent =
        '£' + r.value_range_low.toLocaleString() + ' – £' + r.value_range_high.toLocaleString()

      result?.classList.remove('hidden')

      if (user_id && identifyData.id) {
        saveNote?.classList.remove('hidden')
      }

    } catch (err: any) {
      status!.textContent = 'Error: ' + err.message
    } finally {
      identifyBtn.removeAttribute('disabled')
    }
  })
</script>
