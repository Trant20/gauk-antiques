---
---
<style is:global>
  .snav-trigger {
    position: fixed; top: 14px; left: 16px; z-index: 200;
    width: 36px; height: 36px; background: none; border: 1px solid #C4B49E;
    cursor: pointer; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 5px;
    transition: border-color .2s;
  }
  .snav-trigger:hover { border-color: #7A5C20; }
  .snav-trigger span {
    display: block; width: 16px; height: 1px; background: #5C5040;
    transition: all .25s;
  }
  .snav-trigger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .snav-trigger.open span:nth-child(2) { opacity: 0; }
  .snav-trigger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .snav-overlay {
    position: fixed; inset: 0; z-index: 150;
    background: rgba(28,24,16,.5); backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none; transition: opacity .25s;
  }
  .snav-overlay.open { opacity: 1; pointer-events: all; }

  .snav-drawer {
    position: fixed; top: 0; left: 0; bottom: 0; z-index: 160;
    width: 280px; background: #EFE7D9; border-right: 1px solid #C4B49E;
    display: flex; flex-direction: column;
    transform: translateX(-100%); transition: transform .28s cubic-bezier(.22,1,.36,1);
  }
  .snav-drawer.open { transform: translateX(0); }

  .snav-head {
    padding: 20px 24px 20px 64px;
    border-bottom: 1px solid #C4B49E;
  }
  .snav-logo { font-family: 'Prata', Georgia, serif; font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #1C1810; }
  .snav-logo span { color: #7A5C20; }

  .snav-body { flex: 1; overflow-y: auto; padding: 24px 0; }

  .snav-section { padding: 0 24px; margin-bottom: 8px; }
  .snav-section-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; margin-bottom: 8px; margin-top: 24px; }

  .snav-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 24px; text-decoration: none;
    font-family: 'Prata', Georgia, serif; font-size: 14px; letter-spacing: 1px;
    color: #5C5040; border-left: 2px solid transparent;
    transition: color .15s, border-color .15s, background .15s;
  }
  .snav-item:hover { color: #1C1810; background: #E6DCCB; }
  .snav-item.active { color: #7A5C20; border-left-color: #7A5C20; background: #E6DCCB; }
  .snav-item svg { flex-shrink: 0; opacity: .6; }
  .snav-item.active svg { opacity: 1; }

  .snav-divider { height: 1px; background: #C4B49E; margin: 16px 24px; }

  .snav-credits-block {
    margin: 0 24px 24px;
    background: #E6DCCB; border: 1px solid #C4B49E; padding: 16px;
  }
  .snav-credits-label { font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 3px; text-transform: uppercase; color: #8A7A66; margin-bottom: 6px; }
  .snav-credits-value { font-family: 'Playfair Display', Didot, Georgia, serif; font-size: 32px; color: #7A5C20; line-height: 1; margin-bottom: 10px; }
  .snav-credits-btn { display: block; width: 100%; padding: 10px; background: #1C1810; border: none; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #EFE7D9; cursor: pointer; text-decoration: none; text-align: center; transition: opacity .2s; box-sizing: border-box; }
  .snav-credits-btn:hover { opacity: .85; }

  .snav-foot {
    padding: 16px 24px; border-top: 1px solid #C4B49E;
  }
  .snav-signout { width: 100%; padding: 12px; background: none; border: 1px solid #C4B49E; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #8A7A66; cursor: pointer; transition: all .2s; }
  .snav-signout:hover { border-color: #C46028; color: #C46028; }
  .snav-signin { display: block; width: 100%; padding: 12px; background: #B8860B; border: none; font-family: 'Prata', Georgia, serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #fff; cursor: pointer; text-decoration: none; text-align: center; box-sizing: border-box; }
</style>

<!-- Hamburger trigger -->
<button class="snav-trigger" id="snav-trigger" aria-label="Menu">
  <span></span><span></span><span></span>
</button>

<!-- Overlay -->
<div class="snav-overlay" id="snav-overlay"></div>

<!-- Drawer -->
<nav class="snav-drawer" id="snav-drawer">
  <div class="snav-head">
    <div class="snav-logo">GAUK <span>Antiques</span></div>
  </div>

  <div class="snav-body">
    <div class="snav-section-label" style="padding: 0 24px;">Navigate</div>
    <a href="/" class="snav-item" data-path="/">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      Identify
    </a>
    <a href="/library" class="snav-item" data-path="/library">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
      </svg>
      My Library
    </a>
    <a href="/account" class="snav-item" data-path="/account">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      My Account
    </a>
    <a href="/pricing" class="snav-item" data-path="/pricing">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="12" y1="1" x2="12" y2="23"/>
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
      Pricing
    </a>

    <div class="snav-divider"></div>

    <!-- Credits block — shown when logged in -->
    <div class="snav-credits-block" id="snav-credits-block" style="display:none">
      <div class="snav-credits-label">Credits Remaining</div>
      <div class="snav-credits-value" id="snav-credits-value">—</div>
      <a href="/pricing" class="snav-credits-btn">Top Up</a>
    </div>
  </div>

  <div class="snav-foot">
    <button class="snav-signout" id="snav-signout" style="display:none">Sign Out</button>
    <a href="/auth/signin" class="snav-signin" id="snav-signin" style="display:none">Sign In</a>
  </div>
</nav>

<script>
  import { createClient } from '@supabase/supabase-js'
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  )
  const SITE_ID = 'add6d12c-ecd8-4517-b2e5-0f4977603744'

  const trigger = document.getElementById('snav-trigger')!
  const overlay = document.getElementById('snav-overlay')!
  const drawer  = document.getElementById('snav-drawer')!

  function open() { trigger.classList.add('open'); overlay.classList.add('open'); drawer.classList.add('open') }
  function close() { trigger.classList.remove('open'); overlay.classList.remove('open'); drawer.classList.remove('open') }

  trigger.addEventListener('click', () => drawer.classList.contains('open') ? close() : open())
  overlay.addEventListener('click', close)

  // Active state
  const path = window.location.pathname
  document.querySelectorAll('.snav-item[data-path]').forEach(el => {
    const p = (el as HTMLElement).dataset.path
    if (p === '/' ? path === '/' : path.startsWith(p!)) el.classList.add('active')
  })

  // Auth state
  const { data: { session } } = await supabase.auth.getSession()
  if (session) {
    document.getElementById('snav-signout')!.style.display = 'block'
    document.getElementById('snav-signin')!.style.display = 'none'
    document.getElementById('snav-credits-block')!.style.display = 'block'

    const { data: credits } = await supabase.from('credits').select('balance').eq('user_id', session.user.id).eq('site_id', SITE_ID).single()
    document.getElementById('snav-credits-value')!.textContent = String(credits?.balance ?? 0)

    document.getElementById('snav-signout')!.addEventListener('click', async () => {
      await supabase.auth.signOut()
      window.location.href = '/'
    })
  } else {
    document.getElementById('snav-signin')!.style.display = 'block'
    document.getElementById('snav-signout')!.style.display = 'none'
  }
</script>
